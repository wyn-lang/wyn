// Test lambda/anonymous functions

fn apply(f: fn(int) -> int, x: int) -> int {
    // Call function pointer - need indirect call support
    return f(x)
}

fn main() {
    // Simple lambda
    const double: fn(int) -> int = fn(x: int) -> int { return x * 2 }
    
    // Call lambda directly
    const r1: int = double(5)
    print(r1)
    assert(r1 == 10)
    
    // Lambda with multiple params
    const add: fn(int, int) -> int = fn(a: int, b: int) -> int { return a + b }
    const r2: int = add(3, 4)
    print(r2)
    assert(r2 == 7)
    
    print("Lambda: OK")
}
