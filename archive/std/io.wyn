# std/io.wyn - Minimal I/O without Result types

fn print(s: str) {
    print_str(s)
}

fn println(s: str) {
    print_str(s)
    print_str("\n")
}

fn print_line(s: str) {
    print_str(s)
    print_str("\n")
}

fn path_exists(path: str) -> bool {
    return file_exists(path)
}

fn read_line() -> str {
    return ""
}

fn file_exists(path: str) -> bool {
    return false
}
