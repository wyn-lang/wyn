# Test Module - Pure Wyn

fn assert(condition: bool) {
    if not condition {
        print("Assertion failed!")
        syscall(1, 1, 0, 0, 0, 0, 0)  # exit(1)
    }
}

fn assert_eq(a: int, b: int) {
    if a != b {
        print("Assertion failed: values not equal")
        syscall(1, 1, 0, 0, 0, 0, 0)
    }
}
