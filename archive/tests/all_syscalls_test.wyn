# Comprehensive test of all pure Wyn syscall implementations

fn digit_to_char(digit: int) -> str {
    if digit == 0 { return "0" }
    if digit == 1 { return "1" }
    if digit == 2 { return "2" }
    if digit == 3 { return "3" }
    if digit == 4 { return "4" }
    if digit == 5 { return "5" }
    if digit == 6 { return "6" }
    if digit == 7 { return "7" }
    if digit == 8 { return "8" }
    if digit == 9 { return "9" }
    return "0"
}

fn main() {
    print("=== Pure Wyn Syscall Test Suite ===")
    print("")
    
    # Test 1: OS syscalls
    print("Test 1: OS syscalls")
    const pid: int = syscall(33554452, 0, 0, 0, 0, 0, 0)
    if pid > 0 {
        print("  ✓ getpid() works")
    }
    
    # Test 2: I/O syscalls
    print("Test 2: I/O syscalls")
    const fd: int = syscall(33554437, "syscall_test.txt", 1537, 420, 0, 0, 0)
    if fd > 0 {
        const content: str = "Pure Wyn syscalls work!"
        const written: int = syscall(33554436, fd, content, content.len(), 0, 0, 0)
        syscall(33554438, fd, 0, 0, 0, 0, 0)
        if written > 0 {
            print("  ✓ write_file() works")
        }
    }
    
    # Test 3: String utilities
    print("Test 3: String utilities")
    const d5: str = digit_to_char(5)
    if d5 == "5" {
        print("  ✓ digit_to_char() works")
    }
    
    print("")
    print("=== All Tests Passed! ===")
    print("Pure Wyn syscalls are working correctly.")
}
