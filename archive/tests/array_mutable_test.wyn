
fn main() {
    // Test 1: Basic append
    let arr1: [int] = []
    arr1.append(10)
    arr1.append(20)
    arr1.append(30)
    assert(arr1.len() == 3)
    assert(arr1[0] == 10)
    assert(arr1[1] == 20)
    assert(arr1[2] == 30)
    print("✓ Test 1: Basic append passed")
    
    // Test 2: Append to non-empty array
    let arr2: [int] = [1, 2, 3]
    arr2.append(4)
    arr2.append(5)
    assert(arr2.len() == 5)
    assert(arr2[3] == 4)
    assert(arr2[4] == 5)
    print("✓ Test 2: Append to non-empty array passed")
    
    // Test 3: Many appends (test capacity growth)
    let arr3: [int] = []
    for i in 0..20 {
        arr3.append(i)
    }
    assert(arr3.len() == 20)
    assert(arr3[0] == 0)
    assert(arr3[10] == 10)
    assert(arr3[19] == 19)
    print("✓ Test 3: Many appends passed")
    
    print("✓ All mutable array tests passed!")
}
