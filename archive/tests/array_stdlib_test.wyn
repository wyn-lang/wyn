fn main() {
    print("Testing array stdlib...")
    
    # Test array creation and access
    const arr: [int] = [1, 2, 3, 4, 5]
    assert(arr.len() == 5)
    assert(arr[0] == 1)
    assert(arr[4] == 5)
    
    # Test array slicing
    const slice1: [int] = arr[0:3]
    assert(slice1.len() == 3)
    assert(slice1[0] == 1)
    assert(slice1[2] == 3)
    
    print("✓ All array stdlib tests passed")
}
