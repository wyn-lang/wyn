import collections


fn main() {
    print("Testing collections stdlib...\n")
    
    const arr: [int] = [1, 2, 3, 4, 5]
    
    # Test length
    assert(arr.len() == 5, "length is 5")
    
    # Test indexing
    assert(arr[0] == 1, "first element")
    assert(arr[1] == 2, "second element")
    assert(arr[4] == 5, "last element")
    
    # Test slicing
    const slice1: [int] = arr[0:2]
    assert(slice1.len() == 2, "slice length")
    assert(slice1[0] == 1, "slice first")
    
    const slice2: [int] = arr[2:5]
    assert(slice2.len() == 3, "slice length")
    assert(slice2[0] == 3, "slice first")
    
    # Test empty array
    const empty: [int] = []
    assert(empty.len() == 0, "empty array")
    
    # Test single element
    const single: [int] = [42]
    assert(single.len() == 1, "single element")
    assert(single[0] == 42, "value correct")
    
    print("✓ All collections stdlib tests passed\n")
}
