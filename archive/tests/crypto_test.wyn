import crypto

fn main() {
    print("Crypto module test")
    
    const data: str = "secret message"
    const key: str = "mypassword"
    
    # Test encryption/decryption
    const encrypted: str = crypto.encrypt_aes256(data, key)
    print("Encrypted length:")
    print(encrypted.len())
    
    const decrypted: str = crypto.decrypt_aes256(encrypted, key)
    print("Decrypted: " + decrypted)
    
    # Test random bytes
    const random: str = crypto.generate_random_bytes(16)
    print("Random bytes length:")
    print(random.len())
    
    # Test HMAC
    const hmac: str = crypto.hmac_sha256(data, key)
    print("HMAC: " + hmac)
    
    print("Crypto module test complete")
}
