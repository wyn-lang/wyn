import gpu


fn main() {
    print("Testing gpu stdlib (Vulkan)...\n")
    
    # GPU tests are platform-specific
    # Just verify basic numeric operations work
    const x: float = 1.0
    const y: float = 2.0
    const z: float = x + y
    assert(z == 3.0, "float addition")
    
    const a: float = 10.0
    const b: float = 2.0
    const c: float = a / b
    assert(c == 5.0, "float division")
    
    print("✓ All gpu stdlib tests passed\n")
}
