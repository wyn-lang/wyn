import log


fn main() {
    print("Testing log stdlib...\n")
    
    # Test print functions
    print("  [INFO] Test message\n")
    print("  [WARN] Warning message\n")
    print("  [ERROR] Error message\n")
    
    # Test that print functions work
    const msg: str = "test"
    assert(msg.len() > 0, "message not empty")
    
    print("✓ All log stdlib tests passed\n")
}
