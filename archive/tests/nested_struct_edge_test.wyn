# Edge case tests for nested struct field access


struct Inner { a: int, b: int }
struct Middle { inner: Inner, c: int }
struct Outer { middle: Middle, d: int }

fn main() {
    # Triple nesting
    const outer: Outer = Outer {
        middle: Middle {
            inner: Inner { a: 1, b: 2 },
            c: 3
        },
        d: 4
    }
    
    assert(outer.middle.inner.a == 1)
    assert(outer.middle.inner.b == 2)
    assert(outer.middle.c == 3)
    assert(outer.d == 4)
    
    # Nested struct in array
    const arr: [Inner] = [Inner { a: 10, b: 20 }, Inner { a: 30, b: 40 }]
    assert(arr[0].a == 10)
    assert(arr[0].b == 20)
    assert(arr[1].a == 30)
    assert(arr[1].b == 40)
    
    # Multiple nested structs
    const m1: Middle = Middle { inner: Inner { a: 100, b: 200 }, c: 300 }
    const m2: Middle = Middle { inner: Inner { a: 400, b: 500 }, c: 600 }
    assert(m1.inner.a == 100)
    assert(m2.inner.a == 400)
    
    print("Nested struct edge cases: OK")
}
