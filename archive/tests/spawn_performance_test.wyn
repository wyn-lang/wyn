fn cpu_work() {
    # Simulate some CPU work
    let sum: int = 0
    for i in 0..1000 {
        sum = sum + i
    }
}

fn main() {
    print("M:N Scheduler Performance Test\n")
    print("=============================\n")
    
    # Test 1: 100k lightweight tasks
    print("Test 1: 100k lightweight tasks\n")
    let counter1: int = 0
    
    for i in 0..100000 {
        spawn { counter1 = counter1 + 1 }
    }
    
    sleep_ms(10000)  # 10 seconds
    
    print("Completed: ")
    print(counter1)
    print("/100000\n")
    
    # Test 2: 10k CPU-intensive tasks
    print("\nTest 2: 10k CPU-intensive tasks\n")
    let counter2: int = 0
    
    for i in 0..10000 {
        spawn { 
            cpu_work()
            counter2 = counter2 + 1 
        }
    }
    
    sleep_ms(15000)  # 15 seconds
    
    print("Completed: ")
    print(counter2)
    print("/10000\n")
    
    # Test 3: Nested spawns
    print("\nTest 3: Nested spawns (1k x 10)\n")
    let counter3: int = 0
    
    for i in 0..1000 {
        spawn {
            for j in 0..10 {
                spawn { counter3 = counter3 + 1 }
            }
        }
    }
    
    sleep_ms(5000)  # 5 seconds
    
    print("Completed: ")
    print(counter3)
    print("/10000\n")
    
    print("\nPerformance Summary:\n")
    print("- Lightweight tasks: ")
    print(counter1)
    print(" completed\n")
    
    print("- CPU tasks: ")
    print(counter2)
    print(" completed\n")
    
    print("- Nested tasks: ")
    print(counter3)
    print(" completed\n")
    
    assert(counter1 >= 95000)
    assert(counter2 >= 9500)
    assert(counter3 >= 9500)
    
    print("✓ All performance tests passed\n")
}
