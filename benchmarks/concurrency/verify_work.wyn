fn compute(n: int) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + i * i
        i = i + 1
    }
    print_str("Sum: ")
    print(sum)
    print_newline()
}

fn main() {
    spawn { compute(100000) }
    spawn { compute(100000) }
    spawn { compute(100000) }
    
    print_str("Done")
    print_newline()
}
