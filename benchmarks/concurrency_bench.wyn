#!/usr/bin/env wyn run
# Concurrency benchmark - spawn 1000 tasks

fn main() {
    let counter: int = 0
    let i: int = 0
    
    while i < 1000 {
        spawn {
            counter = counter + 1
        }
        i = i + 1
    }
    
    task_join_all()
    
    print("Spawned and completed 1000 tasks")
    print("Final counter: " + int_to_str(counter))
}
