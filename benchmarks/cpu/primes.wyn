fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    return true
}

fn main() {
    let mut count = 0
    let mut i = 0
    
    while i < 1000000 {
        if is_prime(i) {
            count = count + 1
        }
        i = i + 1
    }
    
    print("Primes found: ")
    print(count)
}
