import std/io

fn main() {
    const content: str = "test data\n"
    let i: int = 0
    
    while i < 1000 {
        write_file("temp/bench.txt", content)
        const data: str = read_file("temp/bench.txt")
        i = i + 1
    }
    
    delete_file("temp/bench.txt")
    io.print("File I/O: ")
    print(i)
    io.print(" operations")
    io.print("")
}
