# Regex matching benchmark

fn main() {
    const text = "The quick brown fox jumps over the lazy dog 12345"
    const pattern = "[0-9]+"
    
    let i: int = 0
    let matches: int = 0
    
    while i < 10000 {
        if regex.matches(text, pattern) {
            matches = matches + 1
        }
        i = i + 1
    }
    
    print(matches)
}
