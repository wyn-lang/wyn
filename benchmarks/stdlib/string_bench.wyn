fn main() {
    const iterations: int = 1000000
    let i: int = 0
    
    # String operations
    while i < iterations {
        const s: str = "hello world"
        const len: int = s.len()
        const sub: str = s[0:5]
        const found: int = str_find(s, "world")
        const parts: [str] = str_split(s, " ")
        const concat: str = s + " test"
        i = i + 1
    }
    
    print_str("String benchmark complete\n")
}
