fn main() {
    print("Wyn LLVM Codegen Integration Example")
    print("====================================")
    
    compile_to_llvm()
    
    print("\nCompiler pipeline integration:")
    let ir = compiler_pipeline("fn main() { return 42 }")
    print(ir)
    
    print("\nNext steps:")
    print("1. Integrate with parser AST")
