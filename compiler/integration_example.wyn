// Integration example: Using Wyn LLVM codegen

import compiler.codegen.{codegen_new, CodeGen, Module, FnDef, Stmt, ReturnStmt, Return}
import compiler.ast.{Expr, LiteralExpr, LiteralValue, Literal}

// Example usage of the codegen
fn compile_to_llvm() {
    // Create codegen instance
    let codegen = codegen_new()
    
    // Create a simple function that returns 42
    let return_expr = Literal(LiteralExpr{
        value: Int(42),
        line: 1,
        column: 1
    })
    
    let return_stmt = Return(ReturnStmt{value: return_expr})
    
    let main_fn = FnDef{
        name: "main",
        params: [],
        body: [return_stmt],
        ret_type: "int"
    }
    
    let module = Module{functions: [main_fn]}
    
    // Generate LLVM IR
    let llvm_ir = codegen.gen_module(module)
    
    print("Generated LLVM IR:")
    print(llvm_ir)
    
    // In a real compiler, you would:
    // 1. Write IR to a .ll file
    // 2. Use llc to compile to assembly: llc -filetype=obj output.ll
    // 3. Link with system libraries: clang output.o -o executable
}

