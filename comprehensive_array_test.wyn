fn main() {
    # Test basic array operations
    let arr: [int] = [10, 20, 30, 40, 50]
    
    print("Array length: " + int_to_str(arr.len()))
    print("First element: " + int_to_str(arr[0]))
    print("Last element: " + int_to_str(arr[-1]))
    
    # Test array indexing
    print("Second element: " + int_to_str(arr[1]))
    print("Third element: " + int_to_str(arr[2]))
    
    # Test array modification
    arr[0] = 100
    print("Modified first element: " + int_to_str(arr[0]))
    
    # Test array slicing (if supported)
    # let slice: [int] = arr[1:3]
    # print("Slice length: " + int_to_str(slice.len()))
    
    print("All array operations completed!")
}
