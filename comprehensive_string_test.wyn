fn main() {
    # Test basic string operations
    const s: str = "hello"
    print("String length: " + int_to_str(s.len()))
    
    # Test ord and chr
    const a_code: int = ord("A")
    const a_char: str = chr(a_code)
    print("ord('A') = " + int_to_str(a_code))
    print("chr(65) = " + a_char)
    
    # Test string conversion
    const num_str: str = int_to_str(123)
    const str_num: int = str_to_int("456")
    print("int_to_str(123) = " + num_str)
    print("str_to_int('456') = " + int_to_str(str_num))
    
    # Test string concatenation
    const greeting: str = "Hello" + " " + "World"
    print("Concatenation: " + greeting)
    
    # Test string comparison
    const test1: str = "test"
    const test2: str = "test"
    if test1 == test2 {
        print("String comparison works!")
    }
    
    print("All string operations completed!")
}
