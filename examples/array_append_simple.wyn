
fn main() {
    print("Creating empty array...")
    
    let arr: [int] = []
    
    print("Array created, length: ")
    print(arr.len())
    print("")
    
    print("Appending 42...")
    arr.append(42)
    
    print("After append, length: ")
    print(arr.len())
    print("")
    
    print("Value at index 0: ")
    print(arr[0])
}
