// Array Operations Demo

print("=== Array Operations ===")

// Array literals
var numbers = [1, 2, 3, 4, 5]
print(numbers[0])
print(numbers.len())

// Array methods
numbers.append(6)
print(numbers.len())

// Slicing
var slice = numbers[1:3]
print(slice.len())

// Iteration
for n in numbers {
    print(n)
}

print("Array operations complete!")
