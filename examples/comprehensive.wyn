fn add(a: int, b: int) -> int {
    return a + b
}

fn factorial(n: int) -> int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

fn main() {
    // Strings
    print("=== Wyn Language Test ===")
    
    // Arithmetic
    print("Arithmetic:")
    print(40 + 2)
    print(10 * 5)
    print(100 / 4)
    
    // Functions
    print("Functions:")
    print(add(15, 27))
    print(factorial(5))
    
    // Variables
    print("Variables:")
    const x: int = 10
    let y: int = 20
    y = y + 5
    print(x + y)
    
    // Control flow
    print("Control flow:")
    if x < y {
        print(1)
    } else {
        print(0)
    }
    
    // Loops
    print("For loop:")
    for i in 0..5 {
        print(i)
    }
    
    // Arrays
    print("Arrays:")
    const arr: [int] = [100, 200, 300, 400]
    print(arr.len())
    print(arr[0])
    print(arr[3])
    
    print("=== All tests passed! ===")
}
