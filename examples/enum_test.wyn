# Test enum definitions and usage

enum Color {
    Red,
    Green,
    Blue
}

enum Status {
    Ok = 0,
    Error = 1,
    Pending = 2
}

fn main() {
    const red: int = Red
    const green: int = Green
    const blue: int = Blue
    
    print(red)
    print(green)
    print(blue)
    
    const ok_val: int = Ok
    const err_val: int = Error
    const pending: int = Pending
    
    print(ok_val)
    print(err_val)
    print(pending)
    
    # Test in expressions
    const sum: int = Red + Green + Blue
    print(sum)
    
    # Test in conditionals
    if red == 0 {
        print(100)
    }
    
    if err_val == 1 {
        print(200)
    }
}
