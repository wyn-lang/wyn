import io
import string

# Test io module

import io
import string

fn main() {
    # Read this source file
    const content: str = io.read_file("examples/file_test.wyn")
    
    # Check it's not empty
    const length: int = content.len()
    print(length)
    assert(length > 0)
    
    # Check first character is '#' (comment) using string.ord
    const first_char: int = string.ord(content)
    print(first_char)  # Should be 35 (#)
    assert(first_char == 35)
    
    print("io.read_file works!")
    print("")
}
