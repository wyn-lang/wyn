# Comprehensive test of all Wyn features

import math

struct Point {
    x: int
    y: int
    
    fn distance_squared(self) -> int {
        return self.x * self.x + self.y * self.y
    }
}

fn my_factorial(n: int) -> int {
    if n <= 1 {
        return 1
    }
    return n * my_factorial(n - 1)
}

fn main() {
    print("=== Wyn Full Feature Test ===")
    
    # Arithmetic
    assert(2 + 3 == 5)
    assert(10 - 4 == 6)
    assert(3 * 4 == 12)
    assert(15 / 3 == 5)
    assert(17 % 5 == 2)
    assert(2 ** 8 == 256)
    print("Arithmetic: OK")
    
    # Bitwise
    assert((5 | 3) == 7)
    assert((5 & 3) == 1)
    assert((5 ^ 3) == 6)
    assert((1 << 4) == 16)
    assert((16 >> 2) == 4)
    print("Bitwise: OK")
    
    # Comparison and Logical
    assert(5 > 3)
    assert(3 < 5)
    assert(true and true)
    assert(true or false)
    assert(not false)
    print("Comparison/Logical: OK")
    
    # Variables and compound assignment
    let x: int = 10
    x += 5
    assert(x == 15)
    x -= 3
    assert(x == 12)
    print("Variables: OK")
    
    # Control flow
    let sum: int = 0
    for i in 0..5 {
        sum += i
    }
    assert(sum == 10)
    print("Control flow: OK")
    
    # Break and continue
    let total: int = 0
    for i in 0..10 {
        if i == 5 {
            break
        }
        total += i
    }
    assert(total == 10)
    print("Break/Continue: OK")
    
    # Match
    const val: int = 2
    let result: int = 0
    match val {
        1 => result = 10
        2 => result = 20
        _ => result = 99
    }
    assert(result == 20)
    print("Match: OK")
    
    # Functions
    assert(my_factorial(5) == 120)
    print("Functions: OK")
    
    # Structs
    const p: Point = Point { x: 3, y: 4 }
    assert(p.x == 3)
    assert(p.y == 4)
    assert(p.distance_squared() == 25)
    print("Structs: OK")
    
    # Arrays
    const arr: [int] = [10, 20, 30]
    assert(len(arr) == 3)
    assert(arr[0] == 10)
    print("Arrays: OK")
    
    # Imports
    assert(abs(-5) == 5)
    assert(min(3, 7) == 3)
    assert(max(3, 7) == 7)
    assert(pow(2, 10) == 1024)
    print("Imports: OK")
    
    print("")
    print("=== All tests passed! ===")
}
