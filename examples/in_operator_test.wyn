// Test 'in' operator for array membership

fn main() {
    const arr: [int] = [1, 2, 3, 4, 5]
    
    // Test element found
    if 3 in arr {
        print("Found 3: OK")
    } else {
        print("FAIL: 3 should be in array")
        exit(1)
    }
    
    // Test element not found
    if 10 in arr {
        print("FAIL: 10 should not be in array")
        exit(1)
    } else {
        print("Not found 10: OK")
    }
    
    // Test first element
    assert(1 in arr)
    
    // Test last element
    assert(5 in arr)
    
    // Test not in
    const found: bool = 99 in arr
    assert(found == false)
    
    print("In operator: OK")
}
