// Infrastructure modules demo
// Demonstrates the new os, json, and net modules for DevOps tasks

import os
import json
import net

fn main() {
    print("=== Wyn Infrastructure Modules Demo ===")
    
    // OS module - system interaction
    print("OS Module:")
    var user: str = os.getenv("USER")
    print("Current user length:")
    print(user.len())
    
    var dir: str = os.cwd()
    print("Working directory length:")
    print(dir.len())
    
    // JSON module - data processing
    print("JSON Module:")
    var config_str: str = "config"
    var config: str = json.parse(config_str)
    print("JSON parsing works:")
    print(config.len())
    
    // Net module - network operations
    print("Net Module:")
    var response: str = net.http_get("https://api.example.com")
    print("HTTP response length:")
    print(response.len())
    
    print("=== Demo Complete ===")
}
