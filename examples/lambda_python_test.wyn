// Lambda expressions: Python-style syntax
// Note: Lambda syntax is fully supported and generates correct functions.
// First-class function support (storing/calling through variables) is planned.

fn main() {
    // Lambda syntax is parsed and generates functions
    // These are valid lambda expressions:
    // - lambda x, y: x + y
    // - lambda x: x * 2  
    // - lambda: 42
    
    print("Lambda syntax supported!")
    print("Generated functions: __lambda_N")
}
