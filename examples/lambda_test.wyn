// Test lambda/anonymous functions

fn apply(f: fn(int) -> int, x: int) -> int {
    // Call function pointer - need indirect call support
    return f(x)
}

fn main() {
    // Simple lambda
    let double: fn(int) -> int = fn(x: int) -> int { return x * 2 }
    
    // Call lambda directly
    let r1: int = double(5)
    print(r1)
    print_newline()
    assert(r1 == 10)
    
    // Lambda with multiple params
    let add: fn(int, int) -> int = fn(a: int, b: int) -> int { return a + b }
    let r2: int = add(3, 4)
    print(r2)
    print_newline()
    assert(r2 == 7)
    
    print_str("Lambda: OK")
    print_newline()
}
