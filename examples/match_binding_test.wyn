# Test match with variable binding

fn test_optional_binding() {
    const opt: ?int = some(42)
    
    match opt {
        some(x) => {
            print(x)  # Should print 42
        }
        none => {
            print(0)
        }
    }
}

fn test_none_match() {
    const opt: ?int = none
    
    match opt {
        some(x) => {
            print(x)
        }
        none => {
            print(99)  # Should print 99
        }
    }
}

fn test_result_ok() {
    const res: Result[int, str] = ok(100)
    
    match res {
        ok(v) => {
            print(v)  # Should print 100
        }
        err(e) => {
            print(0)
        }
    }
}

fn test_result_err() {
    const res: Result[int, str] = err("failed")
    
    match res {
        ok(v) => {
            print(v)
        }
        err(e) => {
            print(e)  # Should print "failed"
            print(200)    # Marker
        }
    }
}

fn main() {
    print("Test 1: some(x) binding\n")
    test_optional_binding()
    
    print("\nTest 2: none match\n")
    test_none_match()
    
    print("\nTest 3: ok(v) binding\n")
    test_result_ok()
    
    print("\nTest 4: err(e) binding\n")
    test_result_err()
    
    print("\nAll tests passed!\n")
}
