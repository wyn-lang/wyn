# Test match statement

fn main() {
    const x: int = 2
    
    match x {
        1 => print(100)
        2 => print(200)
        3 => print(300)
        _ => print(999)
    }
    
    # Test with different value
    const y: int = 5
    match y {
        1 => print(10)
        2 => print(20)
        _ => print(50)
    }
    
    # Test with block body
    const z: int = 1
    match z {
        1 => {
            print(111)
            print(222)
        }
        _ => print(0)
    }
}
