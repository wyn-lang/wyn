# Test math builtin functions
fn main() {
    # Test abs()
    assert(abs(-5) == 5)
    assert(abs(5) == 5)
    assert(abs(0) == 0)
    assert(abs(-100) == 100)
    
    # Test min()
    assert(min(3, 7) == 3)
    assert(min(10, 2) == 2)
    assert(min(-5, 5) == -5)
    assert(min(0, 0) == 0)
    
    # Test max()
    assert(max(3, 7) == 7)
    assert(max(10, 2) == 10)
    assert(max(-5, 5) == 5)
    assert(max(0, 0) == 0)
    
    # Test exit() - commented out as it would exit
    # exit(0)
    
    print_str("Math builtin tests passed!")
}
