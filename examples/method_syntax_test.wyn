fn main() {
    # Test .len() on strings
    const s: str = "hello"
    assert(s.len() == 5)
    assert("world!".len() == 6)
    
    # Test .abs() on integers
    const n: int = -42
    assert(n.abs() == 42)
    assert((-100).abs() == 100)
    
    # Test .to_str() on integers
    const num: int = 123
    print(num.to_str())
    print((-456).to_str())
    
    # Test .to_int() on strings
    const str_num: str = "789"
    assert(str_num.to_int() == 789)
    assert("-999".to_int() == -999)
    
    print("method syntax tests passed")
}
