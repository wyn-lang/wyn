# Test nested struct field access
struct Point { x: int, y: int }
struct Rect { origin: Point, size: Point }

fn main() {
    # Simple struct
    let p: Point = Point { x: 5, y: 10 }
    print(p.x)
    print(p.y)
    assert(p.x == 5)
    assert(p.y == 10)
    
    # Nested struct
    let r: Rect = Rect { origin: Point { x: 100, y: 200 }, size: Point { x: 50, y: 60 } }
    print(r.origin.x)
    print(r.origin.y)
    print(r.size.x)
    print(r.size.y)
    assert(r.origin.x == 100)
    assert(r.origin.y == 200)
    assert(r.size.x == 50)
    assert(r.size.y == 60)
    
    print_str("Nested struct tests passed!")
}
