# Test optional types

fn main() {
    # Create some value
    let x: ?int = some(42)
    print(x!)  # Unwrap and print: 42
    
    # Create none
    let y: ?int = none
    
    # Test with different value
    let z: ?int = some(100)
    print(z!)  # 100
    
    # Test ?? operator (default)
    let a: int = x ?? 0
    print(a)  # 42
    
    let b: int = y ?? 99
    print(b)  # 99 (default because y is none)
    
    print_str("Optional test passed!")
}
