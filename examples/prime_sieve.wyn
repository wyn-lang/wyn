fn is_prime(n: int) -> bool {
    if n < 2 {
        return false
    }
    if n == 2 {
        return true
    }
    if n % 2 == 0 {
        return false
    }
    let i: int = 3
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i += 2
    }
    return true
}

fn main() {
    println_str("Primes up to 100:")
    let n: int = 2
    while n <= 100 {
        if is_prime(n) {
            println(n)
        }
        n += 1
    }
}
