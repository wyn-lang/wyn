print("=== Wyn: Python Simplicity + Compiled Speed ===\n")

// No fn main() needed!
// No imports needed!

let nums = []
nums.append(1)
nums.append(2)
nums.append(3)

print("Items: " + nums.len().to_str())
print("First: " + nums.get(0).to_str())
print("Last: " + nums.get(2).to_str())

// Extension methods
fn int.double(self) -> int {
    return self * 2
}

print("\n5 doubled = " + 5.double().to_str())

print("\n✅ Wyn is now Python-competitive!")
