fn main() {
    const s: str = 42.to_str()
    print(s)
    
    const n: int = "123".to_int()
    assert(n == 123)
    
    # Test negative
    const neg: str = -99.to_str()
    print(neg)
    
    const neg_n: int = "-456".to_int()
    assert(neg_n == -456)
    
    # Test zero
    const zero: str = 0.to_str()
    print(zero)
    
    assert("0".to_int() == 0)
    
    print("conversion tests passed")
}
