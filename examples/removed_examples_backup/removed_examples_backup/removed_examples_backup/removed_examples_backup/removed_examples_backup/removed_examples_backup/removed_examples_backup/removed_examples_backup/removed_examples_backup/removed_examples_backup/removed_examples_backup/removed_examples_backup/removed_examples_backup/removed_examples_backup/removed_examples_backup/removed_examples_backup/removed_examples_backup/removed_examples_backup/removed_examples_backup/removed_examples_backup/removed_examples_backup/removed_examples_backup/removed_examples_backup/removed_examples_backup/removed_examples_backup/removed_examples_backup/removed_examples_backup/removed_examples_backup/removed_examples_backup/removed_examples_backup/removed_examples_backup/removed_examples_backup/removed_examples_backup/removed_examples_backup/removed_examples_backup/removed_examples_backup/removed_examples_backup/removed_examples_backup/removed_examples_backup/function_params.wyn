fn add(x: int, y: int) -> int {
    return x + y
}

fn multiply(a: int, b: int) -> int {
    return a * b
}

fn compute(x: int, y: int) -> int {
    var sum: int = add(x, y)
    var product: int = multiply(x, y)
    return add(sum, product)
}

fn main() {
    var result: int = compute(3, 4)
    print(result)
}
