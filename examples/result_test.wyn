# Test Result type with ok() and err()

fn divide(a: int, b: int) -> Result[int, str] {
    if b == 0 {
        return err("division by zero")
    }
    return ok(a / b)
}

fn main() {
    # Test ok case
    const r1: Result[int, str] = ok(42)
    print(r1!)  # Should print 42
    
    # Test err case  
    const r2: Result[int, str] = err("error message")
    const val: int = r2 ?? -1  # Should use default
    print(val)  # Should print -1
    
    # Test with function
    const r3: Result[int, str] = divide(10, 2)
    print(r3!)  # Should print 5
    
    const r4: Result[int, str] = divide(10, 0)
    const safe: int = r4 ?? 0
    print(safe)  # Should print 0 (error case)
    
    print(999)  # Done marker
}
