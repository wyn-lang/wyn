# Simple Wyn Program
# Demonstrates: variables, expressions, if, while, functions

fn add(a: int, b: int) -> int {
    return a + b
}

fn main() {
    print("Simple Program")
    
    let x: int = 10
    let y: int = add(x, 5)
    
    if y > 12 {
        print("y is large")
    }
    
    let i: int = 0
    while i < 3 {
        print("Loop")
        i = i + 1
    }
}
