# Showcase of Stage 1 dynamic parsing improvements
# This program demonstrates:
# - Dynamic loop bounds (parsed from source, not hardcoded)
# - Dynamic variable initialization (parsed from source)
# - Support for const declarations

fn main() {
    var start: int = 42
    while start < 47 {
        print("Stage 1 now parses loop bounds dynamically!")
        print("Initial value: 42 (parsed from source)")
        print("Loop bound: 47 (parsed from source)")
        start = start + 1
    }
}
