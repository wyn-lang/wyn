# Test string interpolation

fn main() {
    const x: int = 42
    const msg: str = "The answer is {x}"
    print(msg)
    print("\n")
    
    # Direct interpolation
    print("Value: {x}\n")
    
    # Multiple interpolations
    const a: int = 10
    const b: int = 20
    print("a={a}, b={b}\n")
}
