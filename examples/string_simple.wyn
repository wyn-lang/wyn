fn main() {
    # Test basic string operations
    print_str("Hello")
    print_str("World")
    
    # Test string length
    const len1: int = len("Hello")
    print(len1)
    
    # Test string comparison
    const eq: bool = "test" == "test"
    assert(eq)
    
    const neq: bool = "test" != "other"
    assert(neq)
    
    print_str("Tests passed!")
}
