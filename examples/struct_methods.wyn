struct Counter {
    value: int
    
    fn increment(self) {
        self.value = self.value + 1
    }
    
    fn get(self) -> int {
        return self.value
    }
}

fn main() {
    var c: Counter = Counter { value: 0 }
    c.increment()
    c.increment()
    c.increment()
    const result: int = c.get()
    print(result)
}
