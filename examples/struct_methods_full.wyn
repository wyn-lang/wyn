struct Point {
    x: int
    y: int
    
    fn move_right(self, amount: int) {
        self.x = self.x + amount
    }
    
    fn move_up(self, amount: int) {
        self.y = self.y + amount
    }
    
    fn get_x(self) -> int {
        return self.x
    }
    
    fn get_y(self) -> int {
        return self.y
    }
}

fn main() {
    let p: Point = Point { x: 10, y: 20 }
    p.move_right(5)
    p.move_up(3)
    print(p.get_x())
    print(p.get_y())
}
