# Test Task channels for communication between spawn blocks

import task

fn main() {
    print("Testing Task channels...")
    
    # Create a channel
    let ch: int = task.new()
    
    # Spawn a task that sends a value
    spawn {
        print("Sender: sending 42")
        task.send(ch, 42)
        print("Sender: sent!")
    }
    
    # Receive the value (blocks until available)
    print("Receiver: waiting...")
    let value: int = task.recv(ch)
    print("Receiver: got ")
    print(value)
    
    # Close and free the channel
    task.close(ch)
    task.free(ch)
    
    print("Task channel test complete!")
}
