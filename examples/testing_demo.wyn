// Testing framework demonstration
import testing

fn main() {
    print("=== Testing Framework Demo ===")
    
    // Test arithmetic
    const sum = 2 + 2
    testing.assert_eq(sum, 4, "2+2 equals 4")
    
    const product = 3 * 4
    testing.assert_eq(product, 12, "3*4 equals 12")
    
    // Test comparisons
    testing.assert_true(5 > 3, "5 is greater than 3")
    testing.assert_false(10 < 5, "10 is not less than 5")
    
    // Test strings
    const greeting = "hello"
    testing.assert_eq(greeting.len(), 5, "hello has 5 characters")
    
    // Test inequality
    testing.assert_ne(100, 200, "100 is not equal to 200")
    
    // Show summary
    const passed = testing.summary()
    print("Total passed: " + int_to_str(passed))
}
