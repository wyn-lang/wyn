#!/usr/bin/env wyn run
// Ultra-fast parallel test runner using Wyn's spawn

import os
import fs

fn main() {
    print("Discovering tests...")
    
    // Find all test files
    const output = os.exec_output("find tests -name '*_test.wyn' 2>/dev/null | sort")
    
    // Split into lines
    let test_files = []
    let current = ""
    let i = 0
    while i < output.len() {
        const ch = output[i]
        if ch == "\n" {
            if current.len() > 0 {
                test_files = array.append(test_files, current)
                current = ""
            }
        } else {
            current = current + ch
        }
        i = i + 1
    }
    
    const test_count = test_files.len()
    print("Found ${test_count} test files")
    print("Running all tests in parallel...\n")
    
    // Compile all tests first (in parallel)
    i = 0
    while i < test_count {
        const test_file = test_files.get(i)
        const cache_bin = ".wyn/test-cache/test_${i}"
        
        spawn {
            const cmd = "./build/wyn compile ${test_file} -o ${cache_bin} > /dev/null 2>&1"
            os.exec(cmd)
        }
        
        i = i + 1
    }
    
    task_join_all()
    print("Compilation complete!\n")
    
    // Run all tests in parallel using spawn
    i = 0
    while i < test_count {
        const cache_bin = ".wyn/test-cache/test_${i}"
        const test_file = test_files.get(i)
        
        spawn {
            const result = os.exec(cache_bin + " > /dev/null 2>&1")
            if result == 0 {
                print("  ✅ ${test_file}")
            } else {
                print("  ❌ ${test_file}")
            }
        }
        
        i = i + 1
    }
    
    task_join_all()
    
    print("\nAll tests completed!")
}
