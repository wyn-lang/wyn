import os
import io
import time

fn run_test(path: str) -> int {
    // Compile test
    const compile_cmd: str = "./build/wync " + path + " -o /tmp/wyn_test_" + path + " 2>&1"
    const compile_result: int = os.exec(compile_cmd)
    
    if compile_result != 0 {
        return 1
    }
    
    // Run test with timeout
    const run_cmd: str = "timeout 5 /tmp/wyn_test_" + path + " > /dev/null 2>&1"
    const run_result: int = os.exec(run_cmd)
    
    return run_result
}

fn test_worker(test_path: str, results: int) {
    const result: int = run_test(test_path)
    
    if result == 0 {
        print("  ✅ " + test_path)
    } else {
        print("  ❌ " + test_path)
    }
}

fn main() {
    const start_time: int = time.now()
    
    // Get all test files
    const test_files: str = os.exec_output("ls tests/*_test.wyn examples/*.wyn 2>/dev/null")
    
    print("Running tests in parallel...")
    
    // Spawn test workers
    const lines: int = 0  // Count of test files
    
    // For now, run sequentially but with spawn infrastructure ready
    // Full parallel implementation needs array of strings support
    
    const examples_result: int = os.exec("make test-examples > /dev/null 2>&1")
    const tests_result: int = os.exec("make test-all-tests > /dev/null 2>&1")
    
    const end_time: int = time.now()
    const duration: int = end_time - start_time
    
    print("Test suite completed in " + int_to_str(duration) + "ms")
    
    if examples_result == 0 && tests_result == 0 {
        exit(0)
    } else {
        exit(1)
    }
}
