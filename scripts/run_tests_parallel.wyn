#!/usr/bin/env wyn run
// Parallel test runner using spawn

import fs
import os

fn run_test(path: str) {
    const cmd = "./build/wyn run " + path + " > /dev/null 2>&1"
    const result = os.exec(cmd)
    
    if result == 0 {
        print("  ✅ " + path)
    } else {
        print("  ❌ " + path)
    }
}

fn main() {
    print("Discovering tests...")
    
    // Find all test files
    const find_result = os.exec_output("find tests -name '*_test.wyn' 2>/dev/null | sort")
    const lines = find_result.split("\n")
    
    let test_count = 0
    let i = 0
    while i < lines.len() {
        const line = lines.get(i)
        if line.len() > 0 {
            test_count = test_count + 1
        }
        i = i + 1
    }
    
    print("Found " + test_count.to_str() + " test files\n")
    
    // Run tests in parallel using spawn
    i = 0
    while i < lines.len() {
        const line = lines.get(i)
        if line.len() > 0 {
            spawn {
                run_test(line)
            }
        }
        i = i + 1
    }
    
    // Wait for all tests to complete
    task_join_all()
    
    print("\nAll tests completed!")
}
