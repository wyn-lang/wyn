import os
import time

fn run_test(path: str, index: int) {
    // Use index for unique output file
    const out: str = "/tmp/wyn_test_" + int_to_str(index)
    const cmd: str = "./build/wync " + path + " -o " + out + " 2>&1 > /dev/null && timeout 5 " + out + " > /dev/null 2>&1"
    const result: int = os.exec(cmd)
    
    if result == 0 {
        print("✅ " + path)
    } else {
        print("❌ " + path)
    }
    
    os.exec("rm -f " + out)
}

fn main() {
    const start: int = time.now()
    
    print("Wyn Parallel Test Runner")
    print("")
    
    // Get test files
    const examples: str = os.exec_output("find examples -name '*.wyn' -type f | sort")
    const tests: str = os.exec_output("find tests -name '*_test.wyn' -type f | sort")
    
    print("Testing examples...")
    
    const ex_files: [str] = str_split(examples, "\n")
    const ex_index: int = 0
    for file in ex_files {
        if file.len() > 0 {
            const idx: int = ex_index
            ex_index = ex_index + 1
            spawn {
                run_test(file, idx)
            }
        }
    }
    
    print("")
    print("Testing test files...")
    
    const test_files: [str] = str_split(tests, "\n")
    const test_index: int = 1000
    for file in test_files {
        if file.len() > 0 {
            const idx: int = test_index
            test_index = test_index + 1
            spawn {
                run_test(file, idx)
            }
        }
    }
    
    // Wait for tests to complete
    time.sleep(15000)
    
    const end: int = time.now()
    const duration: int = (end - start) / 1000
    
    print("")
    print("Duration: " + int_to_str(duration) + "s")
    print("✅ Complete!")
}
