fn main() {
    const s: str = "hello"
    
    # Test length
    assert(s.len() == 5)
    
    # Test ord
    assert(ord("A") == 65)
    assert(ord("a") == 97)
    
    # Test str_to_int
    assert(str_to_int("123") == 123)
    
    # Test chr
    const c: str = chr(65)
    assert(c == "A")
    
    print("All string tests passed!")
}
