# Wyn Package Manager
# Simple package management inspired by Go modules

import std/io
import std/fs

struct Package {
    name: str
    version: str
    description: str
}

fn main() {
    const args: [str] = args()
    
    if args.len() < 2 {
        print_help()
        return
    }
    
    const cmd: str = args[1]
    
    if cmd == "init" {
        cmd_init()
    } else if cmd == "new" {
        if args.len() < 3 {
            io.print("Usage: wyn pkg new <name>")
            io.print("")
            return
        }
        cmd_new(args[2])
    } else if cmd == "build" {
        cmd_build()
    } else if cmd == "run" {
        cmd_run()
    } else if cmd == "test" {
        cmd_test()
    } else {
        io.print("Unknown command: ")
        io.print(cmd)
        io.print("")
        print_help()
    }
}

fn print_help() {
    io.print("Wyn Package Manager")
    io.print("")
    io.print("Usage: wyn pkg <command>")
    io.print("")
    io.print("")
    io.print("Commands:")
    io.print("")
    io.print("  init       Initialize a new project in current directory")
    io.print("")
    io.print("  new <name> Create a new project")
    io.print("")
    io.print("  build      Build the project")
    io.print("")
    io.print("  run        Build and run the project")
    io.print("")
    io.print("  test       Run tests")
    io.print("")
}

fn cmd_init() {
    # Create wyn.toml
    const manifest: str = "[package]\nname = \"myproject\"\nversion = \"0.1.0\"\n\n[build]\nentry = \"src/main.wyn\"\n"
    
    if file_exists("wyn.toml") {
        io.print("Error: wyn.toml already exists")
        io.print("")
        return
    }
    
    write_file("wyn.toml", manifest)
    
    # Create directories
    mkdir("src")
    mkdir("build")
    mkdir(".wyn")
    
    # Create main.wyn
    const main_content: str = "import std/io\n\nfn main() {\n    io.print(\"Hello, Wyn!\")\n    io.print("")
\n}\n"
    write_file("src/main.wyn", main_content)
    
    io.print("Initialized Wyn project")
    io.print("")
}

fn cmd_new(name: str) {
    # Create directory
    mkdir(name)
    
    # Create manifest
    const manifest: str = str_concat("[package]\nname = \"", name)
    manifest = str_concat(manifest, "\"\nversion = \"0.1.0\"\n\n[build]\nentry = \"src/main.wyn\"\n")
    
    const manifest_path: str = str_concat(name, "/wyn.toml")
    write_file(manifest_path, manifest)
    
    # Create directories
    const src_path: str = str_concat(name, "/src")
    const build_path: str = str_concat(name, "/build")
    const wyn_path: str = str_concat(name, "/.wyn")
    
    mkdir(src_path)
    mkdir(build_path)
    mkdir(wyn_path)
    
    # Create main.wyn
    const main_content: str = "import std/io\n\nfn main() {\n    io.print(\"Hello from "
    main_content = str_concat(main_content, name)
    main_content = str_concat(main_content, "!\")\n    io.print("")\n}\n")
    
    const main_path: str = str_concat(src_path, "/main.wyn")
    write_file(main_path, main_content)
    
    io.print("Created project: ")
    io.print(name)
    io.print("")
}

fn cmd_build() {
    if not file_exists("wyn.toml") {
        io.print("Error: Not a Wyn project (no wyn.toml)")
        io.print("")
        return
    }
    
    io.print("Building project...")
    io.print("")
    
    # Simple build: compile src/main.wyn
    const result: int = system("./build/stage0 -o build/app src/main.wyn")
    
    if result == 0 {
        io.print("Build successful!")
        io.print("")
    } else {
        io.print("Build failed")
        io.print("")
    }
}

fn cmd_run() {
    cmd_build()
    io.print("Running...")
    io.print("")
    system("./build/app")
}

fn cmd_test() {
    io.print("Running tests...")
    io.print("")
    system("./tests/run_tests.sh")
}
