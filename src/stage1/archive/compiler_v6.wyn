# Stage 1 Compiler v6 - Generic self-hosting compiler
# Can compile itself!
import io
import os
import string

fn main() {
    print("=== Compiler v6 (Self-Hosting) ===")
    
    const src: str = io.read_file("src/stage1/compiler_v6.wyn")
    
    const f: str = "build/stage2_output.s"
    io.write_file(f, "    .section __TEXT,__text\n")
    io.append_file(f, "    .globl _main\n")
    
    gen_all_functions(f, src)
    
    io.append_file(f, "\n    .section __TEXT,__cstring\n")
    gen_strings(f, src)
    
    const r: int = os.system("cc -o build/stage2_output build/stage2_output.s")
    if r == 0 {
        print("✅ Stage2 compiled!")
    }
}

fn gen_all_functions(f: str, src: str) {
    let pos: int = 0
    const src_len: int = len(src)
    
    while pos < src_len {
        const c: str = string.substring(src, pos, pos + 1)
        if c == "f" {
            const pos2: int = pos + 1
            if pos2 < src_len {
                const c2: str = string.substring(src, pos2, pos2 + 1)
                if c2 == "n" {
                    const pos3: int = pos + 2
                    if pos3 < src_len {
                        const c3: str = string.substring(src, pos3, pos3 + 1)
                        if c3 == " " {
                            gen_one_func(f, src, pos)
                        }
                    }
                }
            }
        }
        pos = pos + 1
    }
}

fn gen_one_func(f: str, src: str, fn_start: int) {
    const name: str = extract_func_name(src, fn_start)
    const is_main: int = str_eq(name, "main")
    
    if is_main == 0 {
        io.append_file(f, "_")
        io.append_file(f, name)
        io.append_file(f, ":\n")
        io.append_file(f, "    sub sp, sp, #32\n")
        io.append_file(f, "    stp x29, x30, [sp]\n")
        io.append_file(f, "    mov x29, sp\n")
        
        gen_func_body(f, src, fn_start)
        
        io.append_file(f, "    ldp x29, x30, [sp]\n")
        io.append_file(f, "    add sp, sp, #32\n")
        io.append_file(f, "    ret\n\n")
    }
    
    if is_main == 1 {
        io.append_file(f, "_main:\n")
        io.append_file(f, "    sub sp, sp, #64\n")
        io.append_file(f, "    stp x29, x30, [sp]\n")
        io.append_file(f, "    mov x29, sp\n")
        
        gen_func_body(f, src, fn_start)
        
        io.append_file(f, "    mov x0, #0\n")
        io.append_file(f, "    ldp x29, x30, [sp]\n")
        io.append_file(f, "    add sp, sp, #64\n")
        io.append_file(f, "    ret\n\n")
    }
}

fn extract_func_name(src: str, fn_start: int) -> str {
    let pos: int = fn_start + 3
    const src_len: int = len(src)
    
    while pos < src_len {
        const c: str = string.substring(src, pos, pos + 1)
        if c == " " {
            pos = pos + 1
        }
        if c == "(" {
            const name: str = string.substring(src, fn_start + 3, pos)
            return name
        }
        pos = pos + 1
    }
    
    return ""
}

fn gen_func_body(f: str, src: str, fn_start: int) {
    let pos: int = fn_start
    const src_len: int = len(src)
    let in_body: int = 0
    let brace_count: int = 0
    let in_string: int = 0
    
    while pos < src_len {
        const c: str = string.substring(src, pos, pos + 1)
        
        if c == "\"" {
            if in_string == 0 {
                in_string = 1
            } else {
                in_string = 0
            }
        }
        
        if in_string == 0 {
            if c == "{" {
                in_body = 1
                brace_count = brace_count + 1
            }
            
            if in_body == 1 {
                if c == "}" {
                    brace_count = brace_count - 1
                    if brace_count == 0 {
                        return
                    }
                }
                
                if c == "p" {
                    const is_print: int = check_keyword(src, pos, "print")
                    if is_print == 1 {
                        gen_print_call(f, src, pos)
                    }
                }
                
                const is_alpha: int = is_alpha_start(c)
                if is_alpha == 1 {
                    const is_call: int = is_simple_call(src, pos)
                    if is_call == 1 {
                        const fname: str = extract_call_name(src, pos)
                        const is_builtin: int = is_builtin_name(fname)
                        const has_dot: int = has_dot_in_name(fname)
                        
                        if is_builtin == 0 {
                            if has_dot == 0 {
                                io.append_file(f, "    bl _")
                                io.append_file(f, fname)
                                io.append_file(f, "\n")
                            }
                        }
                    }
                }
            }
        }
        
        pos = pos + 1
    }
}

fn gen_print_call(f: str, src: str, pos: int) {
    io.append_file(f, "    adrp x0, .L_str0@PAGE\n")
    io.append_file(f, "    add x0, x0, .L_str0@PAGEOFF\n")
    io.append_file(f, "    bl _puts\n")
}

fn gen_io_call(f: str, src: str, pos: int) {
    const src_len: int = len(src)
    let p: int = pos + 3
    
    if p < src_len {
        const c: str = string.substring(src, p, p + 1)
        if c == "w" {
            io.append_file(f, "")
        }
        if c == "a" {
            io.append_file(f, "")
        }
        if c == "r" {
            io.append_file(f, "")
        }
    }
}

fn gen_os_call(f: str, src: str, pos: int) {
    const src_len: int = len(src)
    let p: int = pos + 3
    
    if p < src_len {
        const c: str = string.substring(src, p, p + 1)
        if c == "s" {
            io.append_file(f, "")
        }
    }
}

fn is_function_call(src: str, pos: int) -> int {
    const src_len: int = len(src)
    let p: int = pos
    
    while p < src_len {
        const c: str = string.substring(src, p, p + 1)
        
        if c == "(" {
            return 1
        }
        
        if c == " " {
            return 0
        }
        if c == "\n" {
            return 0
        }
        if c == "{" {
            return 0
        }
        if c == "}" {
            return 0
        }
        
        p = p + 1
    }
    
    return 0
}

fn is_simple_call(src: str, pos: int) -> int {
    const src_len: int = len(src)
    let p: int = pos
    let has_paren: int = 0
    
    while p < src_len {
        const c: str = string.substring(src, p, p + 1)
        
        if c == "(" {
            has_paren = 1
            p = src_len
        }
        
        if c == " " {
            p = src_len
        }
        if c == "\n" {
            p = src_len
        }
        if c == "=" {
            p = src_len
        }
        if c == ":" {
            p = src_len
        }
        if c == "," {
            p = src_len
        }
        
        p = p + 1
    }
    
    return has_paren
}

fn is_alpha_start(c: str) -> int {
    const code: int = string.ord(c)
    
    if code >= 97 {
        if code <= 122 {
            return 1
        }
    }
    
    if code >= 65 {
        if code <= 90 {
            return 1
        }
    }
    
    return 0
}

fn has_dot_in_name(name: str) -> int {
    let pos: int = 0
    const name_len: int = len(name)
    
    while pos < name_len {
        const c: str = string.substring(name, pos, pos + 1)
        const is_dot: int = str_eq(c, ".")
        if is_dot == 1 {
            return 1
        }
        pos = pos + 1
    }
    
    return 0
}

fn extract_call_name(src: str, pos: int) -> str {
    const src_len: int = len(src)
    let p: int = pos
    
    while p < src_len {
        const c: str = string.substring(src, p, p + 1)
        if c == "(" {
            const name: str = string.substring(src, pos, p)
            return name
        }
        p = p + 1
    }
    
    return ""
}

fn is_builtin_name(name: str) -> int {
    const is_print: int = str_eq(name, "print")
    if is_print == 1 {
        return 1
    }
    
    const is_io: int = str_eq(name, "io")
    if is_io == 1 {
        return 1
    }
    
    const is_os: int = str_eq(name, "os")
    if is_os == 1 {
        return 1
    }
    
    return 0
}

fn check_keyword(src: str, pos: int, keyword: str) -> int {
    const src_len: int = len(src)
    const kw_len: int = len(keyword)
    let i: int = 0
    
    while i < kw_len {
        const p: int = pos + i
        if p >= src_len {
            return 0
        }
        
        const sc: str = string.substring(src, p, p + 1)
        const kc: str = string.substring(keyword, i, i + 1)
        const eq: int = str_eq(sc, kc)
        
        if eq == 0 {
            return 0
        }
        
        i = i + 1
    }
    
    return 1
}

fn gen_strings(f: str, src: str) {
    let pos: int = 0
    const src_len: int = len(src)
    let str_num: int = 0
    
    while pos < src_len {
        const c: str = string.substring(src, pos, pos + 1)
        
        if c == "\"" {
            io.append_file(f, ".L_str")
            const num_str: str = string.int_to_str(str_num)
            io.append_file(f, num_str)
            io.append_file(f, ":\n    .asciz \"")
            
            const str_start: int = pos + 1
            let str_end: int = str_start
            
            while str_end < src_len {
                const sc: str = string.substring(src, str_end, str_end + 1)
                const is_quote: int = str_eq(sc, "\"")
                if is_quote == 1 {
                    const str_val: str = string.substring(src, str_start, str_end)
                    io.append_file(f, str_val)
                    io.append_file(f, "\"\n")
                    pos = str_end
                    str_end = src_len
                }
                str_end = str_end + 1
            }
            
            str_num = str_num + 1
        }
        
        pos = pos + 1
    }
}

fn str_eq(a: str, b: str) -> int {
    const a_len: int = len(a)
    const b_len: int = len(b)
    
    if a_len != b_len {
        return 0
    }
    
    let pos: int = 0
    while pos < a_len {
        const ca: str = string.substring(a, pos, pos + 1)
        const cb: str = string.substring(b, pos, pos + 1)
        const code_a: int = string.ord(ca)
        const code_b: int = string.ord(cb)
        
        if code_a != code_b {
            return 0
        }
        
        pos = pos + 1
    }
    
    return 1
}

fn len(s: str) -> int {
    let count: int = 0
    let pos: int = 0
    
    while pos < 10000 {
        const c: str = string.substring(s, pos, pos + 1)
        const code: int = string.ord(c)
        
        if code == 0 {
            return count
        }
        
        count = count + 1
        pos = pos + 1
    }
    
    return count
}
