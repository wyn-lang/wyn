import io

struct VarInfo {
    name: str
    offset: int
}

let vars: [VarInfo] = []
let stack_offset: int = 0

fn add_var(name: str) -> int {
    stack_offset = stack_offset + 8
    let v: VarInfo = VarInfo{name: name, offset: stack_offset}
    vars.append(v)
    return stack_offset
}

fn find_var(name: str) -> int {
    let i: int = 0
    while i < vars.len() {
        if vars[i].name == name {
            return vars[i].offset
        }
        i = i + 1
    }
    return -1
}

fn load_var(f: str, name: str, reg: str) {
    let offset: int = find_var(name)
    if offset >= 0 {
        io.write_file(f, "    ldr " + reg + ", [sp, #" + str(offset) + "]\n")
    }
}

fn store_var(f: str, name: str, reg: str) {
    let offset: int = find_var(name)
    if offset >= 0 {
        io.write_file(f, "    str " + reg + ", [sp, #" + str(offset) + "]\n")
    }
}

fn gen_binop(f: str, op: str, left: str, right: str) {
    load_var(f, left, "x0")
    load_var(f, right, "x1")
    
    if op == "+" {
        io.write_file(f, "    add x0, x0, x1\n")
    }
    if op == "-" {
        io.write_file(f, "    sub x0, x0, x1\n")
    }
    if op == "<" {
        io.write_file(f, "    cmp x0, x1\n")
    }
    if op == ">" {
        io.write_file(f, "    cmp x0, x1\n")
    }
}

fn load_int(f: str, value: int, reg: str) {
    io.write_file(f, "    mov " + reg + ", #" + str(value) + "\n")
}
