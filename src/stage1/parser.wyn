# ============================================================================
# Parser Implementation
# ============================================================================

struct Token {
    kind: int
    value: str
    line: int
    col: int
}

struct Parser {
    tokens: [Token]
    pos: int
    had_error: bool
    filename: str
}

fn parser_new(tokens: [Token], filename: str) -> Parser {
    return Parser{tokens: tokens, pos: 0, had_error: false, filename: filename}
}

fn parser_current(p: Parser) -> Token {
    if p.pos >= p.tokens.len() {
        return Token{kind: 0, value: "", line: 0, col: 0}
    }
    return p.tokens[p.pos]
}

fn parser_advance(p: mut Parser) -> Token {
    let tok: Token = parser_current(p)
    p.pos = p.pos + 1
    return tok
}

fn parser_check(p: Parser, kind: int) -> bool {
    return parser_current(p).kind == kind
}

fn parser_match(p: mut Parser, kind: int) -> bool {
    if parser_check(p, kind) {
        parser_advance(p)
        return true
    }
    return false
}

fn parser_expect(p: mut Parser, kind: int, msg: str) -> Token {
    if parser_check(p, kind) {
        return parser_advance(p)
    }
    parser_error(p, msg)
    return parser_current(p)
}

fn parser_error(p: mut Parser, msg: str) {
    p.had_error = true
    let tok: Token = parser_current(p)
    io.print_str(p.filename)
    io.print_str(":")
    io.print_int(tok.line)
    io.print_str(":")
    io.print_int(tok.col)
    io.print_str(": error: ")
    io.print_str(msg)
    io.print_newline()
}

# ============================================================================
# Operator Precedence
# ============================================================================
# 11: **
# 10: * / %
#  9: + -
#  8: << >>
#  7: &
#  6: ^
#  5: |
#  4: < > <= >=
#  3: == !=
#  2: and &&
#  1: or ||
#  0: ??

fn get_precedence(op: int) -> int {
    if op == STARSTAR { return 11 }
    if op == STAR { return 10 }
    if op == SLASH { return 10 }
    if op == PERCENT { return 10 }
    if op == PLUS { return 9 }
    if op == MINUS { return 9 }
    if op == LTLT { return 8 }
    if op == GTGT { return 8 }
    if op == AMP { return 7 }
    if op == CARET { return 6 }
    if op == PIPE { return 5 }
    if op == LT { return 4 }
    if op == GT { return 4 }
    if op == LTEQ { return 4 }
    if op == GTEQ { return 4 }
    if op == EQEQ { return 3 }
    if op == NOTEQ { return 3 }
    if op == AND { return 2 }
    if op == AMPAMP { return 2 }
    if op == OR { return 1 }
    if op == PIPEPIPE { return 1 }
    if op == QUESTIONQUESTION { return 0 }
    return -1
}

# ============================================================================
# Parser Algorithm Documentation
# ============================================================================
#
# The parser uses recursive descent with precedence climbing for expressions.
#
# Main parsing functions:
#
# parse_module() -> Module
#   Parses top-level declarations: imports, functions, structs, enums
#
# parse_function(is_pub) -> FnDef
#   fn name[T](params) -> Type { body }
#
# parse_struct(is_pub) -> StructDef
#   struct Name[T] { fields }
#
# parse_enum(is_pub) -> EnumDef
#   enum Name[T] { variants }
#
# parse_stmt() -> Stmt
#   let/mut, if, while, for, match, return, break, continue, defer, block, expr
#
# parse_expr() -> Expr
#   Entry point: parse_binary(0)
#
# parse_binary(min_prec) -> Expr
#   Precedence climbing for binary operators
#
# parse_unary() -> Expr
#   Unary operators: -, not, !, &, *
#
# parse_postfix() -> Expr
#   Postfix operators: (), [], ., !, ?
#
# parse_primary() -> Expr
#   Literals, identifiers, parentheses, arrays, maps, if-expr, match-expr
#
# parse_type() -> Type
#   Types: int, str, [T], {K:V}, ?T, Result[T,E], fn(T)->U, *T, Name[T]
#
# ============================================================================

fn main() {
    io.print_str("Stage 1 Parser - AST Documentation")
    io.print_newline()
    io.print_str("See bootstrap/stage0.c for reference implementation")
    io.print_newline()
}
