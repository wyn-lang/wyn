# Stage 1 Parser - Recursive Descent Parser for Wyn
# 
# This file documents the AST structure and provides a minimal parser implementation.
# The full parser will be implemented once Stage 1 compiler is bootstrapped.
#
# Reference: bootstrap/stage0.c lines 595-1800

# ============================================================================
# AST Node Type Enums
# ============================================================================

# Type Kinds
# INT=0 FLOAT=1 STR=2 BOOL=3 BYTE=4 ANY=5 VOID=6
# ARRAY=7 MAP=8 TUPLE=9 OPTIONAL=10 RESULT=11
# FUNCTION=12 NAMED=13 GENERIC=14 POINTER=15

# Expression Kinds  
# INT=0 FLOAT=1 STRING=2 BOOL=3 IDENT=4
# BINARY=5 UNARY=6 CALL=7 INDEX=8 FIELD=9
# ARRAY=10 MAP=11 TUPLE=12 LAMBDA=13 STRUCT=14
# IF=15 MATCH=16 SOME=17 NONE=18 OK=19 ERR=20
# UNWRAP=21 TRY=22 DEFAULT=23 SLICE=24 ADDR=25 DEREF=26

# Statement Kinds
# LET=0 ASSIGN=1 EXPR=2 RETURN=3 IF=4 WHILE=5
# FOR=6 MATCH=7 BLOCK=8 BREAK=9 CONTINUE=10 DEFER=11 SPAWN=12

