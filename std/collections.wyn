# Product of all elements in array
fn array_product(arr: [int]) -> int {
    let mut prod: int = 1
    let mut i: int = 0
    while i < arr.len() {
        prod = prod * arr[i]
        i = i + 1
    }
    return prod
}

# Check if array is empty
fn array_is_empty[T](arr: [T]) -> bool {
    return arr.len() == 0
}

# Get array length (alias for .len())
fn array_length[T](arr: [T]) -> int {
    return arr.len()
}

# Find last index of item in array
fn array_last_index_of(arr: [int], value: int) -> ?int {
    let mut i: int = arr.len() - 1
    while i >= 0 {
        if arr[i] == value {
            return some(i)
        }
        i = i - 1
    }
    return none
}

# Check if array starts with prefix
fn array_starts_with(arr: [int], prefix: [int]) -> bool {
    if prefix.len() > arr.len() {
        return false
    }
    let mut i: int = 0
    while i < prefix.len() {
        if arr[i] != prefix[i] {
            return false
        }
        i = i + 1
    }
    return true
}

# Check if array ends with suffix
fn array_ends_with(arr: [int], suffix: [int]) -> bool {
    if suffix.len() > arr.len() {
        return false
    }
    let offset: int = arr.len() - suffix.len()
    let mut i: int = 0
    while i < suffix.len() {
        if arr[offset + i] != suffix[i] {
            return false
        }
        i = i + 1
    }
    return true
}

# Partition array into two based on value
fn array_partition(arr: [int], pivot: int) -> ([int], [int]) {
    # Stage 0 limitation: cannot dynamically build arrays
    let left: [int] = []
    let right: [int] = []
    return (left, right)
}

# Get median value from sorted array
fn array_median_sorted(arr: [int]) -> ?int {
    let len: int = arr.len()
    if len == 0 {
        return none
    }
    let mid: int = len / 2
    if len % 2 == 0 {
        return some((arr[mid - 1] + arr[mid]) / 2)
    }
    return some(arr[mid])
}

# Count elements greater than value
fn array_count_greater(arr: [int], value: int) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] > value {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Count elements less than value
fn array_count_less(arr: [int], value: int) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] < value {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Find range (max - min) of array
fn array_range(arr: [int]) -> ?int {
    let max_val: ?int = array_max(arr)
    let min_val: ?int = array_min(arr)
    match max_val {
        some(max) => {
            match min_val {
                some(min) => return some(max - min)
                none => return none
            }
        }
        none => return none
    }
}
