# Find index of maximum value
fn array_index_of_max(arr: [int]) -> ?int {
    if arr.len() == 0 { return none }
    let mut max_idx: int = 0
    let mut i: int = 1
    while i < arr.len() {
        if arr[i] > arr[max_idx] {
            max_idx = i
        }
        i = i + 1
    }
    return some(max_idx)
}

