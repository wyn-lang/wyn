# Stage 1: Will support dynamic array building
fn array_chunk_size(arr: [int], n: int) -> [[int]] {
    # Stage 0 limitation: cannot dynamically build arrays
    # Stage 1 will support: split array into chunks
    return []
}

# Remove duplicates from sorted array
# Stage 1: Will support dynamic array building
fn array_dedup_sorted(arr: [int]) -> [int] {
    # Stage 0 limitation: cannot dynamically build arrays
    # Stage 1 will support: skip consecutive duplicates
    return []
}

# Rotate array left by n positions
# Stage 1: Will support array concatenation
fn array_rotate_left(arr: [int], n: int) -> [int] {
    let len: int = arr.len()
    if len == 0 or n == 0 {
        return arr
    }
    let shift: int = n % len
    # Stage 0 limitation: would need array concatenation
    # Stage 1 will support: arr[shift:] + arr[:shift]
    return arr
}

# Rotate array right by n positions
# Stage 1: Will support array concatenation
fn array_rotate_right(arr: [int], n: int) -> [int] {
    let len: int = arr.len()
    if len == 0 or n == 0 {
        return arr
    }
    let shift: int = n % len
    return array_rotate_left(arr, len - shift)
}

# Swap two elements in array (returns new array)
# Stage 1: Will support array element assignment
fn array_swap(arr: [int], i: int, j: int) -> [int] {
    # Stage 0 limitation: arrays are immutable, cannot modify
    # Stage 1 will support: result[i] = arr[j], result[j] = arr[i]
    return arr
}

# Fill array with value
# Stage 1: Will support dynamic array building
fn array_fill(size: int, value: int) -> [int] {
    # Stage 0 limitation: cannot dynamically build arrays
    # Stage 1 will support: create array of given size with value
    return []
}

# Calculate product of all elements in array
fn array_product(arr: [int]) -> int {
    let mut prod: int = 1
    let mut i: int = 0
    while i < arr.len() {
        prod = prod * arr[i]
        i = i + 1
    }
    return prod
}

# Check if array is empty (length is 0)
fn array_is_empty[T](arr: [T]) -> bool {
    return arr.len() == 0
}

# Get array length (alias for .len())
fn array_length[T](arr: [T]) -> int {
    return arr.len()
}

# Find last index of item in array, returns none if not found
fn array_last_index_of(arr: [int], value: int) -> ?int {
    let mut i: int = arr.len() - 1
    while i >= 0 {
        if arr[i] == value {
            return some(i)
        }
        i = i - 1
    }
    return none
}

# Check if array starts with prefix array
fn array_starts_with(arr: [int], prefix: [int]) -> bool {
    if prefix.len() > arr.len() {
        return false
    }
    let mut i: int = 0
    while i < prefix.len() {
        if arr[i] != prefix[i] {
            return false
        }
        i = i + 1
    }
    return true
}

# Check if array ends with suffix array
fn array_ends_with(arr: [int], suffix: [int]) -> bool {
    if suffix.len() > arr.len() {
        return false
    }
    let offset: int = arr.len() - suffix.len()
    let mut i: int = 0
    while i < suffix.len() {
        if arr[offset + i] != suffix[i] {
            return false
        }
        i = i + 1
    }
    return true
}

# Partition array into two based on value
# Stage 1: Will support dynamic array building
fn array_partition(arr: [int], pivot: int) -> ([int], [int]) {
    # Stage 0 limitation: cannot dynamically build arrays
    # Stage 1 will support: split into elements < pivot and >= pivot
    let left: [int] = []
    let right: [int] = []
    return (left, right)
}

# Get median value from sorted array, returns none if empty
fn array_median_sorted(arr: [int]) -> ?int {
    let len: int = arr.len()
    if len == 0 {
        return none
    }
    let mid: int = len / 2
    if len % 2 == 0 {
        return some((arr[mid - 1] + arr[mid]) / 2)
    }
    return some(arr[mid])
}

# Count elements greater than value
fn array_count_greater(arr: [int], value: int) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] > value {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Count elements less than value
fn array_count_less(arr: [int], value: int) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] < value {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Find range (max - min) of array, returns none if empty
fn array_range(arr: [int]) -> ?int {
    let max_val: ?int = array_max(arr)
    let min_val: ?int = array_min(arr)
    match max_val {
        some(max) => {
            match min_val {
                some(min) => return some(max - min)
                none => return none
            }
        }
        none => return none
    }
}

# Binary search in sorted array, returns index if found or none
fn array_binary_search(arr: [int], target: int) -> ?int {
    let mut left: int = 0
    let mut right: int = arr.len() - 1
    
    while left <= right {
        let mid: int = left + (right - left) / 2
        if arr[mid] == target {
            return some(mid)
        }
        if arr[mid] < target {
            left = mid + 1
        } else {
            right = mid - 1
        }
    }
    return none
}

# Check if two arrays are equal (same length and elements)
fn array_equals[T](a: [T], b: [T]) -> bool {
    if a.len() != b.len() {
        return false
    }
    let mut i: int = 0
    while i < a.len() {
        if a[i] != b[i] {
            return false
        }
        i = i + 1
    }
    return true
}

# Calculate sum of all floats in array
fn array_sum_float(arr: [float]) -> float {
    let mut sum: float = 0.0
    let mut i: int = 0
    while i < arr.len() {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}

# Calculate average of float array, returns none if empty
fn array_avg_float(arr: [float]) -> ?float {
    if arr.len() == 0 {
        return none
    }
    let sum: float = array_sum_float(arr)
    return some(sum / arr.len().to_float())
}

# Find maximum float value in array, returns none if empty
fn array_max_float(arr: [float]) -> ?float {
    if arr.len() == 0 {
        return none
    }
    let mut max_val: float = arr[0]
    let mut i: int = 1
    while i < arr.len() {
        if arr[i] > max_val {
            max_val = arr[i]
        }
        i = i + 1
    }
    return some(max_val)
}

# Find minimum float value in array, returns none if empty
fn array_min_float(arr: [float]) -> ?float {
    if arr.len() == 0 {
        return none
    }
    let mut min_val: float = arr[0]
    let mut i: int = 1
    while i < arr.len() {
        if arr[i] < min_val {
            min_val = arr[i]
        }
        i = i + 1
    }
    return some(min_val)
}

# Calculate product of all floats in array
fn array_product_float(arr: [float]) -> float {
    let mut prod: float = 1.0
    let mut i: int = 0
    while i < arr.len() {
        prod = prod * arr[i]
        i = i + 1
    }
    return prod
}


# Find second largest element in array, returns none if not found
fn array_second_max(arr: [int]) -> ?int {
    if arr.len() < 2 {
        return none
    }
    let mut max1: int = arr[0]
    let mut max2: int = arr[0]
    let mut i: int = 1
    
    while i < arr.len() {
        if arr[i] > max1 {
            max2 = max1
            max1 = arr[i]
        } else {
            if arr[i] > max2 and arr[i] != max1 {
                max2 = arr[i]
            }
        }
        i = i + 1
    }
    
    if max1 == max2 {
        return none
    }
    return some(max2)
}

# Find second smallest element in array, returns none if not found
fn array_second_min(arr: [int]) -> ?int {
    if arr.len() < 2 {
        return none
    }
    let mut min1: int = arr[0]
    let mut min2: int = arr[0]
    let mut i: int = 1
    
    while i < arr.len() {
        if arr[i] < min1 {
            min2 = min1
            min1 = arr[i]
        } else {
            if arr[i] < min2 and arr[i] != min1 {
                min2 = arr[i]
            }
        }
        i = i + 1
    }
    
    if min1 == min2 {
        return none
    }
    return some(min2)
}

# Check if all elements in array are positive
fn array_all_positive(arr: [int]) -> bool {
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] <= 0 {
            return false
        }
        i = i + 1
    }
    return true
}

