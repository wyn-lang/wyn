# Check if array is strictly increasing
fn array_is_increasing(arr: [int]) -> bool {
    let mut i: int = 0
    while i < arr.len() - 1 {
        if arr[i] >= arr[i + 1] {
            return false
        }
        i = i + 1
    }
    return true
}

# Check if array is strictly decreasing
fn array_is_decreasing(arr: [int]) -> bool {
    let mut i: int = 0
    while i < arr.len() - 1 {
        if arr[i] <= arr[i + 1] {
            return false
        }
        i = i + 1
    }
    return true
}

# Count elements in range [min, max]
fn array_count_in_range(arr: [int], min_val: int, max_val: int) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] >= min_val and arr[i] <= max_val {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Find nth largest element (0-indexed)
fn array_nth_largest(arr: [int], n: int) -> ?int {
    if n < 0 or n >= arr.len() { return none }
    return some(arr[arr.len() - 1 - n])
}

# Find nth smallest element (0-indexed)
fn array_nth_smallest(arr: [int], n: int) -> ?int {
    if n < 0 or n >= arr.len() { return none }
    return some(arr[n])
}

# Calculate absolute sum (sum of absolute values)
fn array_abs_sum(arr: [int]) -> int {
    let mut sum: int = 0
    let mut i: int = 0
    while i < arr.len() {
        sum = sum + abs(arr[i])
        i = i + 1
    }
    return sum
}

# Count distinct elements in array
fn array_count_distinct(arr: [int]) -> int {
    if arr.len() == 0 { return 0 }
    let mut count: int = 0
    let mut i: int = 0
    while i < arr.len() {
        let mut is_unique: bool = true
        let mut j: int = 0
        while j < i {
            if arr[j] == arr[i] {
                is_unique = false
            }
            j = j + 1
        }
        if is_unique {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Check if array has duplicates
fn array_has_duplicates(arr: [int]) -> bool {
    let mut i: int = 0
    while i < arr.len() {
        let mut j: int = i + 1
        while j < arr.len() {
            if arr[i] == arr[j] {
                return true
            }
            j = j + 1
        }
        i = i + 1
    }
    return false
}

# Find kth smallest element using selection (0-indexed, requires sorted array)
fn array_kth_smallest(arr: [int], k: int) -> ?int {
    if k < 0 or k >= arr.len() { return none }
    return some(arr[k])
}

# Check if array is a permutation of another
fn array_is_permutation(a: [int], b: [int]) -> bool {
    if a.len() != b.len() { return false }
    let mut i: int = 0
    while i < a.len() {
        if array_count(b, a[i]) != array_count(a, a[i]) {
            return false
        }
        i = i + 1
    }
    return true
}

# Find longest increasing subsequence length
fn array_lis_length(arr: [int]) -> int {
    if arr.len() == 0 { return 0 }
    let mut max_len: int = 1
    let mut i: int = 0
    while i < arr.len() {
        let mut len: int = 1
        let mut j: int = i + 1
        let mut prev: int = arr[i]
        while j < arr.len() {
            if arr[j] > prev {
                len = len + 1
                prev = arr[j]
            }
            j = j + 1
        }
        if len > max_len {
            max_len = len
        }
        i = i + 1
    }
    return max_len
}

# Calculate dot product of two integer arrays
fn array_dot_product(a: [int], b: [int]) -> ?int {
    if a.len() != b.len() { return none }
    let mut sum: int = 0
    let mut i: int = 0
    while i < a.len() {
        sum = sum + (a[i] * b[i])
        i = i + 1
    }
    return some(sum)
}

# Check if array is arithmetic progression
fn array_is_arithmetic(arr: [int]) -> bool {
    if arr.len() < 2 { return true }
    let diff: int = arr[1] - arr[0]
    let mut i: int = 1
    while i < arr.len() - 1 {
        if arr[i + 1] - arr[i] != diff {
            return false
        }
        i = i + 1
    }
    return true
}

# Check if array is geometric progression
fn array_is_geometric(arr: [int]) -> bool {
    if arr.len() < 2 { return true }
    if arr[0] == 0 { return false }
    let ratio: int = arr[1] / arr[0]
    let mut i: int = 1
    while i < arr.len() - 1 {
        if arr[i] == 0 or arr[i + 1] / arr[i] != ratio {
            return false
        }
        i = i + 1
    }
    return true
}

fn abs(n: int) -> int {
    return if n < 0 then 0 - n else n
}

# Find index of first occurrence of element, returns -1 if not found
fn array_index_of(arr: [int], target: int) -> int {
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] == target {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

# Find index of last occurrence of element, returns -1 if not found
fn array_last_index_of(arr: [int], target: int) -> int {
    let mut i: int = arr.len() - 1
    while i >= 0 {
        if arr[i] == target {
            return i
        }
        i = i - 1
    }
    return 0 - 1
}

# Count occurrences of element in array
fn array_count(arr: [int], target: int) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] == target {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Check if array contains element
fn array_contains(arr: [int], target: int) -> bool {
    return array_index_of(arr, target) != 0 - 1
}

# Get first element of array, returns none if empty
fn array_first(arr: [int]) -> ?int {
    if arr.len() == 0 {
        return none
    }
    return some(arr[0])
}

# Get last element of array, returns none if empty
fn array_last(arr: [int]) -> ?int {
    if arr.len() == 0 {
        return none
    }
    return some(arr[arr.len() - 1])
}

# Take first n elements from array
fn array_take(arr: [int], n: int) -> [int] {
    if n <= 0 {
        return []
    }
    if n >= arr.len() {
        return arr
    }
    return arr[:n]
}

# Skip first n elements from array
fn array_skip(arr: [int], n: int) -> [int] {
    if n <= 0 {
        return arr
    }
    if n >= arr.len() {
        return []
    }
    return arr[n:]
}

# Chunk array into groups of size n
fn array_chunk_count(arr: [int], chunk_size: int) -> int {
    if chunk_size <= 0 {
        return 0
    }
    let len: int = arr.len()
    return (len + chunk_size - 1) / chunk_size
}

# Get specific chunk from array
fn array_get_chunk(arr: [int], chunk_index: int, chunk_size: int) -> [int] {
    let start: int = chunk_index * chunk_size
    if start >= arr.len() {
        return []
    }
    let end: int = min(start + chunk_size, arr.len())
    return arr[start:end]
}

# Rotate array left by n positions
fn array_rotate_left(arr: [int], n: int) -> [int] {
    let len: int = arr.len()
    if len == 0 or n == 0 {
        return arr
    }
    let shift: int = n % len
    if shift == 0 {
        return arr
    }
    return arr[shift:] + arr[:shift]
}

# Rotate array right by n positions
fn array_rotate_right(arr: [int], n: int) -> [int] {
    let len: int = arr.len()
    if len == 0 or n == 0 {
        return arr
    }
    let shift: int = n % len
    if shift == 0 {
        return arr
    }
    return arr[len - shift:] + arr[:len - shift]
}

# Interleave two arrays
fn array_interleave(a: [int], b: [int]) -> [int] {
    let len_a: int = a.len()
    let len_b: int = b.len()
    let min_len: int = min(len_a, len_b)
    
    if min_len == 0 {
        if len_a > 0 { return a }
        return b
    }
    
    # Build result by alternating elements
    let mut result: [int] = []
    let mut i: int = 0
    while i < min_len {
        result = result + [a[i], b[i]]
        i = i + 1
    }
    
    # Append remaining elements
    if len_a > min_len {
        result = result + a[min_len:]
    }
    if len_b > min_len {
        result = result + b[min_len:]
    }
    
    return result
}

fn min(a: int, b: int) -> int {
    return if a < b then a else b
}

# Binary search in sorted array, returns index or -1
fn binary_search(arr: [int], target: int) -> int {
    let mut left: int = 0
    let mut right: int = arr.len() - 1
    while left <= right {
        let mid: int = left + (right - left) / 2
        if arr[mid] == target {
            return mid
        }
        if arr[mid] < target {
            left = mid + 1
        } else {
            right = mid - 1
        }
    }
    return 0 - 1
}

# Bubble sort (ascending)
fn bubble_sort(arr: [int]) -> [int] {
    let len: int = arr.len()
    if len <= 1 {
        return arr
    }
    let mut result: [int] = arr
    let mut i: int = 0
    while i < len - 1 {
        let mut j: int = 0
        while j < len - i - 1 {
            if result[j] > result[j + 1] {
                let temp: int = result[j]
                result[j] = result[j + 1]
                result[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    return result
}

# Check if array is sorted (ascending)
fn is_sorted(arr: [int]) -> bool {
    let mut i: int = 1
    while i < arr.len() {
        if arr[i - 1] > arr[i] {
            return false
        }
        i = i + 1
    }
    return true
}

# Find minimum value in array
fn array_min(arr: [int]) -> ?int {
    if arr.len() == 0 {
        return none
    }
    let mut min_val: int = arr[0]
    let mut i: int = 1
    while i < arr.len() {
        if arr[i] < min_val {
            min_val = arr[i]
        }
        i = i + 1
    }
    return some(min_val)
}

# Find maximum value in array
fn array_max(arr: [int]) -> ?int {
    if arr.len() == 0 {
        return none
    }
    let mut max_val: int = arr[0]
    let mut i: int = 1
    while i < arr.len() {
        if arr[i] > max_val {
            max_val = arr[i]
        }
        i = i + 1
    }
    return some(max_val)
}

# Sum all elements in array
fn array_sum(arr: [int]) -> int {
    let mut sum: int = 0
    let mut i: int = 0
    while i < arr.len() {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}

# Product of all elements in array
fn array_product(arr: [int]) -> int {
    if arr.len() == 0 {
        return 0
    }
    let mut prod: int = 1
    let mut i: int = 0
    while i < arr.len() {
        prod = prod * arr[i]
        i = i + 1
    }
    return prod
}

# Partition array into two based on predicate
fn partition(arr: [int], threshold: int) -> ([int], [int]) {
    let mut left: [int] = []
    let mut right: [int] = []
    let mut i: int = 0
    while i < arr.len() {
        if arr[i] < threshold {
            left = left + [arr[i]]
        } else {
            right = right + [arr[i]]
        }
        i = i + 1
    }
    return (left, right)
}

# Remove duplicates from sorted array
fn unique_sorted(arr: [int]) -> [int] {
    if arr.len() <= 1 {
        return arr
    }
    let mut result: [int] = [arr[0]]
    let mut i: int = 1
    while i < arr.len() {
        if arr[i] != arr[i - 1] {
            result = result + [arr[i]]
        }
        i = i + 1
    }
    return result
}

# Merge two sorted arrays
fn merge_sorted(a: [int], b: [int]) -> [int] {
    let mut result: [int] = []
    let mut i: int = 0
    let mut j: int = 0
    while i < a.len() and j < b.len() {
        if a[i] <= b[j] {
            result = result + [a[i]]
            i = i + 1
        } else {
            result = result + [b[j]]
            j = j + 1
        }
    }
    while i < a.len() {
        result = result + [a[i]]
        i = i + 1
    }
    while j < b.len() {
        result = result + [b[j]]
        j = j + 1
    }
    return result
}

