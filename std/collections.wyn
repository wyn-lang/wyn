# Take first n elements
fn array_take[T](arr: [T], n: int) -> [T] {
    if n <= 0 {
        return []
    }
    let len: int = arr.len()
    if n >= len {
        return arr
    }
    return arr[:n]
}

# Skip first n elements
fn array_skip[T](arr: [T], n: int) -> [T] {
    if n <= 0 {
        return arr
    }
    let len: int = arr.len()
    if n >= len {
        return []
    }
    return arr[n:]
}

