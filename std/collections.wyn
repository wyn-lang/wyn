fn array_dedup_sorted(arr: [int]) -> [int] {
    # Stage 0 limitation: cannot dynamically build arrays
    return []
}

# Rotate array left by n positions
fn array_rotate_left(arr: [int], n: int) -> [int] {
    let len: int = arr.len()
    if len == 0 or n == 0 {
        return arr
    }
    let shift: int = n % len
    # Stage 0 limitation: would need array concatenation
    return arr
}

# Rotate array right by n positions
fn array_rotate_right(arr: [int], n: int) -> [int] {
    let len: int = arr.len()
    if len == 0 or n == 0 {
        return arr
    }
    let shift: int = n % len
    return array_rotate_left(arr, len - shift)
}

# Swap two elements in array (returns new array)
fn array_swap(arr: [int], i: int, j: int) -> [int] {
    # Stage 0 limitation: arrays are immutable, cannot modify
    return arr
}

# Fill array with value
fn array_fill(size: int, value: int) -> [int] {
    # Stage 0 limitation: cannot dynamically build arrays
    return []
