# std/config.wyn
# Configuration file parsing (YAML and TOML)
# All functions are mapped to runtime implementations via compiler

# YAML:
#   config.yaml_parse(yaml_str: str) -> str

# TOML:
#   config.toml_parse(toml_str: str) -> str

# Note: These functions parse config files and return a data structure
# Use with json.get_string(), json.get_int() to extract values
