# Simple hash functions (pure Wyn implementations)

# DJB2 hash algorithm - fast, simple, good distribution
# Returns a 32-bit hash value as an integer
# Example: djb2("hello") -> 210676686821
fn djb2(data: str) -> int {
    let mut hash: int = 5381
    let mut i: int = 0
    while i < data.len() {
        let c: int = ord(data[i:i+1][0])
        hash = ((hash << 5) + hash) + c  # hash * 33 + c
        i = i + 1
    }
    return hash
}

# FNV-1a hash algorithm - good distribution, fast
# Returns a 32-bit hash value as an integer
# Example: fnv1a("hello") -> 1335831723
fn fnv1a(data: str) -> int {
    let mut hash: int = 2166136261  # FNV offset basis (32-bit)
    let mut i: int = 0
    while i < data.len() {
        let c: int = ord(data[i:i+1][0])
        hash = hash ^ c
        hash = hash * 16777619  # FNV prime
        i = i + 1
    }
    return hash
}

# Simple polynomial rolling hash
# Returns a hash value modulo a large prime
# Example: simple_hash("hello") -> 99162322
fn simple_hash(data: str) -> int {
    let mut hash: int = 0
    let mut i: int = 0
    while i < data.len() {
        hash = (hash * 31 + ord(data[i:i+1][0])) % 2147483647
        i = i + 1
    }
    return hash
}

# SDBM hash algorithm - used in many hash table implementations
# Returns a 32-bit hash value as an integer
fn sdbm(data: str) -> int {
    let mut hash: int = 0
    let mut i: int = 0
    while i < data.len() {
        let c: int = ord(data[i:i+1][0])
        hash = c + (hash << 6) + (hash << 16) - hash
        i = i + 1
    }
    return hash
}

# Lose-lose hash - simple but poor distribution (for educational purposes)
# Returns sum of all character codes
fn lose_lose(data: str) -> int {
    let mut hash: int = 0
    let mut i: int = 0
    while i < data.len() {
        hash = hash + ord(data[i:i+1][0])
        i = i + 1
    }
    return hash
}

# Compute a checksum by XORing all bytes
# Returns a value in range 0-255
fn xor_checksum(data: str) -> int {
    let mut checksum: int = 0
    let mut i: int = 0
    while i < data.len() {
        checksum = checksum ^ ord(data[i:i+1][0])
        i = i + 1
    }
    return checksum & 255
}

# Compute a simple additive checksum modulo 256
# Returns a value in range 0-255
fn sum_checksum(data: str) -> int {
    let mut checksum: int = 0
    let mut i: int = 0
    while i < data.len() {
        checksum = checksum + ord(data[i:i+1][0])
        i = i + 1
    }
    return checksum % 256
}

# Convert a hash integer to a hexadecimal string
# Example: hash_to_hex(255) -> "000000ff"
fn hash_to_hex(hash: int) -> str {
    let hex_chars: str = "0123456789abcdef"
    let mut result: str = ""
    let mut n: int = hash
    let mut i: int = 0
    
    while i < 8 {
        let digit: int = n & 15
        result = hex_chars[digit:digit+1] + result
        n = n >> 4
        i = i + 1
    }
    
    return result
}

# Simple XOR cipher for basic obfuscation (NOT secure encryption)
# Applies XOR with a repeating key
# Example: xor_cipher("hello", "key") -> obfuscated string
fn xor_cipher(data: str, key: str) -> str {
    if key.len() == 0 {
        return data
    }
    
    let mut result: str = ""
    let mut i: int = 0
    while i < data.len() {
        let data_byte: int = ord(data[i:i+1][0])
        let key_byte: int = ord(key[i % key.len():i % key.len()+1][0])
        let xor_byte: int = data_byte ^ key_byte
        result = result + chr(xor_byte)
        i = i + 1
    }
    return result
}

# Caesar cipher - shift each character by n positions
# Only affects ASCII letters, preserves case
# Example: caesar_cipher("Hello", 3) -> "Khoor"
fn caesar_cipher(data: str, shift: int) -> str {
    let mut result: str = ""
    let mut i: int = 0
    while i < data.len() {
        let c: int = ord(data[i:i+1][0])
        if c >= 65 and c <= 90 {  # 'A'-'Z'
            let shifted: int = ((c - 65 + shift) % 26 + 26) % 26 + 65
            result = result + chr(shifted)
        } else if c >= 97 and c <= 122 {  # 'a'-'z'
            let shifted: int = ((c - 97 + shift) % 26 + 26) % 26 + 97
            result = result + chr(shifted)
        } else {
            result = result + data[i:i+1]
        }
        i = i + 1
    }
    return result
}

# ROT13 cipher - special case of Caesar cipher with shift 13
# Self-inverse: rot13(rot13(x)) == x
fn rot13(data: str) -> str {
    return caesar_cipher(data, 13)
}

# Base64 encoding/decoding

# Encode data to base64 string
# Example: base64_encode("hello") -> "aGVsbG8="
fn base64_encode(data: str) -> str {
    let chars: str = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    let mut result: str = ""
    let mut i: int = 0
    
    while i < data.len() {
        let b1: int = ord(data[i:i+1][0])
        let b2: int = if i + 1 < data.len() then ord(data[i+1:i+2][0]) else 0
        let b3: int = if i + 2 < data.len() then ord(data[i+2:i+3][0]) else 0
        
        let n: int = (b1 << 16) | (b2 << 8) | b3
        
        result = result + chars[(n >> 18) & 63:(n >> 18) & 63 + 1]
        result = result + chars[(n >> 12) & 63:(n >> 12) & 63 + 1]
        result = result + (if i + 1 < data.len() then chars[(n >> 6) & 63:(n >> 6) & 63 + 1] else "=")
        result = result + (if i + 2 < data.len() then chars[n & 63:n & 63 + 1] else "=")
        
        i = i + 3
    }
    
    return result
}

# Decode base64 string to data
# Returns ok(decoded) on success, err(message) on invalid input
fn base64_decode(encoded: str) -> Result[str, str] {
    let chars: str = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    let mut result: str = ""
    let mut i: int = 0
    
    while i < encoded.len() {
        if encoded[i:i+1] == "=" {
            break
        }
        
        let c1: int = index_of(chars, encoded[i:i+1])
        let c2: int = if i + 1 < encoded.len() then index_of(chars, encoded[i+1:i+2]) else -1
        let c3: int = if i + 2 < encoded.len() and encoded[i+2:i+3] != "=" then index_of(chars, encoded[i+2:i+3]) else -1
        let c4: int = if i + 3 < encoded.len() and encoded[i+3:i+4] != "=" then index_of(chars, encoded[i+3:i+4]) else -1
        
        if c1 == -1 or c2 == -1 {
            return err("invalid base64 character")
        }
        
        let n: int = (c1 << 18) | (c2 << 12) | ((if c3 != -1 then c3 else 0) << 6) | (if c4 != -1 then c4 else 0)
        
        result = result + chr((n >> 16) & 255)
        if c3 != -1 {
            result = result + chr((n >> 8) & 255)
        }
        if c4 != -1 {
            result = result + chr(n & 255)
        }
        
        i = i + 4
    }
    
    return ok(result)
}

# Find index of character in string, returns -1 if not found
fn index_of(s: str, c: str) -> int {
    let mut i: int = 0
    while i < s.len() {
        if s[i:i+1] == c {
            return i
        }
        i = i + 1
    }
    return -1
}

# Hex encoding/decoding

# Encode data to hexadecimal string
# Example: hex_encode("hello") -> "68656c6c6f"
fn hex_encode(data: str) -> str {
    let hex_chars: str = "0123456789abcdef"
    let mut result: str = ""
    let mut i: int = 0
    
    while i < data.len() {
        let byte: int = ord(data[i:i+1][0])
        result = result + hex_chars[(byte >> 4) & 15:(byte >> 4) & 15 + 1]
        result = result + hex_chars[byte & 15:byte & 15 + 1]
        i = i + 1
    }
    
    return result
}

# Decode hexadecimal string to data
# Returns ok(decoded) on success, err(message) on invalid input
fn hex_decode(encoded: str) -> Result[str, str] {
    if encoded.len() % 2 != 0 {
        return err("hex string must have even length")
    }
    
    let mut result: str = ""
    let mut i: int = 0
    
    while i < encoded.len() {
        let h1: int = hex_char_to_int(encoded[i:i+1])
        let h2: int = hex_char_to_int(encoded[i+1:i+2])
        
        if h1 == -1 or h2 == -1 {
            return err("invalid hex character")
        }
        
        result = result + chr((h1 << 4) | h2)
        i = i + 2
    }
    
    return ok(result)
}

# Convert hex character to integer (0-15), returns -1 for invalid
fn hex_char_to_int(c: str) -> int {
    let code: int = ord(c[0])
    if code >= 48 and code <= 57 {  # '0'-'9'
        return code - 48
    }
    if code >= 97 and code <= 102 {  # 'a'-'f'
        return code - 97 + 10
    }
    if code >= 65 and code <= 70 {  # 'A'-'F'
        return code - 65 + 10
    }
    return -1
}

# Constant-time string comparison (prevents timing attacks)
# Returns true if strings are equal, false otherwise
fn constant_time_compare(a: str, b: str) -> bool {
    if a.len() != b.len() {
        return false
    }
    
    let mut result: int = 0
    let mut i: int = 0
    while i < a.len() {
        result = result | (ord(a[i:i+1][0]) ^ ord(b[i:i+1][0]))
        i = i + 1
    }
    
    return result == 0
}

