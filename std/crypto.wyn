# std/crypto.wyn
# Cryptographic operations
# All functions are mapped to runtime implementations via compiler

# Encryption:
#   crypto.encrypt_aes256(data: str, key: str) -> str
#   crypto.decrypt_aes256(data: str, key: str) -> str

# Random:
#   crypto.generate_random_bytes(size: int) -> str

# HMAC:
#   crypto.hmac_sha256(data: str, key: str) -> str
#   crypto.verify_signature(data: str, signature: str, key: str) -> int
