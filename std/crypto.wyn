# Compute CRC32 checksum (commonly used for data integrity)
# Returns a 32-bit checksum value
fn crc32(data: str) -> int {
    let mut crc: int = 4294967295
    let mut i: int = 0
    
    while i < data.len() {
        let byte: int = ord(data[i:i+1][0])
        crc = crc ^ byte
        
        let mut j: int = 0
        while j < 8 {
            if (crc & 1) != 0 {
                crc = (crc >> 1) ^ 3988292384
            } else {
                crc = crc >> 1
            }
            j = j + 1
        }
        i = i + 1
    }
    
    return crc ^ 4294967295
}

# Compute Adler-32 checksum (faster than CRC32, used in zlib)
# Returns a 32-bit checksum value
fn adler32(data: str) -> int {
    let mod_adler: int = 65521
    let mut a: int = 1
    let mut b: int = 0
    let mut i: int = 0
    
    while i < data.len() {
        a = (a + ord(data[i:i+1][0])) % mod_adler
        b = (b + a) % mod_adler
        i = i + 1
    }
    
    return (b << 16) | a
}
