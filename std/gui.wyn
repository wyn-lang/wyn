# ============================================================================
# State Management
# ============================================================================

# Reactive state wrapper
struct State[T] {
    value: T
}

fn state[T](initial: T) -> State[T] {
    return State[T]{value: initial}
}

fn get[T](s: State[T]) -> T {
    return s.value
}

fn set[T](s: State[T], value: T) {
    s.value = value
    # Stage 1: Will trigger UI update
}

# ============================================================================
# Theming
# ============================================================================

struct Theme {
    primary: Color
    secondary: Color
    background: Color
    surface: Color
    text: Color
    error: Color
}

fn light_theme() -> Theme {
    return Theme{
        primary: rgb(33, 150, 243),
        secondary: rgb(156, 39, 176),
        background: rgb(250, 250, 250),
        surface: white(),
        text: rgb(33, 33, 33),
        error: rgb(244, 67, 54)
    }
}

fn dark_theme() -> Theme {
    return Theme{
        primary: rgb(100, 181, 246),
        secondary: rgb(206, 147, 216),
        background: rgb(18, 18, 18),
        surface: rgb(30, 30, 30),
        text: rgb(255, 255, 255),
        error: rgb(239, 83, 80)
    }
}

fn set_theme(theme: Theme) {
    # Requires: Native theme support
}
