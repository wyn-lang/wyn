# ============================================================================
# Menu
# ============================================================================

struct MenuItem {
    label: str
    shortcut: str
    action: fn()
}

struct Menu {
    label: str
    items: [MenuItem]
}

fn menu_item(label: str, action: fn()) -> MenuItem {
    return MenuItem{label: label, shortcut: "", action: action}
}

fn menu_item_shortcut(label: str, shortcut: str, action: fn()) -> MenuItem {
    return MenuItem{label: label, shortcut: shortcut, action: action}
}

fn menu(label: str, items: [MenuItem]) -> Menu {
    return Menu{label: label, items: items}
}

fn set_menu(menus: [Menu]) {
    # Requires: Native menu bar
}

