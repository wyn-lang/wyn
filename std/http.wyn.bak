# --- HTTP Methods ---

fn method_get() -> str { return "GET" }
fn method_post() -> str { return "POST" }
fn method_put() -> str { return "PUT" }
fn method_delete() -> str { return "DELETE" }
fn method_patch() -> str { return "PATCH" }
fn method_head() -> str { return "HEAD" }
fn method_options() -> str { return "OPTIONS" }
fn method_trace() -> str { return "TRACE" }
fn method_connect() -> str { return "CONNECT" }

# --- Status Codes ---

fn status_ok() -> int { return 200 }
fn status_created() -> int { return 201 }
fn status_accepted() -> int { return 202 }
fn status_no_content() -> int { return 204 }
fn status_moved_permanently() -> int { return 301 }
fn status_found() -> int { return 302 }
fn status_not_modified() -> int { return 304 }
fn status_temporary_redirect() -> int { return 307 }
fn status_permanent_redirect() -> int { return 308 }
fn status_bad_request() -> int { return 400 }
fn status_unauthorized() -> int { return 401 }
fn status_forbidden() -> int { return 403 }
fn status_not_found() -> int { return 404 }
fn status_method_not_allowed() -> int { return 405 }
fn status_conflict() -> int { return 409 }
fn status_internal_error() -> int { return 500 }
fn status_not_implemented() -> int { return 501 }
fn status_bad_gateway() -> int { return 502 }
fn status_service_unavailable() -> int { return 503 }
fn status_gateway_timeout() -> int { return 504 }

# --- Status Checks ---

fn is_informational(status: int) -> bool {
    return status >= 100 and status < 200
}

fn is_success(status: int) -> bool {
    return status >= 200 and status < 300
}

fn is_redirect(status: int) -> bool {
    return status >= 300 and status < 400
}

fn is_client_error(status: int) -> bool {
    return status >= 400 and status < 500
}

fn is_server_error(status: int) -> bool {
    return status >= 500 and status < 600
}

fn is_error(status: int) -> bool {
    return status >= 400
}

# --- Status Text ---

fn status_text(status: int) -> str {
    if status == 200 { return "OK" }
    if status == 201 { return "Created" }
    if status == 202 { return "Accepted" }
    if status == 204 { return "No Content" }
    if status == 301 { return "Moved Permanently" }
    if status == 302 { return "Found" }
    if status == 304 { return "Not Modified" }
    if status == 307 { return "Temporary Redirect" }
    if status == 308 { return "Permanent Redirect" }
    if status == 400 { return "Bad Request" }
    if status == 401 { return "Unauthorized" }
    if status == 403 { return "Forbidden" }
    if status == 404 { return "Not Found" }
    if status == 405 { return "Method Not Allowed" }
    if status == 409 { return "Conflict" }
    if status == 500 { return "Internal Server Error" }
    if status == 501 { return "Not Implemented" }
    if status == 502 { return "Bad Gateway" }
    if status == 503 { return "Service Unavailable" }
    if status == 504 { return "Gateway Timeout" }
    return "Unknown"
}

# --- Headers ---

fn make_header(key: str, value: str) -> str {
    return key + ": " + value
}

fn parse_header(header: str) -> ?[str] {
    mut i: int = 0
    while i < len(header) {
        if header[i:i+1] == ":" {
            let key: str = header[0:i]
            mut value_start: int = i + 1
            while value_start < len(header) and header[value_start:value_start+1] == " " {
                value_start = value_start + 1
            }
            let value: str = header[value_start:len(header)]
            return some([key, value])
        }
        i = i + 1
    }
    return none
}

fn header_key(header: str) -> str {
    mut i: int = 0
    while i < len(header) {
        if header[i:i+1] == ":" {
            return header[0:i]
        }
        i = i + 1
    }
    return ""
}

fn header_value(header: str) -> str {
    mut i: int = 0
    while i < len(header) {
        if header[i:i+1] == ":" {
            mut value_start: int = i + 1
            while value_start < len(header) and header[value_start:value_start+1] == " " {
                value_start = value_start + 1
            }
            return header[value_start:len(header)]
        }
        i = i + 1
    }
    return ""
}

