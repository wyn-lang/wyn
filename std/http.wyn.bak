# --- URL Parsing ---

fn url_protocol(url: str) -> str {
    if len(url) >= 7 and url[0:7] == "http://" {
        return "http"
    }
    if len(url) >= 8 and url[0:8] == "https://" {
        return "https"
    }
    return ""
}

fn is_https(url: str) -> bool {
    return len(url) >= 8 and url[0:8] == "https://"
}

fn url_host(url: str) -> str {
    mut start: int = 0
    if len(url) >= 7 and url[0:7] == "http://" {
        start = 7
    } else if len(url) >= 8 and url[0:8] == "https://" {
        start = 8
    }
    
    mut end: int = start
    while end < len(url) {
        let c: str = url[end:end+1]
        if c == "/" or c == ":" or c == "?" {
            break
        }
        end = end + 1
    }
    return url[start:end]
}

fn url_path(url: str) -> str {
    mut start: int = 0
    if len(url) >= 7 and url[0:7] == "http://" {
        start = 7
    } else if len(url) >= 8 and url[0:8] == "https://" {
        start = 8
    }
    
    mut i: int = start
    while i < len(url) {
        if url[i:i+1] == "/" {
            mut end: int = i
            while end < len(url) and url[end:end+1] != "?" {
                end = end + 1
            }
            return url[i:end]
        }
        i = i + 1
    }
    return "/"
}

fn url_query(url: str) -> str {
    mut i: int = 0
    while i < len(url) {
        if url[i:i+1] == "?" {
            return url[i+1:len(url)]
        }
        i = i + 1
    }
    return ""
}

fn url_port(url: str) -> int {
    mut start: int = 0
    if len(url) >= 7 and url[0:7] == "http://" {
        start = 7
    } else if len(url) >= 8 and url[0:8] == "https://" {
        start = 8
    }
    
    mut i: int = start
    while i < len(url) {
        if url[i:i+1] == ":" {
            mut port_start: int = i + 1
            mut port_end: int = port_start
            while port_end < len(url) {
                let c: str = url[port_end:port_end+1]
                if c == "/" or c == "?" {
                    break
                }
                port_end = port_end + 1
            }
            let port_str: str = url[port_start:port_end]
            return str_to_int(port_str)
        }
        if url[i:i+1] == "/" or url[i:i+1] == "?" {
            break
        }
        i = i + 1
    }
    
    if is_https(url) {
        return 443
    }
    return 80
}

# --- Query String ---

fn parse_query_param(query: str, key: str) -> ?str {
    mut i: int = 0
    while i < len(query) {
        mut eq_pos: int = i
        while eq_pos < len(query) and query[eq_pos:eq_pos+1] != "=" {
            eq_pos = eq_pos + 1
        }
        
        if eq_pos >= len(query) {
            break
        }
        
        let param_key: str = query[i:eq_pos]
        mut value_end: int = eq_pos + 1
        while value_end < len(query) and query[value_end:value_end+1] != "&" {
            value_end = value_end + 1
        }
        
        let param_value: str = query[eq_pos+1:value_end]
        
        if param_key == key {
            return some(param_value)
        }
        
        i = value_end + 1
    }
    return none
}

fn build_query(params: [[str]]) -> str {
    mut result: str = ""
    mut first: bool = true
    for pair in params {
        if not first {
            result = result + "&"
        }
        result = result + pair[0] + "=" + pair[1]
        first = false
    }
    return result
}

# --- Request Builders ---

fn make_request(method: str, path: str, body: str) -> Request {
    return Request { method: method, path: path, headers: [], body: body }
}

fn get_request(path: str) -> Request {
    return make_request("GET", path, "")
}

fn post_request(path: str, body: str) -> Request {
    return make_request("POST", path, body)
}

fn put_request(path: str, body: str) -> Request {
    return make_request("PUT", path, body)
}

fn delete_request(path: str) -> Request {
    return make_request("DELETE", path, "")
}

fn patch_request(path: str, body: str) -> Request {
    return make_request("PATCH", path, body)
}

fn head_request(path: str) -> Request {
    return make_request("HEAD", path, "")
}

# --- Response Builders ---

fn make_response(status: int, body: str) -> Response {
    return Response { status: status, headers: [], body: body }
}

fn make_response_with_headers(status: int, headers: [str], body: str) -> Response {
    return Response { status: status, headers: headers, body: body }
}

fn json_response(status: int, json_body: str) -> Response {
    return Response { 
        status: status, 
        headers: [make_header("Content-Type", "application/json")], 
        body: json_body 
    }
}

fn html_response(status: int, html_body: str) -> Response {
    return Response { 
        status: status, 
        headers: [make_header("Content-Type", "text/html")], 
        body: html_body 
    }
}

fn text_response(status: int, text_body: str) -> Response {
    return Response { 
        status: status, 
        headers: [make_header("Content-Type", "text/plain")], 
        body: text_body 
    }
}

fn xml_response(status: int, xml_body: str) -> Response {
    return Response { 
        status: status, 
        headers: [make_header("Content-Type", "application/xml")], 
        body: xml_body 
    }
}

fn redirect_response(location: str) -> Response {
    return Response { 
        status: 302, 
        headers: [make_header("Location", location)], 
        body: "" 
    }
}

fn permanent_redirect_response(location: str) -> Response {
    return Response { 
        status: 301, 
        headers: [make_header("Location", location)], 
        body: "" 
    }
}

fn error_response(status: int, message: str) -> Response {
    return text_response(status, message)
}

fn ok_response(body: str) -> Response {
    return make_response(200, body)
}

fn not_found_response() -> Response {
    return error_response(404, "Not Found")
}

fn internal_error_response() -> Response {
    return error_response(500, "Internal Server Error")
}

# --- Method Checks ---

fn is_safe_method(method: str) -> bool {
    return method == "GET" or method == "HEAD" or method == "OPTIONS"
}

fn is_idempotent_method(method: str) -> bool {
    return method == "GET" or method == "HEAD" or method == "PUT" or 
           method == "DELETE" or method == "OPTIONS"
}

fn has_request_body(method: str) -> bool {
    return method == "POST" or method == "PUT" or method == "PATCH"
}

fn has_response_body(method: str) -> bool {
    return method != "HEAD"
}

fn is_valid_method(method: str) -> bool {
    return method == "GET" or method == "POST" or method == "PUT" or 
           method == "DELETE" or method == "PATCH" or method == "HEAD" or 
           method == "OPTIONS" or method == "TRACE" or method == "CONNECT"
}

# --- Response Utilities ---

fn find_header(response: Response, key: str) -> ?str {
    for header in response.headers {
        let h_key: str = header_key(header)
        if h_key == key {
            return some(header_value(header))
        }
    }
    return none
}

fn response_content_type(response: Response) -> str {
    return find_header(response, "Content-Type") ?? ""
}

fn is_json_response(response: Response) -> bool {
    let ct: str = response_content_type(response)
    return len(ct) >= 16 and ct[0:16] == "application/json"
}

fn is_html_response(response: Response) -> bool {
    let ct: str = response_content_type(response)
    return len(ct) >= 9 and ct[0:9] == "text/html"
}

fn is_text_response(response: Response) -> bool {
    let ct: str = response_content_type(response)
    return len(ct) >= 10 and ct[0:10] == "text/plain"
}

fn response_body(response: Response) -> str {
    return response.body
}

fn response_status(response: Response) -> int {
    return response.status
}

fn response_ok(response: Response) -> bool {
    return is_success(response.status)
}

# --- Request Utilities ---

fn request_method(request: Request) -> str {
    return request.method
}

fn request_path(request: Request) -> str {
    return request.path
}

fn request_body(request: Request) -> str {
    return request.body
}

fn find_request_header(request: Request, key: str) -> ?str {
    for header in request.headers {
        let h_key: str = header_key(header)
        if h_key == key {
            return some(header_value(header))
        }
    }
    return none
}

fn request_content_type(request: Request) -> str {
    return find_request_header(request, "Content-Type") ?? ""
}
