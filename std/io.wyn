# std/io.wyn
# Console I/O operations
# All functions are mapped to runtime implementations via compiler

# Note: print(), println(), and input() are built-in and don't need import

# Advanced Console I/O:
#   io.print_str(s: str) -> void
#   io.print_int(n: int) -> void
#   io.print_float(f: float) -> void
#   io.print_newline() -> void
#   io.read_line() -> str
