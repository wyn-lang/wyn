# std/io.wyn
# Basic I/O operations for reading and writing files

# Print a string (no newline)
fn print(s: str) {
    print_str(s)
}

# Print a string followed by a newline
fn println(s: str) {
    print_str(s)
    print_str("\n")
}

# Print a string followed by a newline (alias)
fn print_line(s: str) {
    print_str(s)
    print_str("\n")
}

# Read entire file contents as a string
# Returns ok(content) on success, or err(message) on failure
fn read_to_string(path: str) -> Result[str, str] {
    return read_file(path)
}

# Write a string to a file, overwriting if it exists
# Returns ok(true) on success, or err(message) on failure
fn write_string(path: str, content: str) -> Result[bool, str] {
    return write_file(path, content)
}

# Check if a file or directory exists at the given path
fn path_exists(path: str) -> bool {
    return file_exists(path)
}

# Get the size of a file in bytes
# Returns ok(size) on success, or err(message) on failure
fn get_file_size(path: str) -> Result[int, str] {
    let size = file_size(path)
    if size >= 0 {
        return ok(size)
    }
    return err("File not found or error")
}

# Read a line from standard input
# Requires: Runtime support (stdin syscall)
fn read_line() -> str {
    return read_stdin_line()
}

# Read entire file contents as a string (low-level)
# Returns ok(content) on success, or err(message) on failure
# Requires: Runtime support (file I/O syscalls)
fn read_file(path: str) -> Result[str, str] {
    const content: str = read_file(path)
    if content.len() >= 0 {
        return ok(content)
    }
    return err("Failed to read file")
}

# Write content to a file, overwriting if it exists (low-level)
# Returns ok(true) on success, or err(message) on failure
# Requires: Runtime support (file I/O syscalls)
fn write_file(path: str, content: str) -> Result[bool, str] {
    const result: bool = write_file(path, content)
    if result {
        return ok(true)
    }
    return err("Failed to write file")
}

# Append content to the end of a file
# Returns ok(true) on success, or err(message) on failure
# Requires: Runtime support (file I/O syscalls)
fn append_file(path: str, content: str) -> Result[bool, str] {
    const result: bool = append_file(path, content)
    if result {
        return ok(true)
    }
    return err("Failed to append to file")
}

# Check if a file exists at the given path (low-level)
# Requires: Runtime support (file stat syscall)
fn file_exists(path: str) -> bool {
    return file_exists(path)
}

# Delete a file at the given path
# Returns ok(true) on success, or err(message) on failure
# Requires: Runtime support (file I/O syscalls)
fn delete_file(path: str) -> Result[bool, str] {
    const result: bool = delete_file(path)
    if result {
        return ok(true)
    }
    return err("Failed to delete file")
}

# Read file contents as an array of bytes
# Returns ok(bytes) on success, or err(message) on failure
# Requires: Runtime support (file I/O syscalls)
fn read_bytes(path: str) -> Result[[byte], str] {
    # Will be implemented via syscall or FFI
    return ok([])
}

# Write an array of bytes to a file
# Returns ok(true) on success, or err(message) on failure
# Requires: Runtime support (file I/O syscalls)
fn write_bytes(path: str, data: [byte]) -> Result[bool, str] {
    # Will be implemented via syscall or FFI
    return ok(false)
}

# Read file contents as an array of lines
# Returns ok(lines) on success, or err(message) on failure
fn read_lines(path: str) -> Result[[str], str] {
    const content_result: Result[str, str] = read_file(path)
    if content_result.is_err {
        return err("Failed to read file")
    }
    const content: str = content_result.value
    const lines: [str] = str_split(content, "\n")
    return ok(lines)
}
}

# Create a directory at the given path
# Returns ok(true) on success, or err(message) on failure
# Requires: Runtime support (directory syscalls)
fn create_dir(path: str) -> Result[bool, str] {
    const result: bool = mkdir(path)
    if result {
        return ok(true)
    }
    return err("Failed to create directory")
}

# Remove a directory at the given path
# Returns ok(true) on success, or err(message) on failure
# Requires: Runtime support (directory syscalls)
fn remove_dir(path: str) -> Result[bool, str] {
    const result: bool = rmdir(path)
    if result {
        return ok(true)
    }
    return err("Failed to remove directory")
}

# List all files and directories in the given path
# Returns ok(entries) on success, or err(message) on failure
# Requires: Runtime support (directory syscalls)
fn list_dir(path: str) -> Result[[str], str] {
    const entries: [str] = list_dir(path)
    return ok(entries)
}

# Copy a file from src to dst
# Returns ok(true) on success, or err(message) on failure
fn copy_file(src: str, dst: str) -> Result[bool, str] {
    const content_result: Result[str, str] = read_file(src)
    # Stage 0: Can't pattern match, so just try to write
    # Stage 1 will properly handle Result chaining
    return write_file(dst, "")
}

# Move a file from src to dst
# Returns ok(true) on success, or err(message) on failure
# Requires: Runtime support (file I/O syscalls)
fn move_file(src: str, dst: str) -> Result[bool, str] {
    const result: bool = rename_file(src, dst)
    if result {
        return ok(true)
    }
    return err("Failed to move file")
}

# Format an integer with zero-padding to the specified width
# Example: format_int(42, 5) -> "00042"
fn format_int(n: int, width: int) -> str {
    const s: str = int_to_str(n)
    const len: int = s.len()
    if len >= width {
        return s
    }
    const padding: int = width - len
    let result: str = ""
    let i: int = 0
    while i < padding {
        result = result + "0"
        i = i + 1
    }
    return result + s
}

# Convert a boolean to a string ("true" or "false")
fn format_bool(b: bool) -> str {
    if b {
        return "true"
    }
    return "false"
}

# Format integer with left padding using spaces instead of zeros
# Example: format_int_padded(42, 5) -> "   42"
fn format_int_padded(n: int, width: int) -> str {
    const s: str = int_to_str(n)
    const len: int = s.len()
    if len >= width {
        return s
    }
    const padding: int = width - len
    let result: str = ""
    let i: int = 0
    while i < padding {
        result = result + " "
        i = i + 1
    }
    return result + s
}

# Format integer in hexadecimal (lowercase, no prefix)
# Example: format_hex(255) -> "ff"
fn format_hex(n: int) -> str {
    if n == 0 {
        return "0"
    }
    let result: str = ""
    let val: int = n
    const hex_chars: str = "0123456789abcdef"
    while val > 0 {
        const digit: int = val % 16
        result = hex_chars[digit:digit+1] + result
        val = val / 16
    }
    return result
}

# Format integer in binary (no prefix)
# Example: format_bin(5) -> "101"
fn format_bin(n: int) -> str {
    if n == 0 {
        return "0"
    }
    let result: str = ""
    let val: int = n
    while val > 0 {
        const bit: int = val % 2
        result = int_to_str(bit) + result
        val = val / 2
    }
    return result
}

# Print multiple strings in sequence without newline
fn print_all(parts: [str]) {
    let i: int = 0
    while i < parts.len() {
        print(parts[i])
        i = i + 1
    }
}

# Print an integer followed by a newline
fn println_int(n: int) {
    print(n)
    print("\n")
}

# Repeat a character n times
# Example: repeat_char("*", 5) -> "*****"
fn repeat_char(c: str, n: int) -> str {
    if n <= 0 or c.len() == 0 {
        return ""
    }
    let result: str = ""
    let i: int = 0
    while i < n {
        result = result + c
        i = i + 1
    }
    return result
}

# Format integer with thousands separator
# Example: format_thousands(1234567) -> "1,234,567"
fn format_thousands(n: int) -> str {
    const s: str = int_to_str(n)
    const len: int = s.len()
    if len <= 3 {
        return s
    }
    let result: str = ""
    let count: int = 0
    let i: int = len - 1
    while i >= 0 {
        if count == 3 {
            result = "," + result
            count = 0
        }
        result = s[i:i+1] + result
        count = count + 1
        i = i - 1
    }
    return result
}

# Format percentage with specified decimal places
# Example: format_percent(75, 1) -> "75.0%"
fn format_percent(value: int, decimals: int) -> str {
    return int_to_str(value) + "%"
}

# Print a horizontal line of specified character and width
fn print_line_char(c: str, width: int) {
    print(repeat_char(c, width))
    print("\n")
}

# Print a box around text
fn print_box(text: str) {
    const len: int = text.len()
    const border: str = repeat_char("-", len + 4)
    print(border + "\n")
    print("| " + text + " |\n")
    print(border + "\n")
}

# Print error message to stderr (simulated with prefix)
fn print_error(msg: str) {
    print("ERROR: " + msg + "\n")
}

# Print warning message
fn print_warning(msg: str) {
    print("WARNING: " + msg + "\n")
}

# Print info message
fn print_info(msg: str) {
    print("INFO: " + msg + "\n")
}

# Print success message
fn print_success(msg: str) {
    print("SUCCESS: " + msg + "\n")
}

# Format Result error for display
