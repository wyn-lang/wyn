# --- Path Utilities ---

# Join two path components with separator
# Handles trailing slashes automatically
fn join_path(a: str, b: str) -> str {
    if a.len() == 0 {
        return b
    }
    if b.len() == 0 {
        return a
    }
    const last: int = ord(a[a.len() - 1:a.len()][0])
    if last == 47 {  # '/'
        return a + b
    }
    return a + "/" + b
}

# Get directory portion of path
# Returns "." if no directory component
fn dirname(path: str) -> str {
    let i: int = path.len() - 1
    while i >= 0 {
        if ord(path[i:i+1][0]) == 47 {  # '/'
            if i == 0 {
                return "/"
            }
            return path[0:i]
        }
        i = i - 1
    }
    return "."
}

# Get filename portion of path (last component)
fn basename(path: str) -> str {
    let i: int = path.len() - 1
    while i >= 0 {
        if ord(path[i:i+1][0]) == 47 {  # '/'
            return path[i+1:path.len()]
        }
        i = i - 1
    }
    return path
}

# Get file extension including dot (e.g., ".txt")
# Returns empty string if no extension
fn extension(path: str) -> str {
    const base: str = basename(path)
    let i: int = base.len() - 1
    while i >= 0 {
        if ord(base[i:i+1][0]) == 46 {  # '.'
            return base[i:base.len()]
        }
        i = i - 1
    }
    return ""
}

# Normalize path by removing duplicate slashes
# Removes trailing slash except for root
fn normalize_path(path: str) -> str {
    if path.len() == 0 {
        return "."
    }
    let result: str = ""
    let i: int = 0
    let last_slash: bool = false
    while i < path.len() {
        const c: int = ord(path[i:i+1][0])
        if c == 47 {  # '/'
            if last_slash == false {
                result = result + "/"
                last_slash = true
            }
        } else {
            result = result + path[i:i+1]
            last_slash = false
        }
        i = i + 1
    }
    if result.len() > 1 and ord(result[result.len()-1:result.len()][0]) == 47 {
        result = result[0:result.len()-1]
    }
    return result
}

# Remove file extension from path
fn remove_extension(path: str) -> str {
    const ext: str = extension(path)
    if ext.len() == 0 {
        return path
    }
    return path[0:path.len() - ext.len()]
}

# Check if path is absolute (starts with /)
fn is_absolute(path: str) -> bool {
    if path.len() == 0 {
        return false
    }
    return ord(path[0:1][0]) == 47  # '/'
}

# Check if path has extension
fn has_extension(path: str) -> bool {
    return extension(path).len() > 0
}

# Join multiple path components
fn join_paths(parts: [str]) -> str {
    if parts.len() == 0 {
        return ""
    }
    let result: str = parts[0]
    let i: int = 1
    while i < parts.len() {
        result = join_path(result, parts[i])
        i = i + 1
    }
    return result
}

# Get parent directory (same as dirname but clearer name)
fn parent(path: str) -> str {
    return dirname(path)
}

# Get filename without extension
fn stem(path: str) -> str {
    const base: str = basename(path)
    const ext: str = extension(path)
    if ext.len() == 0 {
        return base
    }
    return base[0:base.len() - ext.len()]
}

# Split path into directory and filename
fn split_path(path: str) -> (str, str) {
    const dir: str = dirname(path)
    const file: str = basename(path)
    return (dir, file)
}

# Check if path ends with separator
fn has_trailing_slash(path: str) -> bool {
    if path.len() == 0 {
        return false
    }
    return ord(path[path.len()-1:path.len()][0]) == 47  # '/'
}

# Add trailing slash if not present
fn ensure_trailing_slash(path: str) -> str {
    if has_trailing_slash(path) {
        return path
    }
    return path + "/"
}

# Remove trailing slash if present (except for root)
fn remove_trailing_slash(path: str) -> str {
    if path.len() <= 1 {
        return path
    }
    if has_trailing_slash(path) {
        return path[0:path.len()-1]
    }
    return path
}

# Check if path matches extension (case-sensitive)
fn has_ext(path: str, ext: str) -> bool {
    const path_ext: str = extension(path)
    if ext.len() > 0 and ord(ext[0:1][0]) != 46 {  # '.'
        return path_ext == "." + ext
    }
    return path_ext == ext
}

# Replace extension with new one
fn with_extension(path: str, new_ext: str) -> str {
    const base: str = remove_extension(path)
    if new_ext.len() == 0 {
        return base
    }
    if ord(new_ext[0:1][0]) == 46 {  # '.'
        return base + new_ext
    }
    return base + "." + new_ext
}

# Count path components (depth)
fn path_depth(path: str) -> int {
    if path.len() == 0 {
        return 0
    }
    const normalized: str = normalize_path(path)
    let count: int = 0
    let i: int = 0
    while i < normalized.len() {
        if ord(normalized[i:i+1][0]) == 47 {  # '/'
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Check if path is just a filename (no directory component)
fn is_filename_only(path: str) -> bool {
    return dirname(path) == "."
}

# Check if path contains parent directory references (..)
fn has_parent_refs(path: str) -> bool {
    let i: int = 0
    while i < path.len() - 1 {
        if path[i:i+2] == ".." {
            let before_ok: bool = false
            if i == 0 {
                before_ok = true
            }
            if i > 0 {
                if ord(path[i-1:i][0]) == 47 {  # '/'
                    before_ok = true
                }
            }
            if before_ok {
                if i + 2 >= path.len() {
                    return true
                }
                if ord(path[i+2:i+3][0]) == 47 {
                    return true
                }
            }
        }
        i = i + 1
    }
    return false
}

# Check if path is hidden (starts with .)
fn is_hidden(path: str) -> bool {
    const base: str = basename(path)
    if base.len() == 0 {
        return false
    }
    return ord(base[0:1][0]) == 46  # '.'
}

# Get common file extensions
fn ext_text() -> str { return ".txt" }
fn ext_json() -> str { return ".json" }
fn ext_xml() -> str { return ".xml" }
fn ext_html() -> str { return ".html" }
fn ext_css() -> str { return ".css" }
fn ext_js() -> str { return ".js" }
fn ext_md() -> str { return ".md" }
fn ext_wyn() -> str { return ".wyn" }

# Check if path is a text file by extension
fn is_text_file(path: str) -> bool {
    const ext: str = extension(path)
    if ext == ".txt" {
        return true
    }
    if ext == ".md" {
        return true
    }
    if ext == ".json" {
        return true
    }
    if ext == ".xml" {
        return true
    }
    if ext == ".html" {
        return true
    }
    if ext == ".css" {
        return true
    }
    if ext == ".js" {
        return true
    }
    if ext == ".wyn" {
        return true
    }
    return false
}

# Sanitize filename by removing invalid characters
fn sanitize_filename(name: str) -> str {
    let result: str = ""
    let i: int = 0
    while i < name.len() {
        const c: int = ord(name[i:i+1][0])
        let invalid: bool = false
        if c == 47 {  # '/'
            invalid = true
        }
        if c == 0 {  # null
            invalid = true
        }
        if c == 92 {  # '\'
            invalid = true
        }
        if invalid {
            result = result + "_"
        } else {
            result = result + name[i:i+1]
        }
        i = i + 1
    }
    return result
}

# Create a safe path by joining and normalizing
fn safe_join(base: str, path: str) -> str {
    const joined: str = join_path(base, path)
    return normalize_path(joined)
}

