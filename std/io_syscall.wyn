# Pure Wyn I/O Module - No C dependencies

fn write_file(path: str, content: str) -> int {
    # open(path, O_WRONLY | O_CREAT | O_TRUNC, 0644)
    # O_WRONLY=1, O_CREAT=512, O_TRUNC=1024 -> flags=1537
    const fd: int = syscall(5, path, 1537, 420, 0, 0, 0)
    
    if fd < 0 {
        return fd
    }
    
    # write(fd, content, len)
    const written: int = syscall(4, fd, content, content.len(), 0, 0, 0)
    
    # close(fd)
    syscall(6, fd, 0, 0, 0, 0, 0)
    
    return written
}
