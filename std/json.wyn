# Check if a JSON string represents a specific type
fn is_json_null(json: str) -> bool {
    return trim(json) == "null"
}

# Check if a JSON string represents a boolean
fn is_json_bool(json: str) -> bool {
    let t: str = trim(json)
    return t == "true" or t == "false"
}

# Check if a JSON string represents a number
fn is_json_number(json: str) -> bool {
    let t: str = trim(json)
    if t.len() == 0 {
        return false
    }
    let first: int = ord(t[0:1][0])
    return is_json_number_start(first)
}

# Check if a JSON string represents a string
fn is_json_string(json: str) -> bool {
    let t: str = trim(json)
    return t.len() >= 2 and t[0:1] == "\"" and t[t.len()-1:t.len()] == "\""
}

# Check if a JSON string represents an array
fn is_json_array(json: str) -> bool {
    let t: str = trim(json)
    return t.len() >= 2 and t[0:1] == "[" and t[t.len()-1:t.len()] == "]"
}

# Check if a JSON string represents an object
fn is_json_object(json: str) -> bool {
    let t: str = trim(json)
    return t.len() >= 2 and t[0:1] == "{" and t[t.len()-1:t.len()] == "}"
}

# Count elements in a JSON array
# Returns the number of top-level elements, or 0 if not an array
fn json_array_length(json: str) -> int {
    let trimmed: str = trim(json)
    if trimmed.len() < 2 or trimmed[0:1] != "[" {
        return 0
    }
    
    let mut count: int = 0
    let mut depth: int = 0
    let mut in_string: bool = false
    let mut i: int = 1
    
    while i < trimmed.len() - 1 {
        let c: str = trimmed[i:i+1]
        let code: int = ord(c[0])
        
        if code == 34 and (i == 0 or ord(trimmed[i-1:i][0]) != 92) {
            in_string = not in_string
        } else if not in_string {
            if c == "[" or c == "{" {
                depth = depth + 1
            } else if c == "]" or c == "}" {
                depth = depth - 1
            } else if c == "," and depth == 0 {
                count = count + 1
            }
        }
        i = i + 1
    }
    
    if count > 0 or (trimmed.len() > 2 and not is_whitespace(ord(trimmed[1:2][0]))) {
        count = count + 1
    }
    
    return count
}

# Trim whitespace from start and end of string
fn trim(s: str) -> str {
    let start: int = skip_whitespace(s, 0)
    let mut end: int = s.len() - 1
    
    while end >= start and is_whitespace(ord(s[end:end+1][0])) {
        end = end - 1
    }
    
    if start > end {
        return ""
    }
    
    return s[start:end+1]
}
