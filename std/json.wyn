# std/json.wyn
# JSON parsing and generation
# All functions are mapped to runtime implementations via compiler

# JSON Operations:
#   json.parse(json_str: str) -> str
#   json.stringify(data: str) -> str
#   json.get_string(json: str, key: str) -> str
#   json.get_int(json: str, key: str) -> int
#   json.get_bool(json: str, key: str) -> int
