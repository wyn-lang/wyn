# Basic serialization helpers

# Escape a string for JSON encoding
# Handles quotes, backslashes, newlines, tabs, and carriage returns
# Example: escape_string("hello\nworld") -> "\"hello\\nworld\""
fn escape_string(s: str) -> str {
    let mut result: str = "\""
    let mut i: int = 0
    while i < s.len() {
        let c: int = ord(s[i:i+1][0])
        if c == 34 {  # '"'
            result = result + "\\\""
        } else if c == 92 {  # '\\'
            result = result + "\\\\"
        } else if c == 10 {  # '\n'
            result = result + "\\n"
        } else if c == 13 {  # '\r'
            result = result + "\\r"
        } else if c == 9 {  # '\t'
            result = result + "\\t"
        } else {
            result = result + s[i:i+1]
        }
        i = i + 1
    }
    result = result + "\""
    return result
}

# Unescape a JSON string
# Handles escaped quotes, backslashes, newlines, tabs, and carriage returns
# Example: unescape_string("hello\\nworld") -> "hello\nworld"
fn unescape_string(s: str) -> str {
    let mut result: str = ""
    let mut i: int = 0
    while i < s.len() {
        let c: int = ord(s[i:i+1][0])
        if c == 92 and i + 1 < s.len() {  # '\\'
            let next: int = ord(s[i+1:i+2][0])
            if next == 110 {  # 'n'
                result = result + "\n"
                i = i + 2
            } else if next == 114 {  # 'r'
                result = result + "\r"
                i = i + 2
            } else if next == 116 {  # 't'
                result = result + "\t"
                i = i + 2
            } else if next == 34 or next == 92 {  # '"' or '\\'
                result = result + s[i+1:i+2]
                i = i + 2
            } else {
                result = result + s[i:i+1]
                i = i + 1
            }
        } else {
            result = result + s[i:i+1]
            i = i + 1
        }
    }
    return result
}

# Check if a character code is whitespace (space, tab, newline, carriage return)
fn is_whitespace(c: int) -> bool {
    return c == 32 or c == 9 or c == 10 or c == 13
}

# Skip whitespace characters in a string starting from a given position
# Returns the index of the first non-whitespace character
fn skip_whitespace(s: str, start: int) -> int {
    let mut i: int = start
    while i < s.len() and is_whitespace(ord(s[i:i+1][0])) {
        i = i + 1
    }
    return i
}

# Check if a character is a valid JSON digit (0-9)
fn is_json_digit(c: int) -> bool {
    return c >= 48 and c <= 57
}

# Check if a character is a valid JSON number start (digit, minus, or plus)
fn is_json_number_start(c: int) -> bool {
    return is_json_digit(c) or c == 45 or c == 43  # '-' or '+'
}

# Serialize an integer to JSON
# Example: int_to_json(42) -> "42"
fn int_to_json(n: int) -> str {
    return int_to_str(n)
}

# Serialize a boolean to JSON
# Example: bool_to_json(true) -> "true"
fn bool_to_json(b: bool) -> str {
    return if b then "true" else "false"
}

# Create a JSON null value
fn json_null() -> str {
    return "null"
}

# Create a JSON array from a list of JSON strings
# Example: json_array(["1", "2", "3"]) -> "[1,2,3]"
fn json_array(items: [str]) -> str {
    let mut result: str = "["
    let mut i: int = 0
    while i < items.len() {
        if i > 0 {
            result = result + ","
        }
        result = result + items[i]
        i = i + 1
    }
    result = result + "]"
    return result
}

# Create a JSON object from parallel arrays of keys and values
# Example: json_object(["name", "age"], ["\"Alice\"", "30"]) -> "{\"name\":\"Alice\",\"age\":30}"
fn json_object(keys: [str], values: [str]) -> str {
    let mut result: str = "{"
    let mut i: int = 0
    let count: int = min(keys.len(), values.len())
    while i < count {
        if i > 0 {
            result = result + ","
        }
        result = result + escape_string(keys[i]) + ":" + values[i]
        i = i + 1
    }
    result = result + "}"
    return result
}

# Pretty-print JSON with indentation
# Adds newlines and spaces for readability
fn pretty_json(json: str, indent: int) -> str {
    let mut result: str = ""
    let mut level: int = 0
    let mut i: int = 0
    let mut in_string: bool = false
    
    while i < json.len() {
        let c: str = json[i:i+1]
        let code: int = ord(c[0])
        
        if code == 34 and (i == 0 or ord(json[i-1:i][0]) != 92) {  # '"' not escaped
            in_string = not in_string
            result = result + c
        } else if not in_string {
            if c == "{" or c == "[" {
                result = result + c + "\n"
                level = level + 1
                let mut j: int = 0
                while j < level * indent {
                    result = result + " "
                    j = j + 1
                }
            } else if c == "}" or c == "]" {
                result = result + "\n"
                level = level - 1
                let mut j: int = 0
                while j < level * indent {
                    result = result + " "
                    j = j + 1
                }
                result = result + c
            } else if c == "," {
                result = result + c + "\n"
                let mut j: int = 0
                while j < level * indent {
                    result = result + " "
                    j = j + 1
                }
            } else if c == ":" {
                result = result + c + " "
            } else if not is_whitespace(code) {
                result = result + c
            }
        } else {
            result = result + c
        }
        i = i + 1
    }
    
    return result
}

# Minify JSON by removing unnecessary whitespace
# Example: minify_json("{ \"a\": 1 }") -> "{\"a\":1}"
fn minify_json(json: str) -> str {
    let mut result: str = ""
    let mut i: int = 0
    let mut in_string: bool = false
    
    while i < json.len() {
        let c: str = json[i:i+1]
        let code: int = ord(c[0])
        
        if code == 34 and (i == 0 or ord(json[i-1:i][0]) != 92) {  # '"' not escaped
            in_string = not in_string
            result = result + c
        } else if in_string {
            result = result + c
        } else if not is_whitespace(code) {
            result = result + c
        }
        i = i + 1
    }
    
    return result
}

# Validate JSON structure (basic check for balanced brackets and quotes)
# Returns ok(()) if valid, err(message) if invalid
fn validate_json(json: str) -> Result[(), str] {
    let mut depth: int = 0
    let mut in_string: bool = false
    let mut i: int = 0
    
    while i < json.len() {
        let c: str = json[i:i+1]
        let code: int = ord(c[0])
        
        if code == 34 and (i == 0 or ord(json[i-1:i][0]) != 92) {  # '"' not escaped
            in_string = not in_string
        } else if not in_string {
            if c == "{" or c == "[" {
                depth = depth + 1
            } else if c == "}" or c == "]" {
                depth = depth - 1
                if depth < 0 {
                    return err("unmatched closing bracket")
                }
            }
        }
        i = i + 1
    }
    
    if in_string {
        return err("unclosed string")
    }
    if depth != 0 {
        return err("unmatched opening bracket")
    }
    
    return ok(())
}

