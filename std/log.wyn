# std/log.wyn
# Logging functions with different levels
# All functions are mapped to runtime implementations via compiler

# Logging Levels:
#   log.info(message: str) -> void
#   log.warn(message: str) -> void
#   log.error(message: str) -> void
#   log.debug(message: str) -> void
#   log.log_with_level(level: str, message: str) -> void
