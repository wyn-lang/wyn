# std/math.wyn
# Mathematical functions and utilities

# Return absolute value of an integer
fn abs(n: int) -> int {
    if n < 0 {
        return 0 - n
    }
    return n
}

# Return minimum of two integers
fn min(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

# Return maximum of two integers
fn max(a: int, b: int) -> int {
    if a > b {
        return a
    }
    return b
}

# Raise base to the power of exp (base^exp)
fn pow(base: int, exp: int) -> int {
    if exp == 0 {
        return 1
    }
    let mut result: int = 1
    let mut i: int = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

# Calculate square root using Newton's method
fn sqrt(n: float) -> float {
    if n < 0.0 {
        return 0.0
    }
    if n == 0.0 {
        return 0.0
    }
    
    let mut x: float = n
    let mut prev: float = 0.0
    let mut i: int = 0
    
    while i < 20 {
        prev = x
        x = (x + n / x) / 2.0
        i = i + 1
    }
    
    return x
}

# Round down to nearest integer (toward negative infinity)
fn floor(n: float) -> int {
    # Simple truncation toward negative infinity
    let i: int = n.to_int()
    # to_int truncates toward zero, so for negative non-integers we need to subtract 1
    if n < 0.0 and n != 0.0 {
        # Check if n is not an integer by seeing if truncation changed it
        # This is a simple approximation
        return i - 1
    }
    return i
}

# Round up to nearest integer (toward positive infinity)
fn ceil(n: float) -> int {
    # Simple truncation toward positive infinity
    let i: int = n.to_int()
    # to_int truncates toward zero, so for positive non-integers we need to add 1
    if n > 0.0 {
        return i + 1
    }
    return i
}

# Round to nearest integer (0.5 rounds away from zero)
fn round(n: float) -> int {
    if n >= 0.0 {
        return (n + 0.5).to_int()
    }
    return (n - 0.5).to_int()
}

