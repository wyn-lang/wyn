# ============================================================================
# Device Info
# ============================================================================

struct DeviceInfo {
    model: str
    manufacturer: str
    os_version: str
    screen_width: int
    screen_height: int
    pixel_ratio: float
    is_tablet: bool
}

fn get_device_info() -> DeviceInfo {
    # Requires: Native device APIs
    return DeviceInfo{
        model: "",
        manufacturer: "",
        os_version: "",
        screen_width: 0,
        screen_height: 0,
        pixel_ratio: 1.0,
        is_tablet: false
    }
}

fn screen_size() -> (int, int) {
    let info: DeviceInfo = get_device_info()
    return (info.screen_width, info.screen_height)
}

fn is_tablet() -> bool {
    return get_device_info().is_tablet
}

