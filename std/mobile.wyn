# ============================================================================
# Platform Detection
# ============================================================================

# Check current platform
fn is_ios() -> bool {
    # Compile-time constant
    return false
}

fn is_android() -> bool {
    # Compile-time constant
    return false
}

fn platform() -> str {
    if is_ios() { return "ios" }
    if is_android() { return "android" }
    return "unknown"
}

fn os_version() -> str {
    return mobile_os_version()
}

