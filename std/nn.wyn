# ============================================================================
# Dropout
# ============================================================================

# Dropout (training mode)
fn dropout(x: gpu.Tensor, rate: float) -> gpu.Tensor {
    # Implemented via GPU backend
    # Randomly zeros elements with probability `rate`
    # Scales remaining by 1/(1-rate)
    return x
}

# Dropout 2D (drops entire channels)
fn dropout2d(x: gpu.Tensor, rate: float) -> gpu.Tensor {
    # Implemented via GPU backend
    return x
}

# ============================================================================
# Loss Functions
# ============================================================================

# Mean squared error
fn mse_loss(pred: gpu.Tensor, target: gpu.Tensor) -> float {
    # Implemented via GPU backend
    return 0.0
}

# Cross entropy loss
fn cross_entropy_loss(pred: gpu.Tensor, target: gpu.Tensor) -> float {
    # Implemented via GPU backend
    # pred: [batch, num_classes] (logits, not softmax)
    # target: [batch] (class indices)
    return 0.0
}

# Binary cross entropy
fn bce_loss(pred: gpu.Tensor, target: gpu.Tensor) -> float {
    # Implemented via GPU backend
    return 0.0
}

# Binary cross entropy with logits
fn bce_with_logits_loss(pred: gpu.Tensor, target: gpu.Tensor) -> float {
    # Implemented via GPU backend
    return 0.0
}

# L1 loss (mean absolute error)
fn l1_loss(pred: gpu.Tensor, target: gpu.Tensor) -> float {
    # Implemented via GPU backend
    return 0.0
}

# Smooth L1 loss (Huber loss)
fn smooth_l1_loss(pred: gpu.Tensor, target: gpu.Tensor, beta: float) -> float {
    # Implemented via GPU backend
    return 0.0
}

# ============================================================================
# Attention
# ============================================================================

# Scaled dot-product attention
fn attention(query: gpu.Tensor, key: gpu.Tensor, value: gpu.Tensor, 
             mask: gpu.Tensor) -> gpu.Tensor {
    # Implemented via GPU backend
    # query, key, value: [batch, seq_len, d_model]
    # mask: [batch, seq_len, seq_len] or none
    # output: [batch, seq_len, d_model]
    return query
}

# Multi-head attention
fn multi_head_attention(query: gpu.Tensor, key: gpu.Tensor, value: gpu.Tensor,
                        num_heads: int, mask: gpu.Tensor) -> gpu.Tensor {
    # Implemented via GPU backend
    return query
}

# Flash attention (memory efficient)
fn flash_attention(query: gpu.Tensor, key: gpu.Tensor, value: gpu.Tensor,
                   mask: gpu.Tensor) -> gpu.Tensor {
    # Implemented via GPU backend
    return query
}

# ============================================================================
# Embedding
# ============================================================================

# Embedding lookup
fn embedding(indices: gpu.Tensor, weight: gpu.Tensor) -> gpu.Tensor {
    # Implemented via GPU backend
    # indices: [batch, seq_len] (integer indices)
    # weight: [vocab_size, embedding_dim]
    # output: [batch, seq_len, embedding_dim]
    return weight
}

# Positional encoding (sinusoidal)
fn positional_encoding(seq_len: int, d_model: int) -> gpu.Tensor {
    # Implemented via GPU backend
    return gpu.zeros()
}

# Rotary positional embedding (RoPE)
fn rotary_embedding(x: gpu.Tensor, seq_len: int) -> gpu.Tensor {
    # Implemented via GPU backend
    return x
}

# ============================================================================
# Linear / Dense
# ============================================================================

# Linear layer: y = x @ W^T + b
fn linear(x: gpu.Tensor, weight: gpu.Tensor, bias: gpu.Tensor) -> gpu.Tensor {
    # Implemented via GPU backend
    return x
}

# Linear without bias
fn linear_no_bias(x: gpu.Tensor, weight: gpu.Tensor) -> gpu.Tensor {
    # Implemented via GPU backend
    return x
}

# ============================================================================
# Utility
# ============================================================================

# One-hot encoding
fn one_hot(indices: gpu.Tensor, num_classes: int) -> gpu.Tensor {
    # Implemented via GPU backend
    return gpu.zeros()
}

# Pad tensor
fn pad(x: gpu.Tensor, padding: [int], value: float) -> gpu.Tensor {
    # Implemented via GPU backend
    return x
}

# Unfold (extract sliding windows)
fn unfold(x: gpu.Tensor, kernel_size: int, stride: int) -> gpu.Tensor {
    # Implemented via GPU backend
