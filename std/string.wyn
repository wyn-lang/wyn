# Join array of strings with newline
fn join_lines(lines: [str]) -> str {
    return join(lines, "\n")
}

# Split string by character
fn split_by_char(s: str, delim: str) -> [str] {
    if s.len() == 0 { return [] }
    let mut result: [str] = []
    let mut current: str = ""
    let mut i: int = 0
    while i < s.len() {
        let c: str = s[i:i+1]
        if c == delim {
            result = result + [current]
            current = ""
        } else {
            current = current + c
        }
        i = i + 1
    }
    result = result + [current]
    return result
}

# Replace all occurrences of old with new
fn replace_all(s: str, old: str, new: str) -> str {
    if old.len() == 0 { return s }
    let mut result: str = ""
    let mut i: int = 0
    while i < s.len() {
        if i <= s.len() - old.len() and s[i:i+old.len()] == old {
            result = result + new
            i = i + old.len()
        } else {
            result = result + s[i:i+1]
            i = i + 1
        }
    }
    return result
}

# Remove all occurrences of substring
fn remove_all(s: str, substr: str) -> str {
    return replace_all(s, substr, "")
}

# Check if string contains only spaces
fn is_blank(s: str) -> bool {
    if s.len() == 0 { return true }
    let mut i: int = 0
    while i < s.len() {
        if s[i:i+1] != " " {
            return false
        }
        i = i + 1
    }
    return true
}

# Normalize whitespace (collapse multiple spaces to one)
fn normalize_whitespace(s: str) -> str {
    let mut result: str = ""
    let mut prev_space: bool = false
    let mut i: int = 0
    while i < s.len() {
        let c: str = s[i:i+1]
        if c == " " or c == "\t" or c == "\n" {
            if not prev_space {
                result = result + " "
                prev_space = true
            }
        } else {
            result = result + c
            prev_space = false
        }
        i = i + 1
    }
    return trim(result)
}

# Abbreviate string to max length with ellipsis in middle
fn abbreviate_middle(s: str, max_len: int) -> str {
    if s.len() <= max_len { return s }
    if max_len <= 3 { return s[:max_len] }
    let half: int = (max_len - 3) / 2
    return s[:half] + "..." + s[s.len() - half:]
}

# Common prefix of two strings
fn common_prefix(a: str, b: str) -> str {
    let min_len: int = if a.len() < b.len() then a.len() else b.len()
    let mut i: int = 0
    while i < min_len and a[i:i+1] == b[i:i+1] {
        i = i + 1
    }
    return a[:i]
}

# Common suffix of two strings
fn common_suffix(a: str, b: str) -> str {
    let min_len: int = if a.len() < b.len() then a.len() else b.len()
    let mut i: int = 0
    while i < min_len and a[a.len()-1-i:a.len()-i] == b[b.len()-1-i:b.len()-i] {
        i = i + 1
    }
    return a[a.len()-i:]
}

# Check if string is title case
fn is_title_case(s: str) -> bool {
    if s.len() == 0 { return false }
    let words: [str] = split_by_char(s, " ")
    let mut i: int = 0
    while i < words.len() {
        let word: str = words[i]
        if word.len() > 0 {
            let first: str = word[0:1]
            if not (first >= "A" and first <= "Z") {
                return false
            }
        }
        i = i + 1
    }
    return true
}

# Repeat string with separator
fn repeat_with_sep(s: str, count: int, sep: str) -> str {
    if count <= 0 { return "" }
    let mut result: str = s
    let mut i: int = 1
    while i < count {
        result = result + sep + s
        i = i + 1
    }
    return result
}

# Count vowels in string
fn count_vowels(s: str) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < s.len() {
        let c: str = to_lower_str(s[i:i+1])
        if c == "a" or c == "e" or c == "i" or c == "o" or c == "u" {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

# Count consonants in string
fn count_consonants(s: str) -> int {
    let mut count: int = 0
    let mut i: int = 0
    while i < s.len() {
        let c: str = to_lower_str(s[i:i+1])
        if (c >= "a" and c <= "z") and not (c == "a" or c == "e" or c == "i" or c == "o" or c == "u") {
            count = count + 1
        }
        i = i + 1
    }
    return count
}


