# Check if string is a valid email (basic check)
fn is_valid_email(s: str) -> bool {
    let at_idx: int = index_of(s, "@")
    if at_idx == 0 - 1 {
        return false
    }
    if at_idx == 0 or at_idx == s.len() - 1 {
        return false
    }
    let dot_idx: int = last_index_of(s, ".")
    if dot_idx == 0 - 1 {
        return false
    }
    return dot_idx > at_idx and dot_idx < s.len() - 1
}

# Check if string is a valid URL (basic check)
fn is_valid_url(s: str) -> bool {
    return starts_with(s, "http://") or starts_with(s, "https://")
}

# Extract substring between two delimiters
fn substring_between(s: str, start_delim: str, end_delim: str) -> ?str {
    let start_idx: int = index_of(s, start_delim)
    if start_idx == 0 - 1 {
        return none
    }
    let search_start: int = start_idx + start_delim.len()
    let remaining: str = s[search_start:]
    let end_idx: int = index_of(remaining, end_delim)
    if end_idx == 0 - 1 {
        return none
    }
    return some(remaining[:end_idx])
}

# Levenshtein distance between two strings
fn levenshtein_distance(a: str, b: str) -> int {
    let alen: int = a.len()
    let blen: int = b.len()
    if alen == 0 { return blen }
    if blen == 0 { return alen }
    let mut prev: int = 0
    let mut curr: int = 0
    let mut i: int = 0
    while i <= alen {
        let mut j: int = 0
        while j <= blen {
            if i == 0 {
                curr = j
            } else if j == 0 {
                curr = i
            } else {
                let cost: int = if a[i-1:i] == b[j-1:j] then 0 else 1
                let del: int = prev + 1
                let ins: int = curr + 1
                let sub: int = prev + cost
                curr = min(min(del, ins), sub)
            }
            prev = curr
            j = j + 1
        }
        i = i + 1
    }
    return curr
}

# Swap case of all letters
fn swap_case(s: str) -> str {
    let mut result: str = ""
    let mut i: int = 0
    while i < s.len() {
        let c: str = s[i:i+1]
        let code: int = ord(c)
        if code >= 65 and code <= 90 {
            result = result + chr(code + 32)
        } else if code >= 97 and code <= 122 {
            result = result + chr(code - 32)
        } else {
            result = result + c
        }
        i = i + 1
    }
    return result
}

# Check if string matches a simple wildcard pattern (* and ?)
fn matches_wildcard(s: str, pattern: str) -> bool {
    if pattern == "*" { return true }
    if pattern.len() == 0 { return s.len() == 0 }
    if s.len() == 0 { return pattern.len() == 0 }
    let p_first: str = pattern[0:1]
    if p_first == "*" {
        return matches_wildcard(s, pattern[1:]) or matches_wildcard(s[1:], pattern)
    }
    if p_first == "?" or p_first == s[0:1] {
        return matches_wildcard(s[1:], pattern[1:])
    }
    return false
}

# Convert string to URL-friendly slug (lowercase, spaces to hyphens)
fn slugify(s: str) -> str {
    let lower: str = to_lower_str(s)
    let mut result: str = ""
    let mut i: int = 0
    while i < lower.len() {
        let c: str = lower[i:i+1]
        let code: int = ord(c)
        if (code >= 97 and code <= 122) or (code >= 48 and code <= 57) {
            result = result + c
        } else if c == " " or c == "_" {
            result = result + "-"
        }
        i = i + 1
    }
    return result
}

# Check if string contains only ASCII characters (0-127)
fn is_ascii(s: str) -> bool {
    let mut i: int = 0
    while i < s.len() {
        if ord(s[i:i+1]) > 127 {
            return false
        }
        i = i + 1
    }
    return true
}

# Hamming distance between two strings (must be same length)
fn hamming_distance(a: str, b: str) -> ?int {
    if a.len() != b.len() {
        return none
    }
    let mut dist: int = 0
    let mut i: int = 0
    while i < a.len() {
        if a[i:i+1] != b[i:i+1] {
            dist = dist + 1
        }
        i = i + 1
    }
    return some(dist)
}

# Indent each line with given prefix
fn indent(s: str, prefix: str) -> str {
    if s.len() == 0 { return s }
    let mut result: str = prefix
    let mut i: int = 0
    while i < s.len() {
        let c: str = s[i:i+1]
        result = result + c
        if c == "\n" and i < s.len() - 1 {
            result = result + prefix
        }
        i = i + 1
    }
    return result
}

# Remove all occurrences of character from string
fn remove_char(s: str, ch: str) -> str {
    let mut result: str = ""
    let mut i: int = 0
    while i < s.len() {
        if s[i:i+1] != ch {
            result = result + s[i:i+1]
        }
        i = i + 1
    }
    return result
}

