        if s[i:i + sublen] == substr {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

# Count occurrences of substring
fn count_substr(s: str, substr: str) -> int {
    let slen: int = s.len()
    let sublen: int = substr.len()
    if sublen > slen or sublen == 0 {
        return 0
    }
    let mut count: int = 0
    let mut i: int = 0
    while i <= slen - sublen {
        if s[i:i + sublen] == substr {
            count = count + 1
            i = i + sublen
        } else {
            i = i + 1
        }
    }
    return count
}

