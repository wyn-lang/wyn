# Keep only characters that match predicate
fn filter_chars(s: str, keep_digits: bool) -> str {
    let mut result: str = ""
    let mut i: int = 0
    while i < s.len() {
        let c: str = s[i:i+1]
        let is_digit: bool = c >= "0" and c <= "9"
        if keep_digits == is_digit {
            result = result + c
        }
        i = i + 1
    }
    return result
}

# Extract only digits from string
fn extract_digits(s: str) -> str {
    return filter_chars(s, true)
}

# Extract only letters from string
fn extract_letters(s: str) -> str {
    let mut result: str = ""
    let mut i: int = 0
    while i < s.len() {
        let c: str = to_lower_str(s[i:i+1])
        if c >= "a" and c <= "z" {
            result = result + s[i:i+1]
        }
        i = i + 1
    }
    return result
}

