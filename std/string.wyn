# Simple string hash (djb2 algorithm)
fn hash_string(s: str) -> int {
    let mut hash: int = 5381
    let mut i: int = 0
    while i < s.len() {
        let c: int = ord(s[i:i+1])
        hash = ((hash << 5) + hash) + c
        i = i + 1
    }
    return hash
}
