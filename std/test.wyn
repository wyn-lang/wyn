# Assert string does not contain substring
fn assert_not_contains(s: str, substr: str, msg: str) {
    let found: bool = false
    const slen: int = s.len()
    const sublen: int = substr.len()
    let i: int = 0
    while i <= slen - sublen {
        if s[i:i+sublen] == substr {
            found = true
        }
        i = i + 1
    }
    if found {
        print("ASSERTION FAILED: " + msg + " (\"" + s + "\" contains \"" + substr + "\")\n")
        exit(1)
    }
}

# Assert array contains value
fn assert_array_contains(arr: [int], value: int, msg: str) {
    let found: bool = false
    let i: int = 0
    while i < arr.len() {
        if arr[i] == value {
            found = true
        }
        i = i + 1
    }
    if not found {
        print("ASSERTION FAILED: " + msg + " (array does not contain ")
        print(value)
        print(")\n")
        exit(1)
    }
}

# Assert value is in range [min, max]
fn assert_in_range(value: int, min_val: int, max_val: int, msg: str) {
    if value < min_val or value > max_val {
        print("ASSERTION FAILED: " + msg + " (")
        print(value)
        print(" not in range [")
        print(min_val)
        print(", ")
        print(max_val)
        print("])\n")
        exit(1)
    }
}

# Assert value is greater than threshold
fn assert_greater(value: int, threshold: int, msg: str) {
    if value <= threshold {
        print("ASSERTION FAILED: " + msg + " (")
        print(value)
        print(" not greater than ")
        print(threshold)
        print(")\n")
        exit(1)
    }
}

# Assert value is less than threshold
fn assert_less(value: int, threshold: int, msg: str) {
    if value >= threshold {
        print("ASSERTION FAILED: " + msg + " (")
        print(value)
        print(" not less than ")
        print(threshold)
        print(")\n")
        exit(1)
    }
}

# Assert value is between min and max (exclusive)
fn assert_between(value: int, min_val: int, max_val: int, msg: str) {
    if value <= min_val or value >= max_val {
        print("ASSERTION FAILED: " + msg + " (")
        print(value)
        print(" not between ")
        print(min_val)
        print(" and ")
        print(max_val)
        print(")\n")
        exit(1)
    }
}

# Assert string is not empty
fn assert_not_empty(s: str, msg: str) {
    if s.len() == 0 {
        print("ASSERTION FAILED: " + msg + " (string is empty)\n")
        exit(1)
    }
}

# Assert array is not empty
fn assert_array_not_empty[T](arr: [T], msg: str) {
    if arr.len() == 0 {
        print("ASSERTION FAILED: " + msg + " (array is empty)\n")
        exit(1)
    }
}

