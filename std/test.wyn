# std/test.wyn
# Testing framework for unit tests

# Assert a condition is true, exit with error if false
fn check(condition: bool, msg: str) {
    if not condition {
        print("ASSERTION FAILED: " + msg + "\n")
        exit(1)
    }
}

# Assert a condition is true
fn assert_true(condition: bool, msg: str) {
    if not condition {
        print("ASSERTION FAILED (expected true): " + msg + "\n")
        exit(1)
    }
}

# Assert a condition is false
fn assert_false(condition: bool, msg: str) {
    if condition {
        print("ASSERTION FAILED (expected false): " + msg + "\n")
        exit(1)
    }
}

# Assert two integers are equal
fn assert_eq(a: int, b: int, msg: str) {
    if a != b {
        print("ASSERTION FAILED: " + msg + " (expected ")
        print(b)
        print(", got ")
        print(a)
        print(")\n")
        exit(1)
    }
}

# Assert two integers are not equal
fn assert_ne(a: int, b: int, msg: str) {
    if a == b {
        print("ASSERTION FAILED: " + msg + " (values should not be equal: ")
        print(a)
        print(")\n")
        exit(1)
    }
}

# Assert two strings are equal
fn assert_eq_str(a: str, b: str, msg: str) {
    if a != b {
        print("ASSERTION FAILED: " + msg + " (expected \"" + b + "\", got \"" + a + "\")\n")
        exit(1)
    }
}

# Assert two strings are not equal
fn assert_ne_str(a: str, b: str, msg: str) {
    if a == b {
        print("ASSERTION FAILED: " + msg + " (strings should not be equal: \"" + a + "\")\n")
        exit(1)
    }
}

# Assert an integer is greater than another
fn assert_gt(a: int, b: int, msg: str) {
    if a <= b {
        print("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print(" > ")
        print(b)
        print(")\n")
        exit(1)
    }
}

# Assert an integer is less than another
fn assert_lt(a: int, b: int, msg: str) {
    if a >= b {
        print("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print(" < ")
        print(b)
        print(")\n")
        exit(1)
    }
}

# Assert an integer is greater than or equal to another
fn assert_ge(a: int, b: int, msg: str) {
    if a < b {
        print("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print(" >= ")
        print(b)
        print(")\n")
        exit(1)
    }
}

# Assert an integer is less than or equal to another
fn assert_le(a: int, b: int, msg: str) {
    if a > b {
        print("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print(" <= ")
        print(b)
        print(")\n")
        exit(1)
    }
}

# Mark a test as passed
fn pass(msg: str) {
    print("PASS: " + msg + "\n")
}

# Mark a test as failed and exit
fn fail(msg: str) {
    print("FAIL: " + msg + "\n")
    exit(1)
}

# Assert two floats are approximately equal (within epsilon)
fn assert_eq_float(a: float, b: float, epsilon: float, msg: str) {
    const diff: float = a - b
    const abs_diff: float = if diff < 0.0 then 0.0 - diff else diff
    if abs_diff > epsilon {
        print("ASSERTION FAILED: " + msg + " (expected ")
        print(b.to_str())
        print(", got ")
        print(a.to_str())
        print(", diff ")
        print(abs_diff.to_str())
        print(")\n")
        exit(1)
    }
}

# Assert array lengths are equal
fn assert_len_eq(arr: [int], expected: int, msg: str) {
    const actual: int = arr.len()
    if actual != expected {
        print("ASSERTION FAILED: " + msg + " (expected length ")
        print(expected)
        print(", got ")
        print(actual)
        print(")\n")
        exit(1)
    }
}

# Assert optional has a value
fn assert_some(opt: ?int, msg: str) {
    match opt {
        some(_) => {}
        none => {
            print("ASSERTION FAILED: " + msg + " (expected some, got none)\n")
            exit(1)
        }
    }
}

# Assert optional is none
fn assert_none(opt: ?int, msg: str) {
    match opt {
        some(v) => {
            print("ASSERTION FAILED: " + msg + " (expected none, got some(")
            print(v)
            print("))\n")
            exit(1)
        }
        none => {}
    }
}

# Assert Result is ok
fn assert_ok[T, E](result: Result[T, E], msg: str) {
    match result {
        ok(_) => {}
        err(_) => {
            print("ASSERTION FAILED: " + msg + " (expected ok, got err)\n")
            exit(1)
        }
    }
}

