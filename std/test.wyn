# std/test.wyn
# Testing framework for unit tests

# Assert a condition is true, exit with error if false
fn assert(condition: bool, msg: str) -> () {
    if not condition {
        print_str("ASSERTION FAILED: " + msg + "\n")
        exit(1)
    }
    return ()
}

# Assert a condition is true
fn assert_true(condition: bool, msg: str) -> () {
    if not condition {
        print_str("ASSERTION FAILED (expected true): " + msg + "\n")
        exit(1)
    }
    return ()
}

# Assert a condition is false
fn assert_false(condition: bool, msg: str) -> () {
    if condition {
        print_str("ASSERTION FAILED (expected false): " + msg + "\n")
        exit(1)
    }
    return ()
}

# Assert two integers are equal
fn assert_eq(a: int, b: int, msg: str) -> () {
    if a != b {
        print_str("ASSERTION FAILED: " + msg + " (expected ")
        print(b)
        print_str(", got ")
        print(a)
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Assert two integers are not equal
fn assert_ne(a: int, b: int, msg: str) -> () {
    if a == b {
        print_str("ASSERTION FAILED: " + msg + " (values should not be equal: ")
        print(a)
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Assert two strings are equal
fn assert_eq_str(a: str, b: str, msg: str) -> () {
    if a != b {
        print_str("ASSERTION FAILED: " + msg + " (expected \"" + b + "\", got \"" + a + "\")\n")
        exit(1)
    }
    return ()
}

# Assert two strings are not equal
fn assert_ne_str(a: str, b: str, msg: str) -> () {
    if a == b {
        print_str("ASSERTION FAILED: " + msg + " (strings should not be equal: \"" + a + "\")\n")
        exit(1)
    }
    return ()
}

# Assert an integer is greater than another
fn assert_gt(a: int, b: int, msg: str) -> () {
    if a <= b {
        print_str("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print_str(" > ")
        print(b)
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Assert an integer is less than another
fn assert_lt(a: int, b: int, msg: str) -> () {
    if a >= b {
        print_str("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print_str(" < ")
        print(b)
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Assert an integer is greater than or equal to another
fn assert_ge(a: int, b: int, msg: str) -> () {
    if a < b {
        print_str("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print_str(" >= ")
        print(b)
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Assert an integer is less than or equal to another
fn assert_le(a: int, b: int, msg: str) -> () {
    if a > b {
        print_str("ASSERTION FAILED: " + msg + " (expected ")
        print(a)
        print_str(" <= ")
        print(b)
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Mark a test as passed
fn pass(msg: str) -> () {
    print_str("PASS: " + msg + "\n")
    return ()
}

# Mark a test as failed and exit
fn fail(msg: str) -> () {
    print_str("FAIL: " + msg + "\n")
    exit(1)
    return ()
}

# Assert two floats are approximately equal (within epsilon)
fn assert_eq_float(a: float, b: float, epsilon: float, msg: str) -> () {
    let diff: float = a - b
    let abs_diff: float = if diff < 0.0 then 0.0 - diff else diff
    if abs_diff > epsilon {
        print_str("ASSERTION FAILED: " + msg + " (expected ")
        print_str(b.to_str())
        print_str(", got ")
        print_str(a.to_str())
        print_str(", diff ")
        print_str(abs_diff.to_str())
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Assert array lengths are equal
fn assert_len_eq(arr: [int], expected: int, msg: str) -> () {
    let actual: int = arr.len()
    if actual != expected {
        print_str("ASSERTION FAILED: " + msg + " (expected length ")
        print(expected)
        print_str(", got ")
        print(actual)
        print_str(")\n")
        exit(1)
    }
    return ()
}

# Assert optional has a value
fn assert_some(opt: ?int, msg: str) -> () {
    match opt {
        some(_) => return ()
        none => {
            print_str("ASSERTION FAILED: " + msg + " (expected some, got none)\n")
            exit(1)
        }
    }
}

# Assert optional is none
fn assert_none(opt: ?int, msg: str) -> () {
    match opt {
        some(v) => {
            print_str("ASSERTION FAILED: " + msg + " (expected none, got some(")
            print(v)
            print_str("))\n")
            exit(1)
        }
        none => return ()
    }
}

