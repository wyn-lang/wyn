# std/test.wyn
# Testing framework

fn assert(condition: bool, msg: str) -> () {
    if not condition {
        print_str("ASSERTION FAILED: " + msg + "\n")
        exit(1)
    }
    return ()
}

fn assert_true(condition: bool, msg: str) -> () {
    if not condition {
        print_str("ASSERTION FAILED (expected true): " + msg + "\n")
        exit(1)
    }
    return ()
}

fn assert_false(condition: bool, msg: str) -> () {
    if condition {
        print_str("ASSERTION FAILED (expected false): " + msg + "\n")
        exit(1)
    }
    return ()
}

fn assert_eq(a: int, b: int, msg: str) -> () {
    if a != b {
        print_str("ASSERTION FAILED: " + msg + " (expected ")
        print(b)
        print_str(", got ")
        print(a)
        print_str(")\n")
        exit(1)
    }
    return ()
}

fn assert_ne(a: int, b: int, msg: str) -> () {
    if a == b {
        print_str("ASSERTION FAILED: " + msg + " (values should not be equal: ")
        print(a)
        print_str(")\n")
        exit(1)
    }
    return ()
}

fn assert_eq_str(a: str, b: str, msg: str) -> () {
    if a != b {
        print_str("ASSERTION FAILED: " + msg + " (expected \"" + b + "\", got \"" + a + "\")\n")
        exit(1)
    }
    return ()
}

fn assert_ne_str(a: str, b: str, msg: str) -> () {
    if a == b {
        print_str("ASSERTION FAILED: " + msg + " (strings should not be equal: \"" + a + "\")\n")
        exit(1)
    }
    return ()
}

fn pass(msg: str) -> () {
    print_str("PASS: " + msg + "\n")
    return ()
}

fn fail(msg: str) -> () {
    print_str("FAIL: " + msg + "\n")
    exit(1)
    return ()
}
