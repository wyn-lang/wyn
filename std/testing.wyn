# std/testing.wyn
# Testing framework
# All functions are mapped to runtime implementations via compiler

# Assertions:
#   testing.assert_eq(actual: int, expected: int, message: str) -> int
#   testing.assert_ne(actual: int, expected: int, message: str) -> int
#   testing.assert_true(value: int, message: str) -> int
#   testing.assert_false(value: int, message: str) -> int

# Summary:
#   testing.summary() -> int  // Print test results summary
