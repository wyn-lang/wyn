# Wyn Standard Library - TUI Module
# Terminal User Interface framework
#
# Requires: Terminal control (ANSI escape codes, termios)
# Stage 1: Will use native terminal APIs

# ============================================================================
# Core Types
# ============================================================================

struct Style {
    fg: Color
    bg: Color
    bold: bool
    italic: bool
    underline: bool
}

struct Color {
    code: int  # ANSI color code or RGB
    is_rgb: bool
    r: int
    g: int
    b: int
}

struct Size {
    width: int
    height: int
}

struct Position {
    row: int
    col: int
}

# ============================================================================
# Color Constants
# ============================================================================

fn default_color() -> Color { return Color{code: 0, is_rgb: false, r: 0, g: 0, b: 0} }
fn black() -> Color { return Color{code: 30, is_rgb: false, r: 0, g: 0, b: 0} }
fn red() -> Color { return Color{code: 31, is_rgb: false, r: 0, g: 0, b: 0} }
fn green() -> Color { return Color{code: 32, is_rgb: false, r: 0, g: 0, b: 0} }
fn yellow() -> Color { return Color{code: 33, is_rgb: false, r: 0, g: 0, b: 0} }
fn blue() -> Color { return Color{code: 34, is_rgb: false, r: 0, g: 0, b: 0} }
fn magenta() -> Color { return Color{code: 35, is_rgb: false, r: 0, g: 0, b: 0} }
fn cyan() -> Color { return Color{code: 36, is_rgb: false, r: 0, g: 0, b: 0} }
fn white() -> Color { return Color{code: 37, is_rgb: false, r: 0, g: 0, b: 0} }

fn rgb(r: int, g: int, b: int) -> Color {
    return Color{code: 0, is_rgb: true, r: r, g: g, b: b}
}

fn default_style() -> Style {
    return Style{
        fg: default_color(),
        bg: default_color(),
        bold: false,
        italic: false,
        underline: false
    }
}

# ============================================================================
# Application Lifecycle
# ============================================================================

# Initialize and run a TUI application
# Requires: Terminal raw mode
fn app(main_fn: fn()) {
    enter_raw_mode()
    clear()
    hide_cursor()
    main_fn()
    show_cursor()
    exit_raw_mode()
}

# Enter raw mode (disable line buffering)
