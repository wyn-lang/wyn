# std/validate.wyn
# String validation utilities

# Check if character is a digit (0-9)
fn is_digit(c: str) -> bool {
    if c.len() != 1 {
        return false
    }
    let code: int = ord(c[0])
    if code < 48 {
        return false
    }
    if code > 57 {
        return false
    }
    return true
}

# Check if character is alphabetic (a-z, A-Z)
fn is_alpha(c: str) -> bool {
    if c.len() != 1 {
        return false
    }
    let code: int = ord(c[0])
    if code >= 65 {
        if code <= 90 {
            return true
        }
    }
    if code >= 97 {
        if code <= 122 {
            return true
        }
    }
    return false
}

# Check if character is alphanumeric (a-z, A-Z, 0-9)
fn is_alnum(c: str) -> bool {
    if is_alpha(c) {
        return true
    }
    return is_digit(c)
}

# Check if string is a valid email (basic check: has @ and . after @)
fn is_email(s: str) -> bool {
    if s.len() < 3 {
        return false
    }
    
    let mut at_pos: int = -1
    let mut i: int = 0
    while i < s.len() {
        if s[i:i+1] == "@" {
            if at_pos != -1 {
                return false
            }
            at_pos = i
        }
        i = i + 1
    }
    
    if at_pos <= 0 {
        return false
    }
    if at_pos >= s.len() - 2 {
        return false
    }
    
    let mut has_dot: bool = false
    let mut j: int = at_pos + 1
    while j < s.len() {
        if s[j:j+1] == "." {
            if j > at_pos + 1 {
                has_dot = true
            }
        }
        j = j + 1
    }
    
    return has_dot
}

# Check if string is a valid IPv4 address (xxx.xxx.xxx.xxx)
fn is_ipv4(s: str) -> bool {
    if s.len() < 7 {
        return false
    }
    
    let mut parts: int = 0
    let mut num_str: str = ""
    let mut i: int = 0
    
    while i <= s.len() {
        let c: str = if i < s.len() then s[i:i+1] else "."
        
        if c == "." {
            if num_str.len() == 0 {
                return false
            }
            if num_str.len() > 3 {
                return false
            }
            
            let num: int = str_to_int(num_str)
            if num < 0 {
                return false
            }
            if num > 255 {
                return false
            }
            
            parts = parts + 1
            num_str = ""
        } else if is_digit(c) {
            num_str = num_str + c
        } else {
            return false
        }
        
        i = i + 1
    }
    
    return parts == 4
}

# Check if string contains only hexadecimal characters (0-9, a-f, A-F)
fn is_hex(s: str) -> bool {
    if s.len() == 0 {
        return false
    }
    
    let mut i: int = 0
    while i < s.len() {
        let code: int = ord(s[i:i+1][0])
        let mut valid: bool = false
        
        if code >= 48 {
            if code <= 57 {
                valid = true
            }
        }
        if code >= 97 {
            if code <= 102 {
                valid = true
            }
        }
        if code >= 65 {
            if code <= 70 {
                valid = true
            }
        }
        
        if valid == false {
            return false
        }
        
        i = i + 1
    }
    
    return true
}

# Helper: Convert string to integer (returns -1 on error)
fn str_to_int(s: str) -> int {
    if s.len() == 0 {
        return -1
    }
    
    let mut result: int = 0
    let mut i: int = 0
    
    while i < s.len() {
        let c: str = s[i:i+1]
        if is_digit(c) == false {
            return -1
        }
        result = result * 10 + (ord(c[0]) - 48)
        i = i + 1
    }
    
    return result
}
