# Simple echo server to test tcp_listen and tcp_accept

fn main() {
    let listen_fd: int = tcp_listen(8888)
    
    if listen_fd < 0 {
        exit(1)
    }
    
    # Accept one connection
    let client_fd: int = tcp_accept(listen_fd)
    
    if client_fd < 0 {
        tcp_close(listen_fd)
        exit(1)
    }
    
    # Receive data
    let data: str = tcp_recv(client_fd, 1024)
    
    # Send it back
    tcp_send(client_fd, data)
    
    # Cleanup
    tcp_close(client_fd)
    tcp_close(listen_fd)
}
