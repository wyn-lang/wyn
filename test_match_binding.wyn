fn main() {
    print_str("=== Match Binding Tests ===")
    
    # Test 1: optional int
    print_str("Test 1: optional int")
    let maybe: ?int = some(42)
    match maybe {
        some(x) => {
            print_str("Got value:")
            print(x)
        }
        none => print_str("nothing")
    }
    
    # Test 2: optional string
    print_str("Test 2: optional string")
    let maybe_str: ?str = some("hello")
    match maybe_str {
        some(s) => {
            print_str("Got string:")
            print_str(s)
        }
        none => print_str("no string")
    }
    
    # Test 3: Result ok
    print_str("Test 3: Result ok")
    let result: Result[int, str] = ok(100)
    match result {
        ok(v) => {
            print_str("Success:")
            print(v)
        }
        err(e) => {
            print_str("Error:")
            print_str(e)
        }
    }
    
    # Test 4: Result err
    print_str("Test 4: Result err")
    let error_result: Result[int, str] = err("failed")
    match error_result {
        ok(v) => {
            print_str("Success:")
            print(v)
        }
        err(e) => {
            print_str("Error:")
            print_str(e)
        }
    }
    
    # Test 5: none case
    print_str("Test 5: none case")
    let nothing: ?int = none
    match nothing {
        some(x) => {
            print_str("Got value:")
            print(x)
        }
        none => print_str("Got none!")
    }
    
    print_str("=== All tests passed! ===")
}
