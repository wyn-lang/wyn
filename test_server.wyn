# Test tcp_listen and tcp_accept builtins

fn main() {
    # Create a listening socket on port 9999
    let listen_fd: int = tcp_listen(9999)
    
    if listen_fd < 0 {
        print(-1)
        print_newline()
        exit(1)
    }
    
    print(listen_fd)
    print_newline()
    
    # Note: tcp_accept would block waiting for a connection
    # So we just test that the listen socket was created successfully
    
    # Close the socket
    tcp_close(listen_fd)
    
    print(0)
    print_newline()
}
