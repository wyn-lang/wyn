fn main() {
    # Test str_concat
    let a: str = "Hello"
    let b: str = " World"
    let c: str = str_concat(a, b)
    print(c)
    
    # Test str_substr
    let s: str = "Hello World"
    let sub: str = str_substr(s, 0, 5)
    print(sub)
    
    # Test str_split
    let text: str = "one,two,three"
    let parts: [str] = str_split(text, ",")
    print(parts[0])
    print(parts[1])
    print(parts[2])
}
