fn main() {
    print_str("Time and networking builtins added successfully!\n")
    print_str("- time_now() -> int\n")
    print_str("- sleep_ms(ms: int)\n")
    print_str("- tcp_connect(host: str, port: int) -> int\n")
    print_str("- tcp_close(sock: int)\n")
    
    let now: int = time_now()
    print_str("Current timestamp: ")
    println(now)
    
    print_str("\nSleeping 200ms...\n")
    sleep_ms(200)
    print_str("Done!\n")
    
    print_str("\nNote: tcp_connect/tcp_close compile but need runtime testing\n")
}
