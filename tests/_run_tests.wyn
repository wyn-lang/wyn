import io

fn main() {
    print("=== Wyn Test Suite ===")
    print("")
    
    let passed: int = 0
    let total: int = 0
    
    # Auto-discover tests in tests/
    const test_files: [str] = io.list_dir("tests")
    let i: int = 0
    while i < test_files.len() {
        const file: str = test_files[i]
        const len: int = file.len()
        if len > 9 {
            const suffix: str = file[len - 9:len]
            if suffix == "_test.wyn" {
                passed = passed + run_test("tests/" + file, file)
                total = total + 1
            }
        }
        i = i + 1
    }
    
    # Auto-discover tests in examples/
    const example_files: [str] = io.list_dir("examples")
    let j: int = 0
    while j < example_files.len() {
        const file: str = example_files[j]
        const len: int = file.len()
        if len > 9 {
            const suffix: str = file[len - 9:len]
            if suffix == "_test.wyn" {
                passed = passed + run_test("examples/" + file, file)
                total = total + 1
            }
        }
        j = j + 1
    }
    
    const failed: int = total - passed
    
    print("")
    print("=== Results ===")
    print("Passed: " + int_to_str(passed))
    if failed > 0 {
        print("Failed: " + int_to_str(failed))
    }
}

fn run_test(path: str, name: str) -> int {
    const exe: str = "/tmp/wyn_test"
    const compile_cmd: str = "./build/stage0 -q -o " + exe + " " + path + " 2>/dev/null"
    const compile_result: int = system(compile_cmd)
    
    if compile_result != 0 {
        print("FAIL " + name)
        return 0
    }
    
    const run_cmd: str = exe + " >/dev/null 2>&1"
    const run_result: int = system(run_cmd)
    
    if run_result == 0 {
        print("PASS " + name)
        return 1
    } else {
        print("FAIL " + name)
        return 0
    }
}
