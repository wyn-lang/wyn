fn run_test(path: str) -> int {
    let parts: [str] = str_split(path, "/")
    let name: str = parts[parts.len() - 1]
    
    let exe: str = "/tmp/wyn_test"
    let compile_cmd: str = "./build/stage0 -q -o " + exe + " " + path + " 2>/dev/null"
    let compile_result: int = system(compile_cmd)
    
    if compile_result != 0 {
        print_str("FAIL ")
        print_str(name)
        print_newline()
        return 0
    }
    
    let run_cmd: str = exe + " >/dev/null 2>&1"
    let run_result: int = system(run_cmd)
    
    if run_result == 0 {
        print_str("PASS ")
        print_str(name)
        print_newline()
        return 1
    } else {
        print_str("FAIL ")
        print_str(name)
        print_newline()
        return 0
    }
}
