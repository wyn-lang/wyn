fn main() {
    # Basic arithmetic
    assert(1 + 2 == 3)
    assert(10 - 3 == 7)
    assert(4 * 5 == 20)
    assert(15 / 3 == 5)
    assert(17 % 5 == 2)
    assert(2 ** 10 == 1024)
    
    # Negative numbers
    assert(-5 + 3 == -2)
    assert(-5 * -3 == 15)
    
    # Precedence
    assert(2 + 3 * 4 == 14)
    assert((2 + 3) * 4 == 20)
    
    # Compound assignment
    let mut x: int = 10
    x += 5
    assert(x == 15)
    x -= 3
    assert(x == 12)
    x *= 2
    assert(x == 24)
    x /= 4
    assert(x == 6)
    
    print_str("arithmetic_test: PASS")
}
