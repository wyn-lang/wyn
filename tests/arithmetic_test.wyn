
import test
import io
fn main() {
    # Basic arithmetic
    test.assert(1 + 2 == 3)
    test.assert(10 - 3 == 7)
    test.assert(4 * 5 == 20)
    test.assert(15 / 3 == 5)
    test.assert(17 % 5 == 2)
    test.assert(2 ** 10 == 1024)
    
    # Negative numbers
    test.assert(-5 + 3 == -2)
    test.assert(-5 * -3 == 15)
    
    # Precedence
    test.assert(2 + 3 * 4 == 14)
    test.assert((2 + 3) * 4 == 20)
    
    # Compound assignment
    let x: int = 10
    x += 5
    test.assert(x == 15)
    x -= 3
    test.assert(x == 12)
    x *= 2
    test.assert(x == 24)
    x /= 4
    test.assert(x == 6)
    
    print("arithmetic_test: PASS")
}
