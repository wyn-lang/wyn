
fn main() {
    let results: [int] = []
    
    // Append from multiple spawns
    spawn {
        results.append(1)
    }
    spawn {
        results.append(2)
    }
    spawn {
        results.append(3)
    }
    
    // Wait for threads
    sleep_ms(1000)
    
    // Check that values were appended
    const final_len: int = results.len()
    assert(final_len == 3)
    
    print("✓ Array append with spawn test passed - ")
    print(final_len)
    print(" elements")
}
