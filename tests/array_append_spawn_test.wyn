fn main() {
    let results: [int] = []
    
    // Append from multiple spawns
    spawn {
        results.append(1)
    }
    spawn {
        results.append(2)
    }
    spawn {
        results.append(3)
    }
    
    // Wait for threads
    sleep(1)
    
    // Check that values were appended
    const final_len: int = len(results)
    assert(final_len == 3)
    
    print_str("✓ Array append with spawn test passed - ")
    print(final_len)
    print_str(" elements")
    print_newline()
}
