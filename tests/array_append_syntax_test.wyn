// Test: Array append with += operator

import array

fn test_plus_equals_operator() {
    let nums = []
    nums += 1
    nums += 2
    nums += 3
    print(nums.len())  // Should print: 3
}

fn test_plus_equals_in_loop() {
    let items = []
    for i in 0..5 {
        items += i
    }
    print(items.len())  // Should print: 5
}

fn main() {
    test_plus_equals_operator()
    test_plus_equals_in_loop()
    print("All tests passed!")
}
