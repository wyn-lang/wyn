// Test: Array bracket indexing with type inference

fn main() {
    // Test 1: Integer array indexing
    let nums = []
    nums.append(1)
    nums.append(2)
    nums.append(3)
    
    print(nums[0])  // 1
    print(nums[1])  // 2
    print(nums[2])  // 3
    
    // Test 2: String array indexing
    let names = []
    names.append("Alice")
    names.append("Bob")
    names.append("Charlie")
    
    print(names[0])  // Alice
    print(names[1])  // Bob
    print(names[2])  // Charlie
}
