import array

fn array.append(self, item: int) -> array {
    return array.append(self, item)
}

fn main() {
    # Test basic extension method
    var s = [1, 2, 3]
    s = s.append(4)
    
    if s.len() != 4 {
        print("ERROR: Expected length 4, got", s.len())
        return
    }
    
    if s.get(3) != 4 {
        print("ERROR: Expected element 4 at index 3, got", s.get(3))
        return
    }
    
    # Test method chaining
    s = s.append(5).append(6)
    
    if s.len() != 6 {
        print("ERROR: Expected length 6 after chaining, got", s.len())
        return
    }
    
    if s.get(4) != 5 {
        print("ERROR: Expected element 5 at index 4, got", s.get(4))
        return
    }
    
    if s.get(5) != 6 {
        print("ERROR: Expected element 6 at index 5, got", s.get(5))
        return
    }
    
    print("✓ Array extension method test passed")
}