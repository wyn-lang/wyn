fn main() {
    const content: str = "line1\nline2\nline3"
    const lines: [str] = str_split(content, "\n")
    
    // Direct access works
    io.print("Direct: ")
    io.print(lines[0])
    io.print("")
    
    // Loop access should work
    io.print("Loop:\n")
    let i: int = 0
    while i < lines.len() {
        const line: str = lines[i]
        io.print(line)
        io.print("")
        i = i + 1
    }
    
    io.print("Test passed!")
    io.print("")
}
