
import string

fn main() {
    const content: str = "line1\nline2\nline3"
    const lines: [str] = string.split(content, "\n")
    
    // Direct access works
    print("Direct: ")
    print(lines[0])
    print("")
    
    // Loop access should work
    print("Loop:\n")
    let i: int = 0
    while i < lines.len() {
        const line: str = lines[i]
        print(line)
        print("")
        i = i + 1
    }
    
    print("Test passed!")
    print("")
}
