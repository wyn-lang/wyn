import array

fn main() {
    print("Testing array methods...")
    
    // Test using module functions (which work)
    const arr = [1, 2, 3]
    const rev = array.reverse(arr)
    print(rev.get(0))  // Should be 3
    print(rev.get(1))  // Should be 2
    print(rev.get(2))  // Should be 1
    
    // Test append
    const arr2 = [1, 2, 3]
    const with_four = array.append(arr2, 4)
    print(with_four.len())  // Should be 4
    print(with_four.get(3))  // Should be 4
    
    print("Array methods work!")
}
