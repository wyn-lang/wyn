fn main() {
    let arr: [int] = [1, 2, 3, 4, 5]
    
    # Length
    assert(len(arr) == 5)
    
    # Indexing
    assert(arr[0] == 1)
    assert(arr[4] == 5)
    assert(arr[-1] == 5)
    assert(arr[-2] == 4)
    
    # Slicing
    let slice: [int] = arr[1:3]
    assert(len(slice) == 2)
    assert(slice[0] == 2)
    assert(slice[1] == 3)
    
    # Slice from start
    let first: [int] = arr[:2]
    assert(len(first) == 2)
    assert(first[0] == 1)
    
    # Slice to end
    let last: [int] = arr[3:]
    assert(len(last) == 2)
    assert(last[0] == 4)
    
    # Iteration
    let mut sum: int = 0
    for item in arr {
        sum += item
    }
    assert(sum == 15)
    
    print_str("array_test: PASS")
}
