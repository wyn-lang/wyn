import io

fn main() {
    const arr: [int] = [1, 2, 3, 4, 5]
    
    # Length - using method
    assert(arr.len() == 5)
    
    # Indexing
    assert(arr[0] == 1)
    assert(arr[4] == 5)
    assert(arr[-1] == 5)
    assert(arr[-2] == 4)
    
    # Slicing
    const slice: [int] = arr[1:3]
    assert(slice.len() == 2)
    assert(slice[0] == 2)
    assert(slice[1] == 3)
    
    # Slice from start
    const first: [int] = arr[:2]
    assert(first.len() == 2)
    assert(first[0] == 1)
    
    # Slice to end
    const last: [int] = arr[3:]
    assert(last.len() == 2)
    assert(last[0] == 4)
    
    # Iteration
    let sum: int = 0
    for item in arr {
        sum += item
    }
    assert(sum == 15)
    
    print("array_test: PASS")
}
