import atomic

fn main() {
    // Test atomic add
    const counter: int = 0
    
    const old1: int = atomic.add(&counter, 5)
    if old1 != 0 {
        print("FAIL: atomic_add should return old value 0")
        exit(1)
    }
    
    const val1: int = atomic.load(&counter)
    if val1 != 5 {
        print("FAIL: counter should be 5")
        exit(1)
    }
    
    // Test atomic sub
    const old2: int = atomic.sub(&counter, 2)
    if old2 != 5 {
        print("FAIL: atomic_sub should return old value 5")
        exit(1)
    }
    
    const val2: int = atomic.load(&counter)
    if val2 != 3 {
        print("FAIL: counter should be 3")
        exit(1)
    }
    
    // Test atomic store
    atomic.store(&counter, 100)
    const val3: int = atomic.load(&counter)
    if val3 != 100 {
        print("FAIL: counter should be 100")
        exit(1)
    }
    
    // Test CAS
    const old3: int = atomic.cas(&counter, 100, 200)
    if old3 != 100 {
        print("FAIL: CAS should return old value 100")
        exit(1)
    }
    
    const val4: int = atomic.load(&counter)
    if val4 != 200 {
        print("FAIL: counter should be 200 after CAS")
        exit(1)
    }
    
    // Test concurrent increments
    const shared: int = 0
    
    spawn {
        for i in 0..100 {
            atomic.add(&shared, 1)
        }
    }
    
    spawn {
        for i in 0..100 {
            atomic.add(&shared, 1)
        }
    }
    
    // Wait for spawns
    const start: int = clock()
    while clock() - start < 100 {
        // Wait
    }
    
    const final: int = atomic.load(&shared)
    if final != 200 {
        print("FAIL: concurrent adds should result in 200, got:")
        print(final)
        exit(1)
    }
    
    print("All atomic operation tests passed!")
}
