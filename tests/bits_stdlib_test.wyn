import test
import bits


fn main() {
    print("Testing bits stdlib...\n")
    
    # Test bitwise AND
    test.assert((5 & 3) == 1, "AND works")
    test.assert((12 & 10) == 8, "AND works")
    
    # Test bitwise OR
    test.assert((5 | 3) == 7, "OR works")
    test.assert((12 | 10) == 14, "OR works")
    
    # Test bitwise XOR
    test.assert((5 ^ 3) == 6, "XOR works")
    test.assert((12 ^ 10) == 6, "XOR works")
    
    # Test left shift
    test.assert((1 << 0) == 1, "shift 0")
    test.assert((1 << 1) == 2, "shift 1")
    test.assert((1 << 2) == 4, "shift 2")
    test.assert((1 << 3) == 8, "shift 3")
    
    # Test right shift
    test.assert((8 >> 0) == 8, "shift 0")
    test.assert((8 >> 1) == 4, "shift 1")
    test.assert((8 >> 2) == 2, "shift 2")
    test.assert((8 >> 3) == 1, "shift 3")
    
    # Test NOT
    test.assert((~0) == -1, "NOT works")
    
    print("✓ All bits stdlib tests passed\n")
}
