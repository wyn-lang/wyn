
import test
import math

fn main() {
    # abs - using method syntax
    test.assert((-5).abs() == 5)
    test.assert((5).abs() == 5)
    test.assert((0).abs() == 0)
    
    # min/max - using module syntax
    test.assert(math.min(3, 7) == 3)
    test.assert(math.max(3, 7) == 7)
    test.assert(math.min(-5, -2) == -5)
    test.assert(math.max(-5, -2) == -2)
    
    # Method syntax
    test.assert((-10).abs() == 10)
    test.assert("hello".len() == 5)
    test.assert("123".to_int() == 123)
    
    print("builtins_test: PASS")
    print("")
}
}
