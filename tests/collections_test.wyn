import collections

fn main() {
    print("Collections module test")
    
    # Test HashMap
    const map: str = collections.hashmap_new()
    collections.hashmap_put(map, "name", "Alice")
    collections.hashmap_put(map, "age", "30")
    collections.hashmap_put(map, "city", "NYC")
    
    const name: str = collections.hashmap_get(map, "name")
    print("Name: " + name)
    
    const age: str = collections.hashmap_get(map, "age")
    print("Age: " + age)
    
    if collections.hashmap_contains(map, "city") == true {
        print("Contains city: OK")
    }
    
    const size: int = collections.hashmap_size(map)
    print("Map size:")
    print(size)
    
    # Test Set
    const set: str = collections.set_new()
    collections.set_add(set, "apple")
    collections.set_add(set, "banana")
    collections.set_add(set, "apple")
    
    if collections.set_contains(set, "apple") == true {
        print("Set contains apple: OK")
    }
    
    const set_size: int = collections.set_size(set)
    print("Set size:")
    print(set_size)
    
    print("Collections module test complete")
}
