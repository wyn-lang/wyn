import ./std/collections

fn main() {
    print_str("Testing collections module...\n")
    
    let arr: [int] = [1, 2, 3, 4, 5]
    
    assert(collections.array_sum(arr) == 15, "array_sum works")
    assert(collections.array_product(arr) == 120, "array_product works")
    
    let avg: int = collections.array_avg(arr)
    assert(avg == 3, "array_avg works")
    
    assert(collections.array_contains(arr, 3), "array_contains finds element")
    assert(not collections.array_contains(arr, 10), "array_contains returns false")
    
    assert(collections.array_index_of(arr, 3) == 2, "array_index_of works")
    
    let rev: [int] = collections.array_reverse(arr)
    assert(rev[0] == 5 and rev[4] == 1, "array_reverse works")
    
    let arr2: [int] = [5, 2, 8, 1, 9]
    let sorted: [int] = collections.array_sort(arr2)
    assert(sorted[0] == 1 and sorted[4] == 9, "array_sort works")
    
    let unique: [int] = collections.array_unique([1, 2, 2, 3, 3, 3])
    assert(unique.len() == 3, "array_unique works")
    
    let chunks: int = collections.array_chunk_count(arr, 2)
    assert(chunks == 3, "array_chunk_count works")
    
    print_str("✓ All collections tests passed\n")
}
