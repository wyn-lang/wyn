fn main() {
    # Integer comparisons
    assert(5 == 5)
    assert(5 != 6)
    assert(3 < 5)
    assert(5 > 3)
    assert(5 <= 5)
    assert(5 >= 5)
    assert(4 <= 5)
    assert(6 >= 5)
    
    # Logical operators
    assert(true and true)
    assert(not false)
    assert(true or false)
    assert(not (true and false))
    
    # String comparisons
    assert("hello" == "hello")
    assert("hello" != "world")
    
    print_str("comparison_test: PASS")
}
