
import test
import io
fn main() {
    # Integer comparisons
    test.assert(5 == 5)
    test.assert(5 != 6)
    test.assert(3 < 5)
    test.assert(5 > 3)
    test.assert(5 <= 5)
    test.assert(5 >= 5)
    test.assert(4 <= 5)
    test.assert(6 >= 5)
    
    # Logical operators
    test.assert(true and true)
    test.assert(not false)
    test.assert(true or false)
    test.assert(not (true and false))
    
    # String comparisons
    test.assert("hello" == "hello")
    test.assert("hello" != "world")
    
    print("comparison_test: PASS")
}
