// List comprehension test

fn main() {
    const numbers = [1, 2, 3, 4, 5]
    
    // Test 1: Simple map
    const doubled = [x * 2 for x in numbers]
    print(doubled.len())  // 5
    print(doubled[0])     // 2
    print(doubled[4])     // 10
    
    // Test 2: Filter
    const evens = [x for x in numbers if x % 2 == 0]
    print(evens.len())    // 2
    print(evens[0])       // 2
    print(evens[1])       // 4
    
    // Test 3: Filter and transform
    const big_doubled = [x * 2 for x in numbers if x > 3]
    print(big_doubled.len())  // 2
    print(big_doubled[0])     // 8
    print(big_doubled[1])     // 10
}
