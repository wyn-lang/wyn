import compress
import fs

fn main() {
    print("Compress module test")
    
    # Test file compression
    const test_file: str = "/tmp/wyn_test.txt"
    const gz_file: str = "/tmp/wyn_test.txt.gz"
    
    fs.write(test_file, "Hello compression!")
    
    const gzip_ok: int = compress.gzip_file(test_file, gz_file)
    if gzip_ok == 1 {
        print("Gzip: OK")
    }
    
    const exists: int = fs.exists(gz_file)
    if exists == 1 {
        print("Gzip file exists: OK")
    }
    
    # Test tar
    const tar_file: str = "/tmp/wyn_test.tar.gz"
    const tar_ok: int = compress.tar_create(tar_file, test_file)
    if tar_ok == 1 {
        print("Tar create: OK")
    }
    
    # Cleanup
    fs.delete(test_file)
    fs.delete(gz_file)
    fs.delete(tar_file)
    
    print("Compress module test complete")
}
