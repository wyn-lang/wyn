import ./std/compress

fn main() {
    print_str("Testing compress module...\n")
    
    let text: str = "aaabbbccc"
    let compressed: str = compress.rle_encode(text)
    assert(compressed.len() < text.len(), "rle_encode compresses")
    
    let decompressed: str = compress.rle_decode(compressed)
    assert(decompressed == text, "rle_decode works")
    
    let ratio: float = compress.compression_ratio(text, compressed)
    assert(ratio > 1.0, "compression ratio > 1")
    
    print_str("✓ All compress tests passed\n")
}
