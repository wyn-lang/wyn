
import test
import io
fn main() {
    # If/else
    const x: int = 10
    if x > 5 {
        test.assert(true)
    } else {
        test.assert(false)
    }
    
    # If expression
    const y: int = if x > 5 then 1 else 0
    test.assert(y == 1)
    
    # While loop
    let sum: int = 0
    let i: int = 0
    while i < 5 {
        sum += i
        i += 1
    }
    test.assert(sum == 10)
    
    # For loop with range
    let total: int = 0
    for j in 0..5 {
        total += j
    }
    test.assert(total == 10)
    
    # Inclusive range
    let count: int = 0
    for k in 1..=5 {
        count += 1
    }
    test.assert(count == 5)
    
    # Break
    let n: int = 0
    while true {
        n += 1
        if n == 5 {
            break
        }
    }
    test.assert(n == 5)
    
    # Continue
    let evens: int = 0
    for m in 0..10 {
        if m % 2 != 0 {
            continue
        }
        evens += 1
    }
    test.assert(evens == 5)
    
    print("control_flow_test: PASS")
}
