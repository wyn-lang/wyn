# Test destructuring patterns

fn get_coordinates() -> [int] {
    const coords = [10, 20, 30]
    return coords
}

fn main() {
    print("Testing destructuring")
    
    # Array destructuring via indexing
    const coords = get_coordinates()
    const x = coords[0]
    const y = coords[1]
    const z = coords[2]
    
    print("Coordinates:")
    print("x = " + int_to_str(x))
    print("y = " + int_to_str(y))
    print("z = " + int_to_str(z))
    
    assert(x == 10)
    assert(y == 20)
    assert(z == 30)
    
    # Result destructuring via match
    const result = ok(42)
    match result {
        ok(value) => {
            print("Destructured value: " + int_to_str(value))
            assert(value == 42)
        }
        err(code) => print("Error")
    }
    
    # Option destructuring via match
    const option = some(100)
    match option {
        some(val) => {
            print("Destructured option: " + int_to_str(val))
            assert(val == 100)
        }
        none => print("None")
    }
    
    print("Destructuring works!")
}
