import string
import io
import os

fn main() {
    print("Testing wyn doc command...\n")
    
    # Test 1: List modules
    const result1: int = system("./build/wyn doc >/tmp/doc_test1.txt 2>&1")
    assert(result1 == 0, "wyn doc should succeed")
    
    # Test 2: Show module
    const result2: int = system("./build/wyn doc os >/tmp/doc_test2.txt 2>&1")
    assert(result2 == 0, "wyn doc os should succeed")
    
    # Test 3: Show function
    const result3: int = system("./build/wyn doc os.getenv >/tmp/doc_test3.txt 2>&1")
    assert(result3 == 0, "wyn doc os.getenv should succeed")
    
    # Verify output contains expected text
    const out1: str = io.read_file("/tmp/doc_test1.txt")
    assert(string.find(out1, "Standard Library") >= 0, "Should show stdlib")
    
    const out2: str = io.read_file("/tmp/doc_test2.txt")
    assert(string.find(out2, "package os") >= 0, "Should show package os")
    
    const out3: str = io.read_file("/tmp/doc_test3.txt")
    assert(string.find(out3, "getenv") >= 0, "Should show getenv")
    
    print("✓ All doc tests passed\n")
}
