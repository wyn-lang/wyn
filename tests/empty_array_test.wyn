// Test: Empty array literals with type inference
// Should infer type from first usage

import array

fn test_empty_array_with_string() {
    let s = []
    s = array.append(s, "hello")
    s = array.append(s, "world")
    print(s.len())  // Should print: 2
}

fn test_empty_array_with_int() {
    let nums = []
    nums = array.append(nums, 1)
    nums = array.append(nums, 2)
    nums = array.append(nums, 3)
    print(nums.len())  // Should print: 3
}

fn test_empty_array_in_loop() {
    let items = []
    for i in 0..5 {
        items = array.append(items, i)
    }
    print(items.len())  // Should print: 5
}

fn test_empty_array_type_error() {
    let mixed = []
    mixed = array.append(mixed, "string")
    // This should fail at compile time:
    // mixed = array.append(mixed, 42)
    print(mixed.len())  // Should print: 1
}

fn main() {
    test_empty_array_with_string()
    test_empty_array_with_int()
    test_empty_array_in_loop()
    test_empty_array_type_error()
    print("All tests passed!")
}
