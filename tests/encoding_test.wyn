import encoding

fn main() {
    print("Testing encoding module...\n")
    
    var text: str = "Hello"
    
    // Test base64
    var b64: str = encoding.base64_encode(text)
    var decoded: str = encoding.base64_decode(b64)
    print("Base64 encode/decode: ")
    print(decoded)
    print("\n")
    
    // Test hex
    var hex: str = encoding.hex_encode(text)
    print("Hex encoded: ")
    print(hex)
    print("\n")
    
    // Test URL encoding
    var url: str = encoding.url_encode("hello world")
    print("URL encoded: ")
    print(url)
    print("\n")
    
    print("Encoding module test passed!\n")
}
