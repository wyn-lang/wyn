import ./std/encoding

fn main() {
    print_str("Testing encoding module...\n")
    
    let text: str = "Hello"
    let b64: str = encoding.base64_encode(text)
    let decoded: str = encoding.base64_decode(b64)
    assert(decoded == text, "base64 encode/decode works")
    
    let hex: str = encoding.hex_encode(text)
    let hex_decoded: str = encoding.hex_decode(hex)
    assert(hex_decoded == text, "hex encode/decode works")
    
    let url: str = "hello world"
    let url_enc: str = encoding.url_encode(url)
    assert(url_enc == "hello%20world", "url_encode works")
    
    let url_dec: str = encoding.url_decode(url_enc)
    assert(url_dec == url, "url_decode works")
    
    print_str("✓ All encoding tests passed\n")
}
