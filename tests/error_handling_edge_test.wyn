fn divide(a: int, b: int) -> Result[int, str] {
    if b == 0 {
        return err("Division by zero")
    }
    return ok(a / b)
}

fn main() {
    print("=== Error Handling Edge Cases ===")
    
    // Success case
    const r1 = divide(10, 2)
    match r1 {
        ok(v) => print(v)
        err(e) => print("Error")
    }
    
    // Error case
    const r2 = divide(10, 0)
    match r2 {
        ok(v) => print(v)
        err(e) => print("Error occurred")
    }
    
    // Nested results
    const r3 = divide(20, 4)
    match r3 {
        ok(v) => {
            const r4 = divide(v, 2)
            match r4 {
                ok(v2) => print(v2)
                err(e2) => print("Nested error")
            }
        }
        err(e) => print("Outer error")
    }
    
    // Unwrap on success
    const r5 = divide(100, 10)
    const val = r5!
    print(val)
    
    print("Error handling edge cases passed!")
}
