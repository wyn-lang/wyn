# Working Error Handling Test

import result

fn divide_safe(a: int, b: int) -> [int] {
    if b == 0 {
        return result.make_err(-1)
    }
    return result.make_ok(a / b)
}

fn main() {
    print("=== Error Handling Test ===")
    
    # Test 1: Basic Result creation
    print("1. Testing Result creation")
    const success = ok(42)
    const failure = err("Error")
    print("✓ Result creation works")
    
    # Test 2: Unwrap operator
    print("2. Testing unwrap operator")
    const value = success!
    print("Unwrapped value:")
    print(value)
    print("✓ Unwrap operator works")
    
    # Test 3: Helper functions
    print("3. Testing helper functions")
    const helper_success = divide_safe(10, 2)
    if result.is_ok(helper_success) == 1 {
        const result_value = result.unwrap(helper_success)
        print("Helper result:")
        print(result_value)
    }
    
    const helper_error = divide_safe(10, 0)
    if result.is_err(helper_error) == 1 {
        print("Helper error caught")
    }
    print("✓ Helper functions work")
    
    # Test 4: Option types
    print("4. Testing Option types")
    const some_val = some(100)
    const none_val = none
    print("✓ Option types work")
    
    print("=== All Tests Passed ===")
    print("🎉 Error handling is working!")
}
