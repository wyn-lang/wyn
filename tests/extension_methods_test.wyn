// Extension methods - Python/JavaScript style!

// Int extensions
fn int.squared(self) -> int {
    return self * self
}

fn int.cubed(self) -> int {
    return self * self * self
}

fn int.plus_ten(self) -> int {
    return self + 10
}

fn int.double(self) -> int {
    return self * 2
}

// String extensions
fn str.shout(self) -> str {
    return self.upper() + "!!!"
}

fn str.whisper(self) -> str {
    return self.lower() + "..."
}

fn str.wrap(self) -> str {
    return "[" + self + "]"
}

fn main() {
    print("=== Extension Methods Test ===")
    
    // Int extensions
    print(5.squared())          // 25
    print(3.cubed())            // 27
    print(5.plus_ten())         // 15
    print(21.double())          // 42
    
    // String extensions
    print("hello".shout())      // "HELLO!!!"
    print("WORLD".whisper())    // "world..."
    print("test".wrap())        // "[test]"
    
    // Method chaining
    print((-10).abs().squared())  // 100
    
    // Variables
    const num = 7
    print(num.squared())        // 49
    
    const text = "wyn"
    print(text.shout())         // "WYN!!!"
    
    print("Extension methods work perfectly!")
}
