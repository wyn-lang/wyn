
import io

fn main() {
    # Test is_dir
    assert(io.is_dir("tests"))
    assert(not io.is_dir("Makefile"))
    
    # Test file_size
    const size: int = io.file_size("Makefile")
    assert(size > 0)
    
    # Test file_exists
    assert(io.file_exists("Makefile"))
    assert(not io.file_exists("nonexistent_file_xyz"))
    
    print("fs_test passed")
    print("")
}
