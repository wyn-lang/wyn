import std/io

fn main() {
    # Test is_dir
    assert(is_dir("tests"))
    assert(not is_dir("Makefile"))
    
    # Test file_size
    const size: int = file_size("Makefile")
    assert(size > 0)
    
    # Test file_exists
    assert(file_exists("Makefile"))
    assert(not file_exists("nonexistent_file_xyz"))
    
    io.print_str("fs_test passed")
    io.print_newline()
}
