import std/io
fn add(a: int, b: int) -> int {
    return a + b
}

fn factorial(n: int) -> int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

fn fib(n: int) -> int {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fn main() {
    assert(add(2, 3) == 5)
    assert(add(-1, 1) == 0)
    
    assert(factorial(0) == 1)
    assert(factorial(1) == 1)
    assert(factorial(5) == 120)
    
    assert(fib(0) == 0)
    assert(fib(1) == 1)
    assert(fib(10) == 55)
    
    print("function_test: PASS")
}
