import ./std/gpu

fn main() {
    print_str("Testing gpu module (Vulkan)...\n")
    
    let init_result: bool = gpu.init()
    if not init_result {
        print_str("⚠ GPU not available, skipping tests\n")
        return
    }
    
    let device_count: int = gpu.device_count()
    print_str("  GPU devices: ")
    print(device_count)
    print_newline()
    
    if device_count > 0 {
        let devices: [str] = gpu.list_devices()
        assert(devices.len() == device_count, "list_devices matches count")
        
        print_str("  Device 0: ")
        print_str(devices[0])
        print_newline()
        
        let current: int = gpu.current_device()
        assert(current >= 0, "current_device returns valid id")
        
        # Test tensor creation
        let data: [[float]] = [[1.0, 2.0], [3.0, 4.0]]
        let tensor: Tensor = gpu.tensor_from_array(data)
        assert(tensor.ndim() == 2, "tensor has 2 dimensions")
        assert(tensor.numel() == 4, "tensor has 4 elements")
        
        # Test tensor operations
        let sum: float = tensor.sum()
        assert(sum == 10.0, "tensor sum is 10.0")
        
        let mean: float = tensor.mean()
        assert(mean == 2.5, "tensor mean is 2.5")
        
        let max_val: float = tensor.max()
        assert(max_val == 4.0, "tensor max is 4.0")
        
        let min_val: float = tensor.min()
        assert(min_val == 1.0, "tensor min is 1.0")
        
        # Test tensor arithmetic
        let doubled: Tensor = gpu.tensor_mul_scalar(tensor, 2.0)
        assert(doubled.sum() == 20.0, "tensor multiplication works")
        
        let added: Tensor = gpu.tensor_add_scalar(tensor, 1.0)
        assert(added.sum() == 14.0, "tensor addition works")
        
        gpu.sync()
        print_str("✓ All gpu tests passed\n")
    } else {
        print_str("⚠ No GPU devices found\n")
    }
}
