fn main() {
    print("Testing hash stdlib...\n")
    
    # Test string hashing consistency
    const s1: str = "hello"
    const s2: str = "hello"
    const s3: str = "world"
    
    # Same strings should be equal
    assert(s1 == s2, "same strings equal")
    assert(s1 != s3, "different strings not equal")
    
    # Test string comparison
    assert("abc" == "abc", "string equality")
    assert("abc" != "def", "string inequality")
    
    # Test empty string
    assert("" == "", "empty strings equal")
    assert("" != "x", "empty vs non-empty")
    
    print("✓ All hash stdlib tests passed\n")
}
