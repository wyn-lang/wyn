import hash

fn main() {
    print("Testing hash module...\n")
    
    var text: str = "test"
    
    var sha256: str = hash.sha256(text)
    print("SHA256: ")
    print(sha256)
    print("\n")
    
    var md5: str = hash.md5(text)
    print("MD5: ")
    print(md5)
    print("\n")
    
    var sha1: str = hash.sha1(text)
    print("SHA1: ")
    print(sha1)
    print("\n")
    
    print("Hash module test passed!\n")
}
