fn main() {
    print("Testing I/O syscalls...")
    
    # macOS syscall numbers need 0x2000000 offset
    const SYS_OPEN: int = 33554437    # 5 + 0x2000000
    const SYS_WRITE: int = 33554436   # 4 + 0x2000000  
    const SYS_CLOSE: int = 33554438   # 6 + 0x2000000
    
    # write_file using syscalls
    # open(path, O_WRONLY | O_CREAT | O_TRUNC, 0644)
    const fd: int = syscall(SYS_OPEN, "test_output.txt", 1537, 420, 0, 0, 0)
    
    if fd < 0 {
        print("Failed to open file")
        exit(1)
    }
    
    const content: str = "Hello from pure Wyn syscalls!"
    # write(fd, content, len)
    const written: int = syscall(SYS_WRITE, fd, content, content.len(), 0, 0, 0)
    
    # close(fd)
    syscall(SYS_CLOSE, fd, 0, 0, 0, 0, 0)
    
    if written > 0 {
        print("✓ write_file() works - wrote bytes successfully!")
    } else {
        print("Failed to write file")
    }
    
    print("✓ All I/O syscall tests passed!")
}
