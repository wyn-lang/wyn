fn main() {
    print_str("Testing json stdlib...\n")
    
    # Test JSON structure characters
    assert("{" == "{", "open brace")
    assert("}" == "}", "close brace")
    assert("[" == "[", "open bracket")
    assert("]" == "]", "close bracket")
    assert(":" == ":", "colon")
    assert("," == ",", "comma")
    
    # Test JSON strings
    const json_str: str = "key:value"
    assert(json_str.len() > 0, "JSON string not empty")
    
    # Test quotes
    const quote: str = "\""
    assert(quote.len() == 1, "quote length")
    
    print_str("✓ All json stdlib tests passed\n")
}
