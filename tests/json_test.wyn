import json

fn main() {
    // Test JSON parsing (minimal)
    var json_str: str = "test"
    var data: str = json.parse(json_str)
    
    // Test stringify
    var str_result: str = json.stringify(data)
    print("JSON stringify: ")
    if str_result.len() >= 0 {
        print(1)
    } else {
        print(0)
    }
    
    // Test getters (will return defaults for now)
    var name: str = json.get_string(data, "name")
    var count: int = json.get_int(data, "count")
    var flag: bool = json.get_bool(data, "flag")
    
    print("JSON module test complete")
}
