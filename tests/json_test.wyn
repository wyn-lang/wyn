import ./std/json

fn main() {
    print_str("Testing json module...\n")
    
    let escaped: str = json.escape_string("hello\"world")
    assert(escaped == "hello\\\"world", "escape_string works")
    
    let unescaped: str = json.unescape_string(escaped)
    assert(unescaped == "hello\"world", "unescape_string works")
    
    let obj: str = json.object_start()
    assert(obj == "{", "object_start returns {")
    
    let arr: str = json.array_start()
    assert(arr == "[", "array_start returns [")
    
    let key_val: str = json.key_value("name", "\"John\"")
    assert(key_val.len() > 0, "key_value creates pair")
    
    assert(json.is_valid_json("{}"), "empty object is valid")
    assert(json.is_valid_json("[]"), "empty array is valid")
    assert(not json.is_valid_json("{"), "incomplete json is invalid")
    
    print_str("✓ All json tests passed\n")
}
