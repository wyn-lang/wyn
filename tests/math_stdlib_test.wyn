import std/io
fn main() {
    test_abs()
    test_min_max()
    test_pow()
    test_sqrt()
    test_gcd()
    test_lcm()
    test_factorial()
    print_str("All math tests passed!")
}

fn test_abs() {
    assert(abs(5) == 5)
    assert(abs(-5) == 5)
    assert(abs(0) == 0)
}

fn test_min_max() {
    assert(min(3, 7) == 3)
    assert(min(-5, -2) == -5)
    assert(max(3, 7) == 7)
    assert(max(-5, -2) == -2)
}

fn test_pow() {
    assert(pow(2, 3) == 8)
    assert(pow(5, 2) == 25)
    assert(pow(10, 0) == 1)
}

fn test_sqrt() {
    assert(sqrt(16) == 4)
    assert(sqrt(25) == 5)
    assert(sqrt(1) == 1)
    assert(sqrt(0) == 0)
}

fn test_gcd() {
    assert(gcd(12, 8) == 4)
    assert(gcd(21, 14) == 7)
    assert(gcd(17, 19) == 1)
}

fn test_lcm() {
    assert(lcm(4, 6) == 12)
    assert(lcm(3, 5) == 15)
    assert(lcm(12, 8) == 24)
}

fn test_factorial() {
    assert(factorial(0) == 1)
    assert(factorial(1) == 1)
    assert(factorial(5) == 120)
    assert(factorial(6) == 720)
}

fn abs(n: int) -> int {
    if n < 0 {
        return -n
    }
    return n
}

fn min(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

fn max(a: int, b: int) -> int {
    if a > b {
        return a
    }
    return b
}

fn pow(base: int, exp: int) -> int {
    let mut result: int = 1
    let mut i: int = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

fn sqrt(n: int) -> int {
    if n == 0 {
        return 0
    }
    let mut x: int = n
    let mut y: int = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

fn gcd(a: int, b: int) -> int {
    let mut x: int = abs(a)
    let mut y: int = abs(b)
    while y != 0 {
        let temp: int = y
        y = x % y
        x = temp
    }
    return x
}

fn lcm(a: int, b: int) -> int {
    if a == 0 {
        return 0
    }
    if b == 0 {
        return 0
    }
    return abs(a * b) / gcd(a, b)
}

fn factorial(n: int) -> int {
    if n <= 1 {
        return 1
    }
    let mut result: int = 1
    let mut i: int = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

fn check(condition: bool) {
    if not condition {
        print_str("ASSERTION FAILED")
    }
}
