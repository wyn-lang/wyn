fn main() {
    print("Testing math stdlib...")
    
    # Test basic math functions that should be available as builtins
    assert(abs(5) == 5)
    assert(abs(-5) == 5)
    assert(abs(0) == 0)
    
    # Test min/max
    assert(min(3, 7) == 3)
    assert(min(-5, -2) == -5)
    assert(max(3, 7) == 7)
    assert(max(-5, -2) == -2)
    
    # Test pow
    assert(pow(2, 3) == 8)
    assert(pow(5, 2) == 25)
    assert(pow(10, 0) == 1)
    assert(pow(2, 10) == 1024)
    
    print("✓ All math stdlib tests passed")
}

fn abs(n: int) -> int {
    if n < 0 {
        return -n
    }
    return n
}

fn min(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

fn max(a: int, b: int) -> int {
    if a > b {
        return a
    }
    return b
}

fn pow(base: int, exp: int) -> int {
    var result: int = 1
    var i: int = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}
