
import math

fn main() {
    print("Testing math stdlib...\n")
    
    # Test abs
    assert(abs(5) == 5, "abs positive")
    assert(abs(-5) == 5, "abs negative")
    assert(abs(0) == 0, "abs zero")
    
    # Test min/max
    assert(min(3, 7) == 3, "min")
    assert(min(-5, -2) == -5, "min negative")
    assert(max(3, 7) == 7, "max")
    assert(max(-5, -2) == -2, "max negative")
    
    # Test pow
    assert(pow(2, 3) == 8, "pow 2^3")
    assert(pow(5, 2) == 25, "pow 5^2")
    assert(pow(10, 0) == 1, "pow x^0")
    assert(pow(2, 10) == 1024, "pow 2^10")
    
    # Test sqrt
    const s2: float = math.sqrt(4.0)
    assert(s2 == 2.0, "sqrt 4")
    const s3: float = math.sqrt(9.0)
    assert(s3 == 3.0, "sqrt 9")
    const s4: float = math.sqrt(16.0)
    assert(s4 == 4.0, "sqrt 16")
    
    # Test trig functions
    const pi: float = 3.14159
    const s: float = math.sin(0.0)
    assert(s == 0.0, "sin 0")
    const c: float = math.cos(0.0)
    assert(c == 1.0, "cos 0")
    
    # Test exp and log
    const e: float = math.exp(0.0)
    assert(e == 1.0, "exp 0")
    const l: float = math.log(1.0)
    assert(l == 0.0, "log 1")
    
    # Test floor/ceil
    const f1: float = math.floor(3.7)
    assert(f1 == 3.0, "floor 3.7")
    const c1: float = math.ceil(3.2)
    assert(c1 == 4.0, "ceil 3.2")
    
    print("✓ All math stdlib tests passed\n")
}


fn test_sqrt() {
    assert(sqrt(16) == 4)
    assert(sqrt(25) == 5)
    assert(sqrt(1) == 1)
    assert(sqrt(0) == 0)
}

fn test_gcd() {
    assert(gcd(12, 8) == 4)
    assert(gcd(21, 14) == 7)
    assert(gcd(17, 19) == 1)
}

fn test_lcm() {
    assert(lcm(4, 6) == 12)
    assert(lcm(3, 5) == 15)
    assert(lcm(12, 8) == 24)
}

fn test_factorial() {
    assert(factorial(0) == 1)
    assert(factorial(1) == 1)
    assert(factorial(5) == 120)
    assert(factorial(6) == 720)
}

fn abs(n: int) -> int {
    if n < 0 {
        return -n
    }
    return n
}

fn min(a: int, b: int) -> int {
    if a < b {
        return a
    }
    return b
}

fn max(a: int, b: int) -> int {
    if a > b {
        return a
    }
    return b
}

fn pow(base: int, exp: int) -> int {
    let result: int = 1
    let i: int = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}

fn sqrt(n: int) -> int {
    if n == 0 {
        return 0
    }
    let x: int = n
    let y: int = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

fn gcd(a: int, b: int) -> int {
    let x: int = abs(a)
    let y: int = abs(b)
    while y != 0 {
        const temp: int = y
        y = x % y
        x = temp
    }
    return x
}

fn lcm(a: int, b: int) -> int {
    if a == 0 {
        return 0
    }
    if b == 0 {
        return 0
    }
    return abs(a * b) / gcd(a, b)
}

fn factorial(n: int) -> int {
    if n <= 1 {
        return 1
    }
    let result: int = 1
    let i: int = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

fn check(condition: bool) {
    if not condition {
        print("ASSERTION FAILED")
    }
}
