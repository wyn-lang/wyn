fn main() {
    print("Testing complete method syntax...")
    
    // String methods
    const s = "hello"
    print(s.upper())
    print(s.lower())
    print("  spaces  ".trim())
    
    const has_world: bool = "hello world".contains("world")
    if has_world {
        print("contains works!")
    }
    
    const starts: bool = "hello".starts_with("hel")
    if starts {
        print("starts_with works!")
    }
    
    const ends: bool = "hello".ends_with("llo")
    if ends {
        print("ends_with works!")
    }
    
    // Int methods
    const n = -42
    print(n.abs())
    
    const str_n: str = 42.to_str()
    print(str_n)
    
    // Array methods
    const arr = [1, 2, 3]
    print(arr.len())
    print(arr.get(0))
    
    print("All method syntax tests passed!")
}
