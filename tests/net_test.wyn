import net

fn main() {
    // Test HTTP functions (will return empty for now)
    var response: str = net.http_get("http://example.com")
    print("HTTP GET: ")
    if response.len() >= 0 {
        print(1)
    } else {
        print(0)
    }
    
    var post_response: str = net.http_post("http://example.com", "data")
    print("HTTP POST: ")
    if post_response.len() >= 0 {
        print(1)
    } else {
        print(0)
    }
    
    // Test TCP functions (will return defaults for now)
    var fd: int = net.tcp_connect("localhost", 8080)
    print("TCP connect: ")
    if fd >= -1 {
        print(1)
    } else {
        print(0)
    }
    
    var sent: bool = net.tcp_send(fd, "hello")
    print("TCP send: ")
    if sent == false {
        print(1)  // Expected false for now
    } else {
        print(0)
    }
    
    var received: str = net.tcp_recv(fd, 1024)
    print("TCP recv: ")
    if received.len() >= 0 {
        print(1)
    } else {
        print(0)
    }
    
    net.tcp_close(fd)
    
    print("Net module test complete")
}
