import std/io
fn maybe_double(x: int) -> ?int {
    if x < 0 {
        return none
    }
    return some(x * 2)
}

fn main() {
    const a: ?int = some(42)
    const b: ?int = none
    
    # Unwrap with default
    assert(a ?? 0 == 42)
    assert(b ?? 99 == 99)
    
    # Force unwrap
    assert(a! == 42)
    
    # Function returning optional
    const c: ?int = maybe_double(5)
    assert(c ?? 0 == 10)
    
    const d: ?int = maybe_double(-1)
    assert(d ?? 0 == 0)
    
    print("optional_test: PASS")
}
