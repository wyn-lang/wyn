fn main() {
    print_str("Testing os stdlib...\n")
    
    # Test getcwd
    let cwd: str = getcwd()
    assert(cwd.len() > 0, "getcwd returns path")
    
    # Test getpid
    let pid: int = getpid()
    assert(pid > 0, "getpid returns positive")
    
    # Test getenv
    let path: str = getenv("PATH")
    assert(path.len() > 0, "PATH env var exists")
    
    # Test args
    let argv: [str] = args()
    assert(argv.len() >= 1, "args has program name")
    
    print_str("✓ All os stdlib tests passed\n")
}
