import os
import fs

fn main() {
    print("=== Process Execution Tests ===")
    
    // Test os.exec_check with successful command
    const check_success = os.exec_check("true")
    assert(check_success)
    print("os.exec_check (success): PASS")
    
    // Test os.exec_check with failing command
    const check_fail = os.exec_check("false")
    assert(!check_fail)
    print("os.exec_check (failure): PASS")
    
    // Test with file operations
    fs.write("test_exec.txt", "test content")
    const cat_exit = os.exec("cat test_exec.txt > /dev/null")
    assert(cat_exit == 0)
    print("File operation with exec: PASS")
    
    // Clean up
    fs.delete("test_exec.txt")
    
    print("Process execution tests passed!")
}