import ./std/random

fn main() {
    print_str("Testing random module...\n")
    
    random.seed(12345)
    
    let r1: int = random.rand()
    assert(r1 >= 0, "rand() returns non-negative")
    
    let r2: int = random.rand_range(1, 10)
    assert(r2 >= 1 and r2 <= 10, "rand_range works")
    
    let f: float = random.rand_float()
    assert(f >= 0.0 and f <= 1.0, "rand_float in range")
    
    let b: bool = random.rand_bool()
    assert(b == true or b == false, "rand_bool returns bool")
    
    let arr: [int] = [1, 2, 3, 4, 5]
    let shuffled: [int] = random.shuffle(arr)
    assert(shuffled.len() == arr.len(), "shuffle preserves length")
    
    let choice: int = random.choice(arr)
    assert(choice >= 1 and choice <= 5, "choice picks from array")
    
    print_str("✓ All random tests passed\n")
}
