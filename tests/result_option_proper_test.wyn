# Test proper Result<T, E> and Option<T> types with integer values

fn divide(a: int, b: int) -> Result[int, int] {
    if b == 0 {
        return err(-1)  # Use integer error code
    }
    return ok(a / b)
}

fn find_value(arr: [int], target: int) -> ?int {
    for i in 0..arr.len() {
        if arr[i] == target {
            return some(arr[i])
        }
    }
    return none
}

fn main() {
    print("Testing Result<T, E> types")
    
    # Test successful division
    const result1 = divide(10, 2)
    match result1 {
        ok(value) => {
            print("Success: " + int_to_str(value))
            assert(value == 5)
        }
        err(code) => print("Error: " + int_to_str(code))
    }
    
    # Test division by zero
    const result2 = divide(10, 0)
    match result2 {
        ok(value) => print("Unexpected success: " + int_to_str(value))
        err(code) => {
            print("Error code: " + int_to_str(code))
            assert(code == -1)
        }
    }
    
    print("Testing Option<T> types")
    
    const items = [10, 20, 30]
    
    # Test finding existing item
    const found1 = find_value(items, 20)
    match found1 {
        some(value) => {
            print("Found: " + int_to_str(value))
            assert(value == 20)
        }
        none => print("Not found")
    }
    
    # Test with unwrap operator
    const found3 = find_value(items, 30)
    const value3 = found3!
    print("Unwrapped value: " + int_to_str(value3))
    assert(value3 == 30)
    
    print("Result and Option types work!")
}
