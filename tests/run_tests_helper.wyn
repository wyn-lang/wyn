# Simple test runner - validates test execution works

fn main() {
    print("=== Wyn Test Runner ===")
    print("")
    
    # Test that we can run tests programmatically
    print("Testing basic functionality:")
    
    # Test 1: Arithmetic
    const result1 = 5 + 3
    assert(result1 == 8)
    print("✓ Arithmetic works")
    
    # Test 2: Strings
    const result2 = "Hello" + " " + "World"
    assert(result2 == "Hello World")
    print("✓ String concatenation works")
    
    # Test 3: Functions
    const result3 = test_function(10)
    assert(result3 == 20)
    print("✓ Functions work")
    
    # Test 4: Control flow
    let result4: int = 0
    const condition: bool = 1 == 1
    if condition {
        result4 = 42
    }
    assert(result4 == 42)
    print("✓ Control flow works")
    
    print("")
    print("=== All Basic Tests Passed ===")
}

fn test_function(x: int) -> int {
    return x * 2
}
