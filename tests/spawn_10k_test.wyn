fn main() {
    print("Testing 10,000 spawns...\n")
    
    let counter: int = 0
    
    for i in 0..10000 {
        spawn { counter = counter + 1 }
    }
    
    sleep_ms(30000)  # 30 seconds for 10k spawns
    
    print("Counter: ")
    print(counter)
    print("/10000\n")
    
    # Allow 99% success rate
    assert(counter >= 9900, "At least 9900/10000 spawns should complete")
    
    print("✓ 10k spawn test passed\n")
}
