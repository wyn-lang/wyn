
fn main() {
    test_immutable_capture()
    test_mutable_capture()
    test_multiple_spawns()
}

fn test_immutable_capture() {
    const x: int = 42
    var result: int = 0
    
    spawn {
        result = x
    }
    
    task_join_all()
    assert(result == 42)
}

fn test_mutable_capture() {
    var counter: int = 0
    
    spawn {
        counter = counter + 1
    }
    
    task_join_all()
    assert(counter == 1)
}

fn test_multiple_spawns() {
    var sum: int = 0
    
    spawn {
        sum = sum + 10
    }
    
    spawn {
        sum = sum + 20
    }
    
    task_join_all()
    assert(sum == 30)
}
