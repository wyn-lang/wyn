
import time

fn main() {
    test_immutable_capture()
    test_mutable_capture()
    test_multiple_spawns()
}

fn test_immutable_capture() {
    const x: int = 42
    let result: int = 0
    
    spawn {
        result = x
    }
    
    time.sleep_ms(100)
    assert(result == 42)
}

fn test_mutable_capture() {
    let counter: int = 0
    
    spawn {
        counter = counter + 1
    }
    
    time.sleep_ms(100)
    assert(counter == 1)
}

fn test_multiple_spawns() {
    let sum: int = 0
    
    spawn {
        sum = sum + 10
    }
    
    spawn {
        sum = sum + 20
    }
    
    time.sleep_ms(100)
    assert(sum == 30)
}
