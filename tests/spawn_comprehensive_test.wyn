
fn main() {
    print("Testing spawn comprehensively...\n")
    
    # Test 1: Single spawn
    let t1: int = 0
    spawn { t1 = t1 + 1 }
    sleep_ms(10)
    assert(t1 == 1)
    
    # Test 2: Multiple spawns
    let t2: int = 0
    spawn { t2 = t2 + 1 }
    spawn { t2 = t2 + 1 }
    spawn { t2 = t2 + 1 }
    sleep_ms(10)
    assert(t2 == 3)
    
    # Test 3: Spawns in loop
    let t3: int = 0
    for i in 0..10 {
        spawn { t3 = t3 + 1 }
    }
    sleep_ms(50)
    assert(t3 == 10)
    
    # Test 4: Variable capture
    const x: int = 42
    let t4: int = 0
    spawn { t4 = x }
    sleep_ms(10)
    assert(t4 == 42)
    
    # Test 5: Multiple variables (separate spawns)
    let a: int = 0
    let b: int = 0
    spawn { a = a + 1 }
    spawn { b = b + 2 }
    sleep_ms(10)
    assert(a == 1)
    assert(b == 2)
    
    # Test 6: 100 spawns
    let t6: int = 0
    for i in 0..100 {
        spawn { t6 = t6 + 1 }
    }
    sleep_ms(100)
    assert(t6 == 100)
    
    print("✓ All spawn tests passed\n")
}
