
fn main() {
    const x: int = 42
    let result: int = 0
    
    print("Before spawn: x=")
    print(x)
    print(", result=")
    print(result)
    
    spawn {
        result = x
    }
    
    task_join_all()
    
    print("After spawn: x=")
    print(x)
    print(", result=")
    print(result)
    
    assert(result == 42)
}
