# Test that spawns in a loop run in parallel

import time

fn main() {
    print("Testing parallel spawn in loop")
    
    # Test 1: Spawn multiple tasks in a loop
    var counter: int = 0
    var i: int = 0
    
    while i < 10 {
        spawn {
            counter = counter + 1
        }
        i = i + 1
    }
    
    task_join_all()
    
    print("Counter after 10 spawns: " + int_to_str(counter))
    assert(counter == 10)
    
    # Test 2: Verify parallel execution with timing
    # If they run in parallel, total time should be ~100ms, not 1000ms
    var task_count: int = 0
    var j: int = 0
    
    while j < 10 {
        spawn {
            sleep_ms(100)  # Each task sleeps 100ms
            task_count = task_count + 1
        }
        j = j + 1
    }
    
    const start = time.now()
    task_join_all()
    const elapsed = time.now() - start
    
    print("Task count: " + int_to_str(task_count))
    print("Elapsed time: " + int_to_str(elapsed) + "ms")
    
    assert(task_count == 10)
    
    # If parallel, should take ~100ms, not 1000ms
    # Allow some overhead, so check < 500ms
    if elapsed < 500 {
        print("✓ Tasks ran in parallel")
    } else {
        print("⚠ Tasks may have run sequentially")
    }
    
    # Test 3: For loop with spawns
    var count: int = 0
    for k in 0..5 {
        spawn {
            count = count + 1
        }
    }
    
    task_join_all()
    
    print("Count from for loop: " + int_to_str(count))
    assert(count == 5)
    
    print("Parallel spawn in loops works!")
}
