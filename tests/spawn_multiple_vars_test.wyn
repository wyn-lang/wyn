import time

fn main() {
    test_multiple_captures()
    test_mixed_types()
}

fn test_multiple_captures() {
    let a: int = 0
    let b: int = 0
    let c: int = 0
    
    spawn {
        a = a + 1
        b = b + 2
        c = c + 3
    }
    
    time.sleep_ms(100)
    assert(a == 1)
    assert(b == 2)
    assert(c == 3)
}

fn test_mixed_types() {
    let counter: int = 0
    const x: int = 42
    let result: int = 0
    
    spawn {
        counter = counter + 1
        result = x
    }
    
    time.sleep_ms(100)
    assert(counter == 1)
    assert(result == 42)
}
