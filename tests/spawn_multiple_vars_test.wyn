
fn main() {
    test_multiple_captures()
    test_mixed_types()
}

fn test_multiple_captures() {
    var a: int = 0
    var b: int = 0
    var c: int = 0
    
    spawn {
        a = a + 1
        b = b + 2
        c = c + 3
    }
    
    task_join_all()
    assert(a == 1)
    assert(b == 2)
    assert(c == 3)
}

fn test_mixed_types() {
    var counter: int = 0
    const x: int = 42
    var result: int = 0
    
    spawn {
        counter = counter + 1
        result = x
    }
    
    task_join_all()
    assert(counter == 1)
    assert(result == 42)
}
