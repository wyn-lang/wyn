
fn main() {
    test_multiple_spawns()
}

fn test_multiple_spawns() {
    let sum: int = 0
    const val1: int = 0
    const val2: int = 10
    const val3: int = 20
    
    spawn {
        sum = sum + val1
    }
    
    spawn {
        sum = sum + val2
    }
    
    spawn {
        sum = sum + val3
    }
    
    task_join_all()
    assert(sum == 30)
}
