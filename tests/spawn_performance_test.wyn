import time

fn cpu_work() {
    # Simulate some CPU work
    let sum: int = 0
    for i in 0..1000 {
        sum = sum + i
    }
}

fn main() {
    print("M:N Scheduler Performance Test\n")
    print("=============================\n")
    
    # Test 1: 100k lightweight tasks
    print("Test 1: 100k lightweight tasks\n")
    let counter1: int = 0
    let start1 = time.now_ms()
    
    for i in 0..100000 {
        spawn { counter1 = counter1 + 1 }
    }
    
    time.sleep_ms(10000)  # 10 seconds
    let end1 = time.now_ms()
    
    print("Completed: ")
    print(counter1)
    print("/100000 in ")
    print(end1 - start1)
    print("ms\n")
    
    # Test 2: 10k CPU-intensive tasks
    print("\nTest 2: 10k CPU-intensive tasks\n")
    let counter2: int = 0
    let start2 = time.now_ms()
    
    for i in 0..10000 {
        spawn { 
            cpu_work()
            counter2 = counter2 + 1 
        }
    }
    
    time.sleep_ms(15000)  # 15 seconds
    let end2 = time.now_ms()
    
    print("Completed: ")
    print(counter2)
    print("/10000 in ")
    print(end2 - start2)
    print("ms\n")
    
    # Test 3: Nested spawns
    print("\nTest 3: Nested spawns (1k x 10)\n")
    let counter3: int = 0
    let start3 = time.now_ms()
    
    for i in 0..1000 {
        spawn {
            for j in 0..10 {
                spawn { counter3 = counter3 + 1 }
            }
        }
    }
    
    time.sleep_ms(5000)  # 5 seconds
    let end3 = time.now_ms()
    
    print("Completed: ")
    print(counter3)
    print("/10000 in ")
    print(end3 - start3)
    print("ms\n")
    
    print("\nPerformance Summary:\n")
    print("- Lightweight tasks: ")
    print(counter1 * 1000 / (end1 - start1))
    print(" tasks/sec\n")
    
    print("- CPU tasks: ")
    print(counter2 * 1000 / (end2 - start2))
    print(" tasks/sec\n")
    
    print("- Nested tasks: ")
    print(counter3 * 1000 / (end3 - start3))
    print(" tasks/sec\n")
    
    assert(counter1 >= 95000, "95% lightweight tasks should complete")
    assert(counter2 >= 9500, "95% CPU tasks should complete")
    assert(counter3 >= 9500, "95% nested tasks should complete")
    
    print("✓ All performance tests passed\n")
}
