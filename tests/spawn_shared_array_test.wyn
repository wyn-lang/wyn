fn main() {
    test_multiple_variables()
}

fn test_multiple_variables() {
    let mut v0: int = 0
    let mut v1: int = 0
    let mut v2: int = 0
    let mut v3: int = 0
    let mut v4: int = 0
    
    spawn {
        v0 = 0
    }
    
    spawn {
        v1 = 10
    }
    
    spawn {
        v2 = 20
    }
    
    spawn {
        v3 = 30
    }
    
    spawn {
        v4 = 40
    }
    
    sleep_ms(200)
    assert(v0 == 0)
    assert(v1 == 10)
    assert(v2 == 20)
    assert(v3 == 30)
    assert(v4 == 40)
}
