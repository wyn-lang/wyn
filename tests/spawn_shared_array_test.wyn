fn main() {
    test_array_append()
    test_array_multiple_values()
}

fn test_array_append() {
    let mut results: [int] = []
    
    for i in 0..5 {
        spawn {
            results.append(i)
        }
    }
    
    sleep_ms(200)
    assert(results.len() == 5)
}

fn test_array_multiple_values() {
    let mut data: [int] = []
    
    spawn {
        data.append(10)
    }
    
    spawn {
        data.append(20)
    }
    
    spawn {
        data.append(30)
    }
    
    sleep_ms(200)
    assert(data.len() == 3)
    
    let mut sum: int = 0
    for i in 0..data.len() {
        sum = sum + data[i]
    }
    assert(sum == 60)
}

fn sleep_ms(ms: int) {
    let start: int = time_now_ms()
    while time_now_ms() - start < ms {}
}
