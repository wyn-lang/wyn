import time

fn main() {
    test_shared_counter()
}

fn test_shared_counter() {
    let counter: int = 0
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    time.sleep_ms(200)
    assert(counter == 10)
}
