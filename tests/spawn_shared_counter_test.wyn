
fn main() {
    test_shared_counter()
}

fn test_shared_counter() {
    let counter: int = 0
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 1
    }
    
    task_join_all()
    assert(counter == 10)
}
