fn main() {
    let mut counter = 0
    
    spawn {
        counter = counter + 1
    }
    
    spawn {
        counter = counter + 10
    }
    
    spawn {
        counter = counter + 100
    }
    
    print_str("Counter: ")
    print(counter)
    print_newline()
    
    assert(counter == 111)
}
