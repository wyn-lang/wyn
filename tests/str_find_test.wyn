import std/io
# Test str_find builtin

fn main() {
    println_str("Testing str_find...")
    
    let haystack: str = "hello world"
    let idx: int = str_find(haystack, "world")
    
    if idx == 6 {
        println_str("PASS: found world at 6")
    } else {
        println_str("FAIL: wrong index for world")
        exit(1)
    }
    
    let idx2: int = str_find(haystack, "hello")
    if idx2 == 0 {
        println_str("PASS: found hello at 0")
    } else {
        println_str("FAIL: wrong index for hello")
        exit(1)
    }
    
    let idx3: int = str_find(haystack, "xyz")
    if idx3 == -1 {
        println_str("PASS: xyz not found")
    } else {
        println_str("FAIL: should not find xyz")
        exit(1)
    }
    
    # Test str_cmp
    let cmp1: int = str_cmp("abc", "abc")
    if cmp1 == 0 {
        println_str("PASS: str_cmp equal")
    } else {
        println_str("FAIL: str_cmp equal")
        exit(1)
    }
    
    let cmp2: int = str_cmp("abc", "abd")
    if cmp2 < 0 {
        println_str("PASS: str_cmp less")
    } else {
        println_str("FAIL: str_cmp less")
        exit(1)
    }
    
    println_str("All str_find tests passed!")
}
