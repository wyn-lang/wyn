import std/io
# Test str_find builtin

fn main() {
    print("Testing str_find...")
    
    const haystack: str = "hello world"
    const idx: int = str_find(haystack, "world")
    
    if idx == 6 {
        print("PASS: found world at 6")
    } else {
        print("FAIL: wrong index for world")
        exit(1)
    }
    
    const idx2: int = str_find(haystack, "hello")
    if idx2 == 0 {
        print("PASS: found hello at 0")
    } else {
        print("FAIL: wrong index for hello")
        exit(1)
    }
    
    const idx3: int = str_find(haystack, "xyz")
    if idx3 == -1 {
        print("PASS: xyz not found")
    } else {
        print("FAIL: should not find xyz")
        exit(1)
    }
    
    # Test str_cmp
    const cmp1: int = str_cmp("abc", "abc")
    if cmp1 == 0 {
        print("PASS: str_cmp equal")
    } else {
        print("FAIL: str_cmp equal")
        exit(1)
    }
    
    const cmp2: int = str_cmp("abc", "abd")
    if cmp2 < 0 {
        print("PASS: str_cmp less")
    } else {
        print("FAIL: str_cmp less")
        exit(1)
    }
    
    print("All str_find tests passed!")
}
