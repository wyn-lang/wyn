fn main() {
    // Test str_split (builtin)
    const text: str = "apple,banana,cherry"
    const fruits: [str] = str_split(text, ",")
    
    // Test iteration (this should work with our new for loop code)
    print("Fruits:")
    for fruit in fruits {
        print(fruit)
    }
    
    // Test with newlines
    const lines: str = "line1\nline2\nline3"
    const parts: [str] = str_split(lines, "\n")
    
    print("Lines:")
    for line in parts {
        print(line)
    }
    
    print("String array tests passed!")
}
