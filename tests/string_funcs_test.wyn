# Test string utility functions

fn main() {
    # str_lower/upper
    assert(str_lower("HELLO") == "hello")
    assert(str_upper("hello") == "HELLO")
    
    # str_starts_with/ends_with
    assert(str_starts_with("hello world", "hello"))
    assert(str_ends_with("hello world", "world"))
    assert(not str_starts_with("hello", "world"))
    
    # str_contains
    assert(str_contains("hello world", "lo wo"))
    assert(not str_contains("hello", "xyz"))
    
    # str_trim
    assert(str_trim("  hello  ") == "hello")
    assert(str_trim("hello") == "hello")
    
    # str_split
    let parts: [str] = str_split("a,b,c", ",")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "b")
    assert(parts[2] == "c")
    
    print_str("string_funcs_test passed")
    print_newline()
}
