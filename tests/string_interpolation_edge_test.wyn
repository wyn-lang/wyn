fn main() {
    print("=== String Interpolation Edge Cases ===")
    
    // Empty string
    const empty = ""
    print("Empty: ${empty}!")
    
    // Zero value
    const zero = 0
    print("Zero: ${zero}")
    
    // Negative numbers
    const neg = -42
    print("Negative: ${neg}")
    
    // Interpolation at start
    const name = "Wyn"
    print("${name} is great")
    
    // Interpolation at end
    print("Language: ${name}")
    
    // Only interpolation
    print("${name}")
    
    // With special characters
    const special = "test"
    print("Value: ${special}!")
    
    print("Edge cases passed!")
}
