fn main() {
    print("=== String Interpolation Test ===")
    
    // String variables
    const name = "Wyn"
    print("Hello ${name}!")
    
    // Int variables  
    const age = 42
    print("Age: ${age}")
    
    const count = 100
    print("Count: ${count}")
    
    print("String interpolation works!")
}
