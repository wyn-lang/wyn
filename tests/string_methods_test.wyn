fn main() {
    print_str("Testing string methods...\n")
    
    # Test upper/lower
    const s: str = "Hello"
    const up: str = upper(s)
    const low: str = lower(s)
    assert(up == "HELLO", "upper works")
    assert(low == "hello", "lower works")
    
    # Test starts_with/ends_with
    assert(starts_with("hello world", "hello"), "starts_with works")
    assert(ends_with("hello world", "world"), "ends_with works")
    assert(not starts_with("hello", "world"), "starts_with false works")
    
    # Test contains
    assert(contains("hello world", "lo wo"), "contains works")
    assert(not contains("hello", "xyz"), "contains false works")
    
    # Test replace
    const r1: str = replace_first("hello hello", "hello", "hi")
    assert(r1 == "hi hello", "replace_first works")
    
    const r2: str = replace_all("hello hello", "hello", "hi")
    assert(r2 == "hi hi", "replace_all works")
    
    # Test repeat
    const rep: str = repeat("ab", 3)
    assert(rep == "ababab", "repeat works")
    
    # Test reverse
    const rev: str = reverse("abc")
    assert(rev == "cba", "reverse works")
    
    # Test is_empty
    assert(is_empty(""), "is_empty works")
    assert(not is_empty("x"), "is_empty false works")
    
    # Test is_alpha
    assert(is_alpha("abc"), "is_alpha works")
    assert(not is_alpha("abc123"), "is_alpha false works")
    
    # Test is_digit
    assert(is_digit("123"), "is_digit works")
    assert(not is_digit("12a"), "is_digit false works")
    
    print_str("✓ All string method tests passed\n")
}
