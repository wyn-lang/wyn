import std/io
# String stdlib tests
# NOTE: These compile but have runtime issues in Stage 0
# Tests will be fully functional in Stage 1

fn main() {
    print_str("String tests compiled successfully")
}

fn test_contains() {
    let result1: bool = contains("hello world", "world")
    let result2: bool = contains("hello", "ell")
    let result3: bool = contains("hello", "xyz")
}

fn test_starts_with() {
    let result1: bool = starts_with("hello", "hel")
    let result2: bool = starts_with("hello", "hello")
    let result3: bool = starts_with("hello", "ell")
}

fn test_ends_with() {
    let result1: bool = ends_with("hello", "llo")
    let result2: bool = ends_with("hello", "hello")
    let result3: bool = ends_with("hello", "hel")
}

fn test_repeat() {
    let result1: str = repeat("ab", 3)
    let result2: str = repeat("x", 5)
    let result3: str = repeat("hi", 0)
}

fn test_reverse() {
    let result1: str = reverse("hello")
    let result2: str = reverse("abc")
    let result3: str = reverse("")
}

fn contains(s: str, substr: str) -> bool {
    if substr.len() == 0 {
        return true
    }
    if substr.len() > s.len() {
        return false
    }
    
    let mut i: int = 0
    while i <= s.len() - substr.len() {
        if s[i:i+substr.len()] == substr {
            return true
        }
        i = i + 1
    }
    return false
}

fn starts_with(s: str, prefix: str) -> bool {
    if prefix.len() > s.len() {
        return false
    }
    return s[0:prefix.len()] == prefix
}

fn ends_with(s: str, suffix: str) -> bool {
    if suffix.len() > s.len() {
        return false
    }
    return s[s.len()-suffix.len():s.len()] == suffix
}

fn repeat(s: str, n: int) -> str {
    let mut result: str = ""
    let mut i: int = 0
    while i < n {
        result = result + s
        i = i + 1
    }
    return result
}

fn reverse(s: str) -> str {
    let mut result: str = ""
    let mut i: int = s.len() - 1
    while i >= 0 {
        result = result + s[i:i+1]
        i = i - 1
    }
    return result
}
