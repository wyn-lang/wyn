
import string

fn main() {
    print("Testing string stdlib...\n")
    
    # Test string length
    assert("hello".len() == 5, "string length")
    assert("".len() == 0, "empty string length")
    
    # Test string concatenation
    const s1: str = "hello"
    const s2: str = " world"
    const s3: str = s1 + s2
    assert(s3 == "hello world", "concatenation")
    assert(s3.len() == 11, "concat length")
    
    # Test string slicing
    const text: str = "hello world"
    assert(text[0:5] == "hello", "slice 0:5")
    assert(text[6:11] == "world", "slice 6:11")
    assert(text[0:1] == "h", "single char slice")
    
    # Test char_at
    assert(string.char_at(text, 0) == "h", "char_at 0")
    assert(string.char_at(text, 6) == "w", "char_at 6")
    
    # Test str_find
    assert(string.find(text, "world") == 6, "find world")
    assert(string.find(text, "hello") == 0, "find hello")
    assert(string.find(text, "xyz") == -1, "find missing")
    assert(string.find(text, "o") == 4, "find char")
    
    # Test str_split
    const parts: [str] = string.split("a,b,c", ",")
    assert(parts.len() == 3, "split length")
    
    const parts2: [str] = string.split("one two three", " ")
    assert(parts2.len() == 3, "split by space")
    
    # Test str_concat
    const joined: str = string.concat("hello", " world")
    assert(joined == "hello world", "str_concat")
    
    # Test str_cmp
    assert(string.cmp("abc", "abc") == 0, "equal strings")
    assert(string.cmp("abc", "def") < 0, "less than")
    assert(string.cmp("def", "abc") > 0, "greater than")
    
    # Test substring
    const sub: str = string.substring(text, 0, 5)
    assert(sub == "hello", "substring")
    
    # Test chr and ord
    assert(string.chr(65) == "A", "chr 65")
    assert(string.chr(97) == "a", "chr 97")
    assert(string.ord("A") == 65, "ord A")
    assert(string.ord("a") == 97, "ord a")
    
    # Test int_to_str
    assert(string.int_to_str(42) == "42", "int_to_str")
    assert(string.int_to_str(0) == "0", "int_to_str 0")
    assert(string.int_to_str(-5) == "-5", "int_to_str negative")
    
    print("✓ All string stdlib tests passed\n")
}
