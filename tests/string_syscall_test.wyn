fn digit_to_char(digit: int) -> str {
    if digit == 0 { return "0" }
    if digit == 1 { return "1" }
    if digit == 2 { return "2" }
    if digit == 3 { return "3" }
    if digit == 4 { return "4" }
    if digit == 5 { return "5" }
    if digit == 6 { return "6" }
    if digit == 7 { return "7" }
    if digit == 8 { return "8" }
    if digit == 9 { return "9" }
    return "0"
}

fn char_to_digit(c: str) -> int {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return 0
}

fn main() {
    print("Testing string conversion...")
    
    const d0: str = digit_to_char(0)
    const d5: str = digit_to_char(5)
    const d9: str = digit_to_char(9)
    
    print("digit_to_char(0) = " + d0)
    print("digit_to_char(5) = " + d5)
    print("digit_to_char(9) = " + d9)
    
    const n0: int = char_to_digit("0")
    const n5: int = char_to_digit("5")
    const n9: int = char_to_digit("9")
    
    if n0 == 0 {
        print("✓ char_to_digit('0') = 0")
    }
    if n5 == 5 {
        print("✓ char_to_digit('5') = 5")
    }
    if n9 == 9 {
        print("✓ char_to_digit('9') = 9")
    }
    
    print("✓ All string conversion tests passed!")
}
