#!/usr/bin/env wyn
# StringBuilder Tests

import stringbuilder
import testing
import string

fn main() {
    testing.describe("StringBuilder") {
        testing.it("creates empty StringBuilder") {
            var sb = stringbuilder.new()
            var result = sb.to_str()
            testing.assert_eq(result, "")
        }
        
        testing.it("appends single string") {
            var sb = stringbuilder.new()
            sb.append("hello")
            var result = sb.to_str()
            testing.assert_eq(result, "hello")
        }
        
        testing.it("appends multiple strings") {
            var sb = stringbuilder.new()
            sb.append("hello")
            sb.append(" ")
            sb.append("world")
            var result = sb.to_str()
            testing.assert_eq(result, "hello world")
        }
        
        testing.it("handles empty strings") {
            var sb = stringbuilder.new()
            sb.append("")
            sb.append("test")
            sb.append("")
            var result = sb.to_str()
            testing.assert_eq(result, "test")
        }
        
        testing.it("builds large strings efficiently") {
            var sb = stringbuilder.new()
            for i in 1..10 {
                sb.append("x")
            }
            var result = sb.to_str()
            # Just check that we get a non-empty result
            testing.assert_eq(result, "xxxxxxxxx")
        }
        
        testing.it("produces same result as traditional concatenation") {
            var sb = stringbuilder.new()
            var traditional = ""
            
            var parts = ["Hello", " ", "beautiful", " ", "world", "!"]
            for part in parts {
                sb.append(part)
                traditional = traditional + part
            }
            
            var sb_result = sb.to_str()
            testing.assert_eq(sb_result, traditional)
            testing.assert_eq(sb_result, "Hello beautiful world!")
        }
    }
}