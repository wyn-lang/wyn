import std/io
struct Point {
    x: int
    y: int
}

struct Rect {
    x: int
    y: int
    width: int
    height: int
    
    fn area(self) -> int {
        return self.width * self.height
    }
}

fn main() {
    let p: Point = Point { x: 3, y: 4 }
    assert(p.x == 3)
    assert(p.y == 4)
    
    let r: Rect = Rect {
        x: 0,
        y: 0,
        width: 10,
        height: 5
    }
    assert(r.width == 10)
    assert(r.x == 0)
    assert(r.area() == 50)
    
    print_str("struct_test: PASS")
}
