import ./std/http

fn main() {
    println_str("HTTP Library Test")
    
    # Status codes
    println(status_ok())
    println(status_not_found())
    
    # Status checks
    println(is_success(200))
    println(is_error(404))
    
    # Headers
    let h: str = make_header("Content-Type", "application/json")
    println_str(h)
    println_str(header_key(h))
    println_str(header_value(h))
    
    # URL parsing
    let url: str = "https://example.com:8080/path?q=test"
    println_str(url_protocol(url))
    println_str(url_host(url))
    println(url_port(url))
    println_str(url_path(url))
    println_str(url_query(url))
    
    # Query params
    let q: str = "id=123&name=test"
    let id: ?str = parse_query_param(q, "id")
    println_str(id ?? "none")
    
    # Response builders
    let resp: Response = json_response(200, "{}")
    println(resp.status)
    println_str(resp.body)
    
    # Request builders
    let req: Request = post_request("/api", "data")
    println_str(req.method)
    println_str(req.path)
    
    println_str("All tests passed")
}
