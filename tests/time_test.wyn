import ./std/time

fn main() {
    print_str("Testing time module...\n")
    
    let now: int = time.now()
    assert(now > 0, "now() should return positive timestamp")
    
    let ms: int = time.now_millis()
    assert(ms > now * 1000 - 1000, "now_millis() should be reasonable")
    
    let year: int = time.current_year()
    assert(year >= 2025, "current_year() should be >= 2025")
    
    let month: int = time.current_month()
    assert(month >= 1 and month <= 12, "month should be 1-12")
    
    let day: int = time.current_day()
    assert(day >= 1 and day <= 31, "day should be 1-31")
    
    assert(time.is_leap_year(2024), "2024 is leap year")
    assert(not time.is_leap_year(2025), "2025 is not leap year")
    
    assert(time.days_in_month(2, 2024) == 29, "Feb 2024 has 29 days")
    assert(time.days_in_month(2, 2025) == 28, "Feb 2025 has 28 days")
    
    let d1: Duration = time.seconds(5)
    assert(d1.seconds == 5, "seconds() creates duration")
    
    let d2: Duration = time.minutes(2)
    assert(d2.seconds == 120, "minutes() creates duration")
    
    let formatted: str = time.format_date(2025, 12, 4)
    assert(formatted == "2025-12-04", "format_date works")
    
    let dow: int = time.day_of_week(2025, 12, 4)
    assert(dow >= 0 and dow <= 6, "day_of_week returns 0-6")
    
    print_str("✓ All time tests passed\n")
}
