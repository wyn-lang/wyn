fn main() {
    print_str("Testing utils stdlib...\n")
    
    # Test min/max
    assert(min(3, 7) == 3, "min works")
    assert(min(-5, -2) == -5, "min negative")
    assert(max(3, 7) == 7, "max works")
    assert(max(-5, -2) == -2, "max negative")
    
    # Test abs
    assert(abs(5) == 5, "abs positive")
    assert(abs(-5) == 5, "abs negative")
    assert(abs(0) == 0, "abs zero")
    
    # Test clamp logic
    let x: int = 5
    assert(x >= 0 and x <= 10, "in range")
    
    let y: int = -5
    assert(y < 0, "below range")
    
    let z: int = 15
    assert(z > 10, "above range")
    
    print_str("✓ All utils stdlib tests passed\n")
}
