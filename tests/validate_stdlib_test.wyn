fn main() {
    print_str("Testing validate stdlib...\n")
    
    # Test string validation
    const s: str = "test"
    assert(s.len() == 4, "length validation")
    assert(s.len() > 0, "non-empty validation")
    
    # Test numeric validation
    const n: int = 42
    assert(n > 0, "positive validation")
    assert(n < 100, "range validation")
    assert(n >= 42, "min validation")
    assert(n <= 42, "max validation")
    
    # Test boolean validation
    const b: bool = true
    assert(b == true, "bool validation")
    assert(not (b == false), "bool negation")
    
    print_str("✓ All validate stdlib tests passed\n")
}
