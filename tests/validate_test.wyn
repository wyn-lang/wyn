import ./std/validate

fn main() {
    print_str("Testing validate module...\n")
    
    assert(validate.is_email("test@example.com"), "valid email")
    assert(not validate.is_email("invalid"), "invalid email")
    
    assert(validate.is_url("https://example.com"), "valid url")
    assert(not validate.is_url("not a url"), "invalid url")
    
    assert(validate.is_ipv4("192.168.1.1"), "valid ipv4")
    assert(not validate.is_ipv4("999.999.999.999"), "invalid ipv4")
    
    assert(validate.is_hex_color("#FF0000"), "valid hex color")
    assert(not validate.is_hex_color("red"), "invalid hex color")
    
    assert(validate.is_alpha("hello"), "alpha string")
    assert(not validate.is_alpha("hello123"), "not alpha")
    
    assert(validate.is_numeric("12345"), "numeric string")
    assert(not validate.is_numeric("123abc"), "not numeric")
    
    assert(validate.is_alphanumeric("hello123"), "alphanumeric")
    assert(not validate.is_alphanumeric("hello!"), "not alphanumeric")
    
    print_str("✓ All validate tests passed\n")
}
