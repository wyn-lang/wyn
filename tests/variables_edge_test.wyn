fn main() {
    print("=== Variables & Scoping Edge Cases ===")
    
    // Shadowing
    const x = 10
    print(x)
    
    // Mutation
    var y = 5
    y = 10
    y = y + 5
    print(y)
    
    // Scope in if
    const a = 1
    if a == 1 {
        const b = 2
        print(b)
    }
    
    // Scope in while
    var i = 0
    while i < 1 {
        const c = 3
        print(c)
        i = i + 1
    }
    
    // Scope in for
    for j in 0..1 {
        const d = 4
        print(d)
    }
    
    // Multiple assignments
    var z = 1
    z = 2
    z = 3
    print(z)
    
    // Assignment with operations
    var w = 10
    w = w * 2
    w = w + 5
    print(w)
    
    // Const with method calls
    const upper = "test".upper()
    print(upper)
    
    // Let with method calls
    var text = "hello"
    text = text.upper()
    print(text)
    
    print("Variables edge cases passed!")
}
