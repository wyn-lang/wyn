#!/bin/bash
# Wyn CLI wrapper - calls the Wyn-based CLI tool

# Find the wyn binary
if [ -f "./build/wyn" ]; then
    exec ./build/wyn "$@"
elif [ -f "/usr/local/bin/wyn-cli" ]; then
    exec /usr/local/bin/wyn-cli "$@"
elif command -v wyn-cli &> /dev/null; then
    exec wyn-cli "$@"
else
    echo "Error: wyn CLI not found. Run 'make all' first."
    exit 1
fi
