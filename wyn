#!/bin/bash
# Wyn Package Manager

set -e

CMD="${1:-help}"
ARG="${2:-.}"

# Find project root (directory with wyn.toml)
find_project_root() {
    local dir="$1"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/wyn.toml" ]; then
            echo "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

# Get entry point from wyn.toml or use default
get_entry_point() {
    if [ -f "wyn.toml" ]; then
        grep "entry" wyn.toml | cut -d'"' -f2 || echo "src/main.wyn"
    else
        echo "src/main.wyn"
    fi
}

case "$CMD" in
    run)
        if [ "$ARG" = "." ]; then
            # Run current directory
            PROJECT_ROOT=$(find_project_root "$(pwd)")
            if [ -z "$PROJECT_ROOT" ]; then
                echo "Error: Not in a Wyn project (no wyn.toml found)"
                exit 1
            fi
            cd "$PROJECT_ROOT"
            ENTRY=$(get_entry_point)
            echo "Running $ENTRY..."
            ./build/stage0 --stage1-tc --stage1-opt -o build/main "$ENTRY"
            ./build/main
        else
            # Run specific file
            ./build/stage0 --stage1-tc --stage1-opt -o /tmp/wyn_run "$ARG"
            /tmp/wyn_run
        fi
        ;;
        
    build)
        if [ "$ARG" = "." ]; then
            # Build current directory
            PROJECT_ROOT=$(find_project_root "$(pwd)")
            if [ -z "$PROJECT_ROOT" ]; then
                echo "Error: Not in a Wyn project (no wyn.toml found)"
                exit 1
            fi
            cd "$PROJECT_ROOT"
            ENTRY=$(get_entry_point)
            NAME=$(grep "name" wyn.toml | head -1 | cut -d'"' -f2 || echo "main")
            echo "Building $NAME from $ENTRY..."
            ./build/stage0 --stage1-tc --stage1-opt -o "build/$NAME" "$ENTRY"
            echo "✓ Built: build/$NAME"
        else
            # Build specific file
            OUTPUT=$(basename "$ARG" .wyn)
            ./build/stage0 --stage1-tc --stage1-opt -o "$OUTPUT" "$ARG"
            echo "✓ Built: $OUTPUT"
        fi
        ;;
    init)
        echo "Initializing Wyn project..."
        cat > wyn.toml << 'EOF'
[package]
name = "myproject"
version = "0.1.0"

[build]
entry = "src/main.wyn"
EOF
        mkdir -p src build .wyn
        cat > src/main.wyn << 'EOF'
import std/io

fn main() {
    io.print_str("Hello, Wyn!")
    io.print_newline()
}
EOF
        echo "✓ Initialized Wyn project"
        ;;
        
    new)
        NAME="$1"
        if [ -z "$NAME" ]; then
            echo "Usage: wyn new <name>"
            exit 1
        fi
        echo "Creating project: $NAME"
        mkdir -p "$NAME"/{src,build,.wyn}
        cat > "$NAME/wyn.toml" << EOF
[package]
name = "$NAME"
version = "0.1.0"

[build]
entry = "src/main.wyn"
EOF
        cat > "$NAME/src/main.wyn" << 'EOF'
import std/io

fn main() {
    io.print_str("Hello from $NAME!")
    io.print_newline()
}
EOF
        echo "✓ Created project: $NAME"
        ;;
        
    build)
        if [ ! -f wyn.toml ]; then
            echo "Error: Not a Wyn project (no wyn.toml)"
            exit 1
        fi
        echo "Building project..."
        ./build/stage0 -o build/app src/main.wyn
        echo "✓ Build successful: build/app"
        ;;
        
    run)
        $0 build
        echo "Running..."
        ./build/app
        ;;
        
    test)
        echo "Running tests..."
        ./tests/run_tests.sh
        ;;
        
    help|*)
        cat << 'EOF'
Wyn Package Manager

Usage: wyn <command> [arguments]

Commands:
  init           Initialize a new project in current directory
  new <name>     Create a new project
  build          Build the project
  run            Build and run the project
  test           Run tests
  help           Show this help

Examples:
  wyn new myapp
  cd myapp
  wyn build
  wyn run
EOF
        ;;
esac
