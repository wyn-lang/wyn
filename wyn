#!/bin/bash
# Wyn CLI - Comprehensive package manager and developer tool

set -e

# Default target (auto-detect)
TARGET="${WYN_TARGET:-$(uname -s | tr '[:upper:]' '[:lower:]')}"
TARGET_ARCH="${WYN_ARCH:-$(uname -m)}"

# Parse flags before command
while [[ $# -gt 0 ]]; do
    case $1 in
        --target)
            TARGET="$2"
            shift 2
            ;;
        --arch)
            TARGET_ARCH="$2"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

CMD="${1:-help}"
shift || true

# Build flags based on target
get_build_flags() {
    local flags="--stage1-tc --stage1-opt"
    case "$TARGET" in
        darwin|macos)
            flags="$flags --target-os macos"
            ;;
        linux)
            flags="$flags --target-os linux"
            ;;
        windows)
            flags="$flags --target-os windows"
            ;;
        ios)
            flags="$flags --target-os macos" # iOS uses macOS backend
            ;;
        android)
            flags="$flags --target-os linux" # Android uses Linux backend
            ;;
    esac
    
    case "$TARGET_ARCH" in
        arm64|aarch64)
            flags="$flags --target arm64"
            ;;
        x86_64|amd64)
            flags="$flags --target x86_64"
            ;;
    esac
    
    echo "$flags"
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Find project root
find_project_root() {
    local dir="$(pwd)"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/wyn.toml" ]; then
            echo "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

# Get entry point from wyn.toml
get_entry_point() {
    if [ -f "wyn.toml" ]; then
        grep "entry" wyn.toml | cut -d'"' -f2 || echo "src/main.wyn"
    else
        echo "src/main.wyn"
    fi
}

# Get project name
get_project_name() {
    if [ -f "wyn.toml" ]; then
        grep "name" wyn.toml | head -1 | cut -d'"' -f2 || echo "main"
    else
        echo "main"
    fi
}

case "$CMD" in
    run)
        ARG="${1:-.}"
        if [ "$ARG" = "." ]; then
            PROJECT_ROOT=$(find_project_root "$(pwd)")
            if [ -z "$PROJECT_ROOT" ]; then
                echo -e "${RED}Error: Not in a Wyn project${NC}"
                exit 1
            fi
            cd "$PROJECT_ROOT"
            ENTRY=$(get_entry_point)
            echo "Running $ENTRY..."
            ./build/stage0 --stage1-tc --stage1-opt -q -o build/main "$ENTRY"
            ./build/main
        else
            ./build/stage0 --stage1-tc --stage1-opt -q -o /tmp/wyn_run "$ARG"
            /tmp/wyn_run
        fi
        ;;
        
    build)
        ARG="${1:-.}"
        FLAGS=$(get_build_flags)
        
        if [ "$TARGET" != "$(uname -s | tr '[:upper:]' '[:lower:]')" ]; then
            echo "Cross-compiling for: $TARGET ($TARGET_ARCH)"
        fi
        
        if [ "$ARG" = "." ]; then
            PROJECT_ROOT=$(find_project_root "$(pwd)")
            if [ -z "$PROJECT_ROOT" ]; then
                echo -e "${RED}Error: Not in a Wyn project${NC}"
                exit 1
            fi
            cd "$PROJECT_ROOT"
            ENTRY=$(get_entry_point)
            NAME=$(get_project_name)
            echo "Building $NAME from $ENTRY for $TARGET..."
            
            # Use installed wyn or local build
            if [ -f "./build/stage0" ]; then
                COMPILER="./build/stage0"
            elif [ -f "/usr/local/bin/wyn" ]; then
                COMPILER="/usr/local/bin/wyn"
            elif command -v wyn &> /dev/null; then
                COMPILER="wyn"
            else
                # In CI, use relative path to stage0
                COMPILER="$(dirname "$0")/build/stage0"
            fi
            
            $COMPILER $FLAGS -o "build/$NAME" "$ENTRY"
            echo -e "${GREEN}✓ Built: build/$NAME${NC}"
        else
            OUTPUT=$(basename "$ARG" .wyn)
            
            # Use installed wyn or local build
            if [ -f "./build/stage0" ]; then
                COMPILER="./build/stage0"
            elif [ -f "/usr/local/bin/wyn" ]; then
                COMPILER="/usr/local/bin/wyn"
            elif command -v wyn &> /dev/null; then
                COMPILER="wyn"
            else
                # In CI, use relative path to stage0
                COMPILER="$(dirname "$0")/build/stage0"
            fi
            
            $COMPILER $FLAGS -o "$OUTPUT" "$ARG"
            echo -e "${GREEN}✓ Built: $OUTPUT${NC}"
        fi
        ;;
        
    clean)
        echo "Cleaning build artifacts..."
        rm -rf build/*.o build/main build/test_* .wyn/test-cache/*
        if [ -f "wyn.toml" ]; then
            NAME=$(get_project_name)
            rm -f "build/$NAME"
        fi
        echo -e "${GREEN}✓ Clean complete${NC}"
        ;;
        
    test)
        if [ -f "wyn.toml" ]; then
            echo "Running project tests..."
            if [ -d "tests" ]; then
                for test in tests/*.wyn; do
                    echo "Testing $(basename $test)..."
                    ./build/stage0 -q -o ".wyn/test-cache/$(basename $test .wyn)" "$test"
                    ".wyn/test-cache/$(basename $test .wyn)" && echo -e "${GREEN}✓ PASS${NC}" || echo -e "${RED}✗ FAIL${NC}"
                done
            else
                echo "No tests/ directory found"
            fi
        else
            echo "Running Wyn test suite..."
            make test
        fi
        ;;
        
    inline)
        CODE="$*"
        if [ -z "$CODE" ]; then
            echo "Usage: wyn inline \"code here\""
            echo "Example: wyn inline \"print(42)\""
            exit 1
        fi
        
        # Create temporary file with proper escaping
        cat > /tmp/wyn_inline.wyn << EOF
fn main() {
    $CODE
}
EOF
        ./build/stage0 -q -o /tmp/wyn_inline /tmp/wyn_inline.wyn 2>&1
        if [ $? -eq 0 ]; then
            /tmp/wyn_inline
        fi
        rm -f /tmp/wyn_inline.wyn /tmp/wyn_inline
        ;;
        
    exec)
        # Execute Wyn code from stdin
        CODE=$(cat)
        cat > /tmp/wyn_exec.wyn << EOF
fn main() {
    $CODE
}
EOF
        ./build/stage0 -q -o /tmp/wyn_exec /tmp/wyn_exec.wyn
        /tmp/wyn_exec
        rm -f /tmp/wyn_exec.wyn /tmp/wyn_exec
        ;;
        
    fmt)
        echo "Code formatting not yet implemented"
        echo "Planned for v1.1"
        ;;
        
    doc)
        ARG="${1:-index}"
        
        # Check if it's a module.function lookup
        if [[ "$ARG" == *.* ]]; then
            MODULE="${ARG%%.*}"
            FUNC="${ARG#*.}"
            
            # Find the module file
            if [ -f "std/${MODULE}.wyn" ]; then
                echo -e "${GREEN}=== $MODULE.$FUNC ===${NC}"
                echo ""
                # Extract function documentation
                awk "/^fn $FUNC/,/^}/" "std/${MODULE}.wyn" | head -20
                echo ""
                echo "Module: std/${MODULE}.wyn"
            else
                echo -e "${RED}Module not found: $MODULE${NC}"
                exit 1
            fi
            exit 0
        fi
        
        # Check if it's a module lookup
        if [ -f "std/${ARG}.wyn" ]; then
            echo -e "${GREEN}=== Module: $ARG ===${NC}"
            echo ""
            # Show module header and function list
            head -20 "std/${ARG}.wyn"
            echo ""
            echo "Functions:"
            grep "^fn " "std/${ARG}.wyn" | sed 's/fn /  /' | head -20
            echo ""
            echo "Full docs: std/${ARG}.wyn"
            exit 0
        fi
        
        # Map common names to doc files
        case "$ARG" in
            .|index|main) DOC="docs/README.md" ;;
            start|quickstart) DOC="docs/QUICK_START.md" ;;
            lang|language|spec) DOC="docs/2-language-spec.md" ;;
            stdlib|lib|std) DOC="docs/4-stdlib-reference.md" ;;
            gui) DOC="docs/gui-support.md" ;;
            mobile|ios) DOC="docs/mobile-ios.md" ;;
            cli|commands) DOC="docs/CLI.md" ;;
            perf|performance|bench) DOC="benchmarks/FINAL_RESULTS.md" ;;
            *) DOC="docs/$ARG.md" ;;
        esac
        
        if [ ! -f "$DOC" ]; then
            echo -e "${RED}Documentation not found: $ARG${NC}"
            echo "Try: wyn doc start, wyn doc fs, or wyn doc fs.read_file"
            exit 1
        fi
        
        # Format like manpage using less with color
        if command -v bat > /dev/null 2>&1; then
            bat --style=plain --paging=always "$DOC"
        elif command -v less > /dev/null 2>&1; then
            less -R "$DOC"
        else
            cat "$DOC"
        fi
        ;;
        
    bench)
        echo "Running benchmarks..."
        cd benchmarks && ./run.sh
        ;;
        
    install)
        echo "Installing Wyn to /usr/local/bin..."
        sudo cp build/stage0 /usr/local/bin/wyn
        echo -e "${GREEN}✓ Installed: /usr/local/bin/wyn${NC}"
        ;;
        
    uninstall)
        echo "Uninstalling Wyn..."
        sudo rm -f /usr/local/bin/wyn
        echo -e "${GREEN}✓ Uninstalled${NC}"
        ;;
        
    version)
        echo "Wyn v1.0.0"
        echo "Stage 1 compiler with optimizations"
        ;;
        
    init)
        echo "Initializing Wyn project..."
        cat > wyn.toml << 'EOF'
[package]
name = "myproject"
version = "0.1.0"

[build]
entry = "src/main.wyn"
EOF
        mkdir -p src build .wyn
        cat > src/main.wyn << 'EOF'
fn main() {
    io.print_str("Hello, Wyn!")
    io.print_newline()
}
EOF
        echo -e "${GREEN}✓ Initialized Wyn project${NC}"
        echo "Run: wyn run ."
        ;;
        
    new)
        NAME="$1"
        if [ -z "$NAME" ]; then
            echo "Usage: wyn new <name>"
            exit 1
        fi
        echo "Creating project: $NAME"
        mkdir -p "$NAME"/{src,build,.wyn}
        cat > "$NAME/wyn.toml" << EOF
[package]
name = "$NAME"
version = "0.1.0"

[build]
entry = "src/main.wyn"
EOF
        cat > "$NAME/src/main.wyn" << 'EOF'
fn main() {
    io.print_str("Hello from $NAME!")
    io.print_newline()
}
EOF
        echo -e "${GREEN}✓ Created project: $NAME${NC}"
        echo "cd $NAME && wyn run ."
        ;;
        
    help|--help|-h)
        cat << 'EOF'
Wyn CLI - Fast, simple, universal programming language

USAGE:
    wyn [--target OS] [--arch ARCH] <command> [arguments]

TARGETS:
    --target darwin|linux|windows|ios|android
    --arch arm64|x86_64
    
    Or set environment variables:
    export WYN_TARGET=linux
    export WYN_ARCH=x86_64

COMMANDS:
    run [file|.]        Run a Wyn program or current project
    build [file|.]      Build a Wyn program or current project
    init                Initialize a new project in current directory
    new <name>          Create a new directory with project
    test                Run tests
    clean               Clean build artifacts
    
    inline "code"       Execute inline Wyn code
    exec                Execute Wyn code from stdin
    
    bench               Run performance benchmarks
    doc [topic]         Show documentation (like manpages)
                        Topics: start, lang, stdlib, gui, mobile, cli, perf
                        Modules: wyn doc fs, wyn doc io, wyn doc math
                        Functions: wyn doc fs.read, wyn doc io.print
    fmt                 Format code (planned)
    
    install             Install wyn to /usr/local/bin
    uninstall           Remove wyn from /usr/local/bin
    version             Show version
    help                Show this help

EXAMPLES:
    # Basic usage
    wyn init                    # Create project in current dir
    wyn new myapp               # Create myapp/ directory
    wyn run .                   # Run current project
    wyn build .                 # Build current project
    
    # Cross-compilation
    wyn --target linux build .          # Build for Linux
    wyn --target windows build .        # Build for Windows
    wyn --target ios build .            # Build for iOS
    wyn --target android build .        # Build for Android
    
    # Quick commands
    wyn inline "print(42)"      # Execute inline code
    echo "print(42)" | wyn exec # Execute from stdin
    wyn doc fs.read             # Show function docs
    wyn clean                   # Clean build artifacts

COMPILER OPTIONS:
    wyn -o output input.wyn                    # Basic compile
    wyn --stage1-tc --stage1-opt -o out in.wyn # With optimizations

For more: wyn doc start
EOF
        ;;
        
    *)
        echo -e "${RED}Unknown command: $CMD${NC}"
        echo "Run 'wyn help' for usage"
        exit 1
        ;;
esac
